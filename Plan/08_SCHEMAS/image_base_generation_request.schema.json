{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Wave15 Image Base Generation Request",
  "required": [
    "request_id",
    "scene_director_plan_id",
    "requested_output",
    "routing_preferences"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "scene_director_plan_id": {
      "type": "string"
    },
    "requested_output": {
      "type": "object"
    },
    "routing_preferences": {
      "type": "object"
    },
    "character_bindings": {
      "type": "array"
    },
    "environment_binding": {
      "type": "object"
    },
    "camera_plan_id": {
      "type": "string"
    },
    "mask_plan_id": {
      "type": "string"
    },
    "control_plan_id": {
      "type": "string"
    }
  }
}
