{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-av-local-repair-plan/1.0.0",
  "title": "Hyperreal Local AV Repair Plan",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "av_local_repair_plan_id",
    "revision",
    "status",
    "created_at",
    "scope",
    "sync_evaluation_ref",
    "accepted_video_parent_ref",
    "accepted_audio_parent_ref",
    "repairs",
    "accepted_parents_immutable",
    "smallest_failed_scope_only",
    "full_av_rerender",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_av_local_repair_plan"
    },
    "av_local_repair_plan_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "scope": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ExecutionScope"
    },
    "sync_evaluation_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "accepted_video_parent_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "accepted_audio_parent_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "repairs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event_ids",
          "target_span",
          "method",
          "maximum_time_stretch_ratio",
          "handle_samples_before",
          "handle_samples_after",
          "hypothesis_ref"
        ],
        "properties": {
          "event_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "target_span": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/MediaSpan"
          },
          "method": {
            "enum": [
              "shift_event",
              "bounded_time_stretch",
              "silence_pad",
              "crossfade",
              "regenerate_audio_event",
              "rerender_mouth_span",
              "remux_only"
            ]
          },
          "maximum_time_stretch_ratio": {
            "type": "number",
            "minimum": 0.95,
            "maximum": 1.05
          },
          "handle_samples_before": {
            "type": "integer",
            "minimum": 1
          },
          "handle_samples_after": {
            "type": "integer",
            "minimum": 1
          },
          "hypothesis_ref": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "accepted_parents_immutable": {
      "const": true
    },
    "smallest_failed_scope_only": {
      "const": true
    },
    "full_av_rerender": {
      "const": false
    }
  },
  "additionalProperties": false
}
