{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-timeline-edit-result/1.0.0",
  "title": "Hyperreal Operator Timeline Edit Result and Conflict Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "timeline_edit_result_id",
    "revision",
    "status",
    "created_at",
    "transaction_ref",
    "result",
    "base_revision",
    "result_revision",
    "result_timeline_ref",
    "conflict_refs",
    "merge_preview_ref",
    "undo_transaction_ref",
    "correlation_id",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_timeline_edit_result"
    },
    "timeline_edit_result_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "transaction_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "result": {
      "enum": [
        "applied",
        "rejected",
        "conflict",
        "rebase_preview",
        "manual_merge_required",
        "duplicate"
      ]
    },
    "base_revision": {
      "type": "integer",
      "minimum": 0
    },
    "result_revision": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "result_timeline_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "conflict_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 0
    },
    "merge_preview_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "undo_transaction_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
