{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/audio_benchmark_corpus_manifest.schema.json",
  "title": "Wave64 Row109 Audio Benchmark Corpus Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tracker_id",
    "item_id",
    "record_type",
    "compiler_revision",
    "policy_revision",
    "policy_sha256",
    "corpus_revision",
    "is_synthetic",
    "library_authority",
    "pcm_decode_invoked",
    "live_full_library_scan",
    "dependency_admissions",
    "required_gates",
    "coverage_matrix",
    "partition_manifest",
    "adversarial_cases",
    "truth_integrity",
    "cases",
    "decision",
    "manifest_sha256"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "tracker_id": { "type": "string", "const": "TRK-W64-109" },
    "item_id": { "type": "string", "const": "ITEM-W64-109" },
    "record_type": {
      "type": "string",
      "const": "audio_benchmark_corpus_manifest"
    },
    "compiler_revision": {
      "type": "string",
      "const": "wave64_row109_audio_benchmark_corpus_compiler_v0.1.0"
    },
    "policy_revision": {
      "type": "string",
      "const": "wave64_row109_audio_benchmark_corpus_policy_v0.1.0"
    },
    "policy_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "corpus_revision": {
      "type": "string",
      "const": "wave64_row109_synthetic_benchmark_corpus_v0.1.0"
    },
    "is_synthetic": { "type": "boolean", "const": true },
    "library_authority": { "type": "boolean", "const": false },
    "pcm_decode_invoked": { "type": "boolean", "const": false },
    "live_full_library_scan": { "type": "boolean", "const": false },
    "dependency_admissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["TRK-W64-067", "TRK-W64-068"],
      "properties": {
        "TRK-W64-067": { "$ref": "#/$defs/dependency_admission" },
        "TRK-W64-068": { "$ref": "#/$defs/dependency_admission" }
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        { "const": "coverage_matrix" },
        { "const": "annotation_authority" },
        { "const": "partition_separation" },
        { "const": "adversarial_cases" },
        { "const": "truth_integrity" }
      ],
      "items": false
    },
    "coverage_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_families_covered",
        "materials_covered",
        "footwear_covered",
        "partitions_with_reference_truth",
        "calibration_and_held_out_overlap_families",
        "coverage_complete"
      ],
      "properties": {
        "event_families_covered": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "materials_covered": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "footwear_covered": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "partitions_with_reference_truth": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["train", "calibration", "held_out_test"]
          },
          "uniqueItems": true
        },
        "calibration_and_held_out_overlap_families": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "coverage_complete": { "type": "boolean" }
      }
    },
    "partition_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train", "calibration", "held_out_test", "adversarial", "separation_ok"],
      "properties": {
        "train": { "$ref": "#/$defs/partition_stats" },
        "calibration": { "$ref": "#/$defs/partition_stats" },
        "held_out_test": { "$ref": "#/$defs/partition_stats" },
        "adversarial": { "$ref": "#/$defs/partition_stats" },
        "separation_ok": { "type": "boolean" }
      }
    },
    "adversarial_cases": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_roles", "roles_present", "blocked_contamination_count", "complete"],
      "properties": {
        "required_roles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "roles_present": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blocked_contamination_count": { "type": "integer", "minimum": 0 },
        "complete": { "type": "boolean" }
      }
    },
    "truth_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "immutable_truth_bound",
        "generated_cannot_contaminate_reference",
        "partition_truth_rules_ok",
        "integrity_ok"
      ],
      "properties": {
        "immutable_truth_bound": { "type": "boolean" },
        "generated_cannot_contaminate_reference": { "type": "boolean" },
        "partition_truth_rules_ok": { "type": "boolean" },
        "integrity_ok": { "type": "boolean" }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/corpus_case" }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "row109_acceptance",
        "product_completion",
        "runtime_completion",
        "gates_satisfied",
        "safe_next_action"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["fixture_corpus_compiled", "blocked"]
        },
        "row109_acceptance": {
          "type": "string",
          "enum": ["fixture_only", "held"]
        },
        "product_completion": { "type": "boolean", "const": false },
        "runtime_completion": { "type": "boolean", "const": false },
        "gates_satisfied": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "safe_next_action": { "type": "string", "minLength": 1 }
      }
    },
    "manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "$defs": {
    "dependency_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tracker_id",
        "delta_path",
        "delta_exists",
        "delta_sha256",
        "row_complete",
        "dependency_satisfied",
        "blocker_codes"
      ],
      "properties": {
        "tracker_id": { "type": "string", "minLength": 1 },
        "delta_path": { "type": "string", "minLength": 1 },
        "delta_exists": { "type": "boolean" },
        "delta_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "row_complete": { "type": "boolean" },
        "dependency_satisfied": { "type": "boolean" },
        "blocker_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "partition_stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_count", "case_ids", "truth_classes"],
      "properties": {
        "case_count": { "type": "integer", "minimum": 0 },
        "case_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "truth_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["reference_truth", "generated_candidate", "adversarial_decoy"]
          },
          "uniqueItems": true
        }
      }
    },
    "corpus_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "partition",
        "event_family",
        "material",
        "footwear",
        "room",
        "ownership",
        "camera",
        "truth_class",
        "adversarial_role",
        "annotation",
        "media_locator",
        "truth_sha256",
        "source_fixture",
        "source_fixture_sha256"
      ],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "partition": {
          "type": "string",
          "enum": ["train", "calibration", "held_out_test", "adversarial"]
        },
        "event_family": { "type": "string", "minLength": 1 },
        "material": { "type": "string", "minLength": 1 },
        "footwear": { "type": "string", "minLength": 1 },
        "room": { "type": "string", "minLength": 1 },
        "ownership": { "type": "string", "minLength": 1 },
        "camera": { "type": "string", "minLength": 1 },
        "truth_class": {
          "type": "string",
          "enum": ["reference_truth", "generated_candidate", "adversarial_decoy"]
        },
        "adversarial_role": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "annotation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "annotator_role",
            "silent_event",
            "labels",
            "generated_from_eval_pass",
            "rights_bound"
          ],
          "properties": {
            "annotator_role": {
              "type": "string",
              "enum": ["synthetic_fixture_authority", "human_gold"]
            },
            "silent_event": { "type": "boolean" },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": ["string", "boolean", "number", "null"]
              }
            },
            "generated_from_eval_pass": { "type": "boolean" },
            "rights_bound": { "type": "boolean" }
          }
        },
        "media_locator": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "descriptor_path",
            "descriptor_sha256",
            "pcm_bytes",
            "decode_invoked"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "const": "synthetic_fixture_descriptor"
            },
            "descriptor_path": { "type": "string", "minLength": 1 },
            "descriptor_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "pcm_bytes": { "type": "null" },
            "decode_invoked": { "type": "boolean", "const": false }
          }
        },
        "truth_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "source_fixture": { "type": "string", "minLength": 1 },
        "source_fixture_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
