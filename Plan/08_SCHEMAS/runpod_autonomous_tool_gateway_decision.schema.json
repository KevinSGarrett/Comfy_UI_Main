{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_tool_gateway_decision.schema.json",
  "title": "Wave64 Autonomous Tool Gateway Admission Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "decision_id", "request_id", "job_id", "actor_role_id",
    "policy_sha256", "action_type", "normalized_target", "admission_disposition",
    "execution_performed", "reason_codes", "secret_scan_categories"
  ],
  "properties": {
    "schema_version": {"const": "wave64.aqa.tool_gateway_decision.v1"},
    "decision_id": {"$ref": "#/definitions/sha256"},
    "request_id": {"type": "string", "minLength": 1},
    "job_id": {"type": "string", "minLength": 1},
    "actor_role_id": {"type": "string", "minLength": 1},
    "policy_sha256": {"$ref": "#/definitions/sha256"},
    "action_type": {"type": "string", "minLength": 1},
    "normalized_target": {"type": "string", "minLength": 1},
    "admission_disposition": {"enum": ["ADMIT_FOR_SEPARATE_EXECUTOR", "DENY"]},
    "execution_performed": {"const": false},
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}
    },
    "secret_scan_categories": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}
    }
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
