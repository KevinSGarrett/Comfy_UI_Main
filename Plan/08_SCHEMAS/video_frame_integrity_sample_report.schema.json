{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave12 Video Frame Integrity Sample Report",
  "type": "object",
  "required": [
    "video_path",
    "sampled_frames",
    "decision"
  ],
  "properties": {
    "video_path": {
      "type": "string"
    },
    "sampled_frames": {
      "type": "array"
    },
    "temporal_identity_switches": {
      "type": "integer"
    },
    "merged_body_frame_count": {
      "type": "integer"
    },
    "decision": {
      "type": "string"
    }
  }
}
