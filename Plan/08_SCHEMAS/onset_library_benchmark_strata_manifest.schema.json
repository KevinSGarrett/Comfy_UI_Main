{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/onset_library_benchmark_strata_manifest.schema.json",
  "title": "Wave64 Row072 Onset Library Benchmark Strata Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "tracker_id",
    "item_id",
    "strata_registry_revision",
    "threshold_registry_revision",
    "detector_revision",
    "authority",
    "selection_policy",
    "source_retained_records",
    "strata_targets",
    "candidates",
    "counts",
    "truth_onset_status",
    "blocker_codes",
    "decision"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "artifact_type": {
      "type": "string",
      "const": "onset_library_benchmark_strata_manifest"
    },
    "tracker_id": { "type": "string", "const": "TRK-W64-072" },
    "item_id": { "type": "string", "const": "ITEM-W64-072" },
    "strata_registry_revision": {
      "type": "string",
      "const": "wave64_row072_onset_library_benchmark_strata_v0.1.0"
    },
    "threshold_registry_revision": {
      "type": "string",
      "const": "wave64_row072_onset_thresholds_v0.1.0"
    },
    "detector_revision": {
      "type": "string",
      "const": "wave64_row072_onset_transient_detector_v0.1.0"
    },
    "authority": {
      "type": "string",
      "const": "candidate_shortlist_pending_truth_onsets"
    },
    "selection_policy": {
      "type": "string",
      "const": "retained_records_only_no_pcm_decode_no_full_rescan"
    },
    "source_retained_records": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes", "records_scanned"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 0 },
        "records_scanned": { "type": "integer", "minimum": 0 }
      }
    },
    "strata_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stratum_target" }
    },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate" }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strata_targets",
        "strata_filled",
        "strata_unfilled",
        "candidates_selected",
        "truth_labeled",
        "truth_unlabeled"
      ],
      "properties": {
        "strata_targets": { "type": "integer", "minimum": 0 },
        "strata_filled": { "type": "integer", "minimum": 0 },
        "strata_unfilled": { "type": "integer", "minimum": 0 },
        "candidates_selected": { "type": "integer", "minimum": 0 },
        "truth_labeled": { "type": "integer", "minimum": 0 },
        "truth_unlabeled": { "type": "integer", "minimum": 0 }
      }
    },
    "truth_onset_status": {
      "enum": ["absent", "pending", "partial", "complete"]
    },
    "blocker_codes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "library_authority",
        "row_complete",
        "product_completion",
        "threshold_authority_unfrozen",
        "benchmark_strata_calibrated"
      ],
      "properties": {
        "status": { "enum": ["blocked", "pass"] },
        "library_authority": { "type": "boolean" },
        "row_complete": { "type": "boolean" },
        "product_completion": { "type": "boolean" },
        "threshold_authority_unfrozen": { "type": "boolean" },
        "benchmark_strata_calibrated": { "type": "boolean" },
        "safe_next_action": { "type": "string", "minLength": 1 }
      }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "stratum_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stratum_id",
        "role",
        "event_type",
        "extension",
        "onset_status",
        "max_candidates"
      ],
      "properties": {
        "stratum_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "event_type": { "type": "string", "minLength": 1 },
        "extension": { "type": "string", "pattern": "^\\.[a-z0-9]+$" },
        "onset_status": { "enum": ["pass", "blocked"] },
        "max_candidates": { "type": "integer", "minimum": 1 }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "stratum_id",
        "relative_path",
        "asset_id",
        "role",
        "event_type",
        "extension",
        "onset_status",
        "source_sha256",
        "canonical_pcm_sha256",
        "truth_onset_sample",
        "truth_label_status"
      ],
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "stratum_id": { "type": "string", "minLength": 1 },
        "relative_path": { "type": "string", "minLength": 1 },
        "asset_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "event_type": { "type": "string", "minLength": 1 },
        "extension": { "type": "string", "minLength": 1 },
        "onset_status": { "enum": ["pass", "blocked"] },
        "technical_onset_pass": { "type": "boolean" },
        "measured_onset_sample": { "type": ["integer", "null"], "minimum": 0 },
        "sample_rate_hz": { "type": ["integer", "null"], "minimum": 1 },
        "channels": { "type": ["integer", "null"], "minimum": 1 },
        "frame_count": { "type": ["integer", "null"], "minimum": 0 },
        "source_sha256": {
          "oneOf": [
            { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            { "type": "null" }
          ]
        },
        "canonical_pcm_sha256": {
          "oneOf": [
            { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            { "type": "null" }
          ]
        },
        "truth_onset_sample": { "type": ["integer", "null"], "minimum": 0 },
        "truth_label_status": {
          "enum": ["unlabeled", "pending", "labeled", "blocked"]
        },
        "blocker_code": { "type": ["string", "null"] }
      }
    }
  }
}
