{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wave64_phoneme_viseme_compilation.schema.json",
  "title": "Wave64 phoneme-to-viseme compilation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "compiler_version", "status", "input", "mapping", "timing", "events", "frame_controls", "coverage", "gates", "authority"],
  "properties": {
    "schema_version": {"const": "wave64.phoneme_viseme_compilation.v1"},
    "compiler_version": {"const": "wave64_ipa_viseme_compiler_v1"},
    "status": {"enum": ["PASS_EXACT_ACCEPTED_ALIGNMENT_TO_VISEME_CONTROLS", "FAIL_VISEME_COMPILATION"]},
    "input": {"type": "object"},
    "mapping": {"type": "object"},
    "timing": {"type": "object"},
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["event_index", "source_kind", "phoneme", "viseme", "category", "start_sample", "end_sample", "start_seconds", "end_seconds", "posterior", "controls"],
        "properties": {
          "event_index": {"type": "integer", "minimum": 0},
          "source_kind": {"enum": ["aligned_phoneme", "inferred_silence_gap"]},
          "phoneme": {"type": "string"},
          "viseme": {"type": "string"},
          "category": {"type": "string"},
          "start_sample": {"type": "integer", "minimum": 0},
          "end_sample": {"type": "integer", "minimum": 1},
          "start_seconds": {"type": "number", "minimum": 0},
          "end_seconds": {"type": "number", "exclusiveMinimum": 0},
          "posterior": {"type": "number", "minimum": 0, "maximum": 1},
          "controls": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "frame_controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["frame_index", "center_sample", "primary_viseme", "viseme_weights", "controls"],
        "properties": {
          "frame_index": {"type": "integer", "minimum": 0},
          "center_sample": {"type": "integer", "minimum": 0},
          "primary_viseme": {"type": "string"},
          "viseme_weights": {"type": "object", "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}},
          "controls": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "coverage": {"type": "object"},
    "gates": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "authority": {"type": "object", "additionalProperties": {"type": "boolean"}}
  }
}
