{
  "$id": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/maskfactory_release_snapshot_v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "fixture_only": {
            "const": true
          }
        },
        "required": [
          "fixture_only"
        ]
      },
      "then": {
        "properties": {
          "genuine_runtime_evidence_refs": {
            "maxItems": 0
          },
          "release_context": {
            "const": "fixture_validation"
          },
          "release_status": {
            "const": "fixture"
          },
          "runtime_completion_claimed": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "release_context": {
            "const": "production_runtime"
          }
        },
        "required": [
          "release_context"
        ]
      },
      "then": {
        "properties": {
          "fixture_only": {
            "const": false
          },
          "genuine_runtime_evidence_refs": {
            "minItems": 1
          },
          "release_status": {
            "const": "published"
          },
          "signature_trust": {
            "properties": {
              "trust_result": {
                "const": "trusted"
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "artifact_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "minItems": 1,
      "type": "array"
    },
    "capability_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "type": "array"
    },
    "certificate_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "type": "array"
    },
    "completion_profiles": {
      "additionalProperties": false,
      "properties": {
        "core_autonomous_runtime": {
          "enum": [
            "not_claimed",
            "planned",
            "qualified"
          ]
        },
        "independent_real_accuracy": {
          "enum": [
            "not_claimed",
            "planned",
            "qualified"
          ]
        },
        "scale_daz_maturity": {
          "enum": [
            "not_claimed",
            "planned",
            "qualified"
          ]
        }
      },
      "required": [
        "core_autonomous_runtime",
        "independent_real_accuracy",
        "scale_daz_maturity"
      ],
      "type": "object"
    },
    "component_bindings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "component": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
          },
          "sha256": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/sha256"
          },
          "version": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "component",
          "version",
          "sha256"
        ],
        "type": "object"
      },
      "minItems": 4,
      "type": "array"
    },
    "contract_bindings": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/contract_binding"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "created_at": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/timestamp"
    },
    "fixture_only": {
      "type": "boolean"
    },
    "genuine_runtime_evidence_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "type": "array",
      "uniqueItems": true
    },
    "maskfactory_release_snapshot_v2_id": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "mutable_worktree_consumption_allowed": {
      "const": false
    },
    "normalization_hash_profile": {
      "const": "main_domain_separated_sorted_utf8_json_v2_excluding_normalization_hash_signature_and_signature_trust"
    },
    "normalization_payload_sha256": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/sha256"
    },
    "normalization_signature": {
      "minLength": 16,
      "type": "string"
    },
    "normalization_signature_domain": {
      "const": "comfy_ui_main.maskfactory_normalized_release.v2"
    },
    "normalization_signature_trust": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/signing_trust_verification"
    },
    "producer_source": {
      "additionalProperties": false,
      "properties": {
        "commit_sha": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "repository_id": {
          "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
        },
        "source_clean": {
          "const": true
        },
        "tag": {
          "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
        }
      },
      "required": [
        "repository_id",
        "commit_sha",
        "tag",
        "source_clean"
      ],
      "type": "object"
    },
    "published_at": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/timestamp"
    },
    "raw_producer_release_ref": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
    },
    "record_type": {
      "const": "maskfactory_release_snapshot_v2"
    },
    "release_context": {
      "enum": [
        "fixture_validation",
        "production_runtime"
      ]
    },
    "release_id": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "release_signature": {
      "minLength": 16,
      "type": "string"
    },
    "release_signature_domain": {
      "const": "maskfactory.sha256_digest_bytes.v1"
    },
    "release_status": {
      "enum": [
        "fixture",
        "published",
        "superseded",
        "revoked"
      ]
    },
    "revision": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "revocation_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "type": "array"
    },
    "runtime_completion_claimed": {
      "const": false
    },
    "schema_version": {
      "const": "2.0.0"
    },
    "signature_trust": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/signing_trust_verification"
    },
    "snapshot_sha256": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/sha256"
    }
  },
  "required": [
    "schema_version",
    "record_type",
    "maskfactory_release_snapshot_v2_id",
    "revision",
    "created_at",
    "fixture_only",
    "runtime_completion_claimed",
    "release_id",
    "snapshot_sha256",
    "raw_producer_release_ref",
    "release_status",
    "published_at",
    "release_context",
    "genuine_runtime_evidence_refs",
    "release_signature_domain",
    "release_signature",
    "normalization_hash_profile",
    "normalization_payload_sha256",
    "normalization_signature_domain",
    "normalization_signature",
    "normalization_signature_trust",
    "producer_source",
    "contract_bindings",
    "component_bindings",
    "capability_refs",
    "certificate_refs",
    "revocation_refs",
    "artifact_refs",
    "signature_trust",
    "completion_profiles",
    "mutable_worktree_consumption_allowed"
  ],
  "title": "maskfactory_release_snapshot_v2",
  "type": "object"
}
