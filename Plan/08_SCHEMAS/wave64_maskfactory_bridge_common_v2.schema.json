{
  "$defs": {
    "authority": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "authority_state": {
                "const": "certified"
              }
            },
            "required": [
              "authority_state"
            ]
          },
          "then": {
            "properties": {
              "certificate_ref": {
                "$ref": "#/$defs/immutable_ref"
              },
              "issuer_kind": {
                "enum": [
                  "maskfactory_autonomous",
                  "human_anchor_optional"
                ]
              }
            },
            "required": [
              "certificate_ref",
              "issuer_kind"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "authority_state": {
                "const": "certified"
              },
              "issuer_kind": {
                "const": "maskfactory_autonomous"
              }
            },
            "required": [
              "authority_state",
              "issuer_kind"
            ]
          },
          "then": {
            "properties": {
              "claim_class": {
                "const": "operationally_certified_artifact"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "authority_state": {
                "enum": [
                  "hypothesis",
                  "draft"
                ]
              }
            },
            "required": [
              "authority_state"
            ]
          },
          "then": {
            "properties": {
              "claim_class": {
                "const": "machine_candidate"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "authority_state": {
                "const": "qa_passed_noncertified"
              }
            },
            "required": [
              "authority_state"
            ]
          },
          "then": {
            "properties": {
              "claim_class": {
                "const": "qa_passed_machine_candidate"
              }
            }
          }
        }
      ],
      "properties": {
        "authority_state": {
          "enum": [
            "invalid",
            "hypothesis",
            "draft",
            "qa_passed_noncertified",
            "certified"
          ]
        },
        "certificate_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/immutable_ref"
            },
            {
              "type": "null"
            }
          ]
        },
        "certificate_scope": {
          "items": {
            "$ref": "#/$defs/id"
          },
          "type": "array",
          "uniqueItems": true
        },
        "claim_class": {
          "enum": [
            "invalid",
            "machine_candidate",
            "qa_passed_machine_candidate",
            "operationally_certified_artifact",
            "independent_real_accuracy_anchor",
            "training_gold"
          ]
        },
        "issuer_kind": {
          "enum": [
            "maskfactory_autonomous",
            "human_anchor_optional",
            "none"
          ]
        },
        "revocation_checked_at": {
          "$ref": "#/$defs/timestamp"
        },
        "verified_at": {
          "$ref": "#/$defs/timestamp"
        }
      },
      "required": [
        "authority_state",
        "issuer_kind",
        "claim_class",
        "certificate_ref",
        "certificate_scope",
        "verified_at",
        "revocation_checked_at"
      ],
      "type": "object"
    },
    "blocker": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "completion_profile": {
                "enum": [
                  "independent_real_accuracy",
                  "scale_daz_maturity"
                ]
              }
            },
            "required": [
              "completion_profile"
            ]
          },
          "then": {
            "properties": {
              "core_impact": {
                "const": "non_blocking"
              }
            }
          }
        }
      ],
      "properties": {
        "blocks_scope": {
          "enum": [
            "dependent_pass",
            "required_release_path",
            "whole_run"
          ]
        },
        "category": {
          "enum": [
            "compatibility",
            "availability",
            "integrity",
            "ownership",
            "transform",
            "authority",
            "quality",
            "recovery",
            "policy"
          ]
        },
        "code": {
          "$ref": "#/$defs/id"
        },
        "completion_profile": {
          "enum": [
            "core_autonomous_runtime",
            "independent_real_accuracy",
            "scale_daz_maturity"
          ]
        },
        "core_impact": {
          "enum": [
            "blocking",
            "non_blocking"
          ]
        },
        "evidence_refs": {
          "items": {
            "$ref": "#/$defs/immutable_ref"
          },
          "type": "array"
        },
        "message": {
          "minLength": 1,
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "category",
        "message",
        "retryable",
        "blocks_scope",
        "completion_profile",
        "core_impact",
        "evidence_refs"
      ],
      "type": "object"
    },
    "certificate_temporal_evaluation": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "temporal_decision": {
                "const": "valid"
              }
            },
            "required": [
              "temporal_decision"
            ]
          },
          "then": {
            "properties": {
              "certificate_not_revoked": {
                "const": true
              },
              "decision_before_expiry": {
                "const": true
              },
              "issued_not_after_decision": {
                "const": true
              },
              "revocation_index_current_at_decision": {
                "const": true
              }
            }
          }
        }
      ],
      "properties": {
        "certificate_expires_at": {
          "$ref": "#/$defs/timestamp"
        },
        "certificate_issued_at": {
          "$ref": "#/$defs/timestamp"
        },
        "certificate_not_revoked": {
          "type": "boolean"
        },
        "certificate_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "decision_at": {
          "$ref": "#/$defs/timestamp"
        },
        "decision_before_expiry": {
          "type": "boolean"
        },
        "issued_not_after_decision": {
          "type": "boolean"
        },
        "revocation_checked_at": {
          "$ref": "#/$defs/timestamp"
        },
        "revocation_index_current_at_decision": {
          "type": "boolean"
        },
        "revocation_index_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "revocation_index_valid_from": {
          "$ref": "#/$defs/timestamp"
        },
        "revocation_index_valid_until": {
          "$ref": "#/$defs/timestamp"
        },
        "temporal_decision": {
          "enum": [
            "valid",
            "future_issued",
            "expired",
            "revoked",
            "stale_revocation_index"
          ]
        }
      },
      "required": [
        "certificate_ref",
        "decision_at",
        "certificate_issued_at",
        "certificate_expires_at",
        "revocation_index_ref",
        "revocation_index_valid_from",
        "revocation_index_valid_until",
        "revocation_checked_at",
        "issued_not_after_decision",
        "decision_before_expiry",
        "revocation_index_current_at_decision",
        "certificate_not_revoked",
        "temporal_decision"
      ],
      "type": "object"
    },
    "contract_binding": {
      "additionalProperties": false,
      "properties": {
        "schema_id": {
          "format": "uri",
          "type": "string"
        },
        "schema_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "schema_source": {
          "minLength": 3,
          "type": "string"
        },
        "schema_version": {
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "type": "string"
        },
        "wire_schema_name": {
          "$ref": "#/$defs/id"
        }
      },
      "required": [
        "wire_schema_name",
        "schema_source",
        "schema_id",
        "schema_version",
        "schema_sha256"
      ],
      "type": "object"
    },
    "coordinate_state": {
      "additionalProperties": false,
      "properties": {
