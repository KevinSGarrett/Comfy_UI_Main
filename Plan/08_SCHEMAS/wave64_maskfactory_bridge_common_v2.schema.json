                "$ref": "#/$defs/sha256"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "retry_kind": {
                "const": "transport_replay"
              }
            },
            "required": [
              "retry_kind"
            ]
          },
          "then": {
            "properties": {
              "hypothesis_class": {
                "const": "transport_replay"
              }
            }
          }
        }
      ],
      "properties": {
        "hypothesis_class": {
          "enum": [
            "initial",
            "geometry",
            "ownership",
            "boundary",
            "model_route",
            "prompt_control",
            "transform",
            "transport_replay"
          ]
        },
        "hypothesis_id": {
          "$ref": "#/$defs/id"
        },
        "material_change_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "retry_kind": {
          "enum": [
            "initial",
            "quality_hypothesis",
            "transport_replay"
          ]
        }
      },
      "required": [
        "hypothesis_id",
        "hypothesis_class",
        "material_change_sha256",
        "retry_kind"
      ],
      "type": "object"
