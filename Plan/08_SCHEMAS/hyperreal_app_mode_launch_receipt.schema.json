{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-app-mode-launch-receipt/1.0.0",
  "title": "Hyperreal ComfyUI App Mode Launch and Return Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "app_mode_launch_receipt_id",
    "revision",
    "status",
    "created_at",
    "launch_request_ref",
    "result",
    "comfyui_submission_ref",
    "execution_receipt_ref",
    "returned_artifact_refs",
    "returned_payload_schema_ids",
    "callback_receipt_ref",
    "correlation_id",
    "promotion_performed",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_app_mode_launch_receipt"
    },
    "app_mode_launch_receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "launch_request_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "result": {
      "enum": [
        "opened",
        "submitted",
        "cancelled",
        "completed",
        "failed",
        "expired"
      ]
    },
    "comfyui_submission_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "execution_receipt_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "returned_artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 0
    },
    "returned_payload_schema_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "callback_receipt_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "promotion_performed": {
      "const": false
    }
  },
  "additionalProperties": false
}
