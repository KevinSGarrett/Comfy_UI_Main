{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave27 Short Span Repair Execution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name", "version", "source_bindings", "executor_registry", "algorithm",
    "frame_count", "image_format", "target_frame_indices", "preserved_frame_indices", "span_executions",
    "candidate_manifest", "claims"
  ],
  "properties": {
    "schema_name": {"const": "wave27_short_span_repair_execution"},
    "version": {"type": "integer", "const": 1},
    "source_bindings": {
      "type": "object", "additionalProperties": false, "required": ["repair_ledger", "source_manifest"],
      "properties": {"repair_ledger": {"$ref": "#/$defs/file_binding"}, "source_manifest": {"$ref": "#/$defs/file_binding"}}
    },
    "executor_registry": {
      "type": "object", "additionalProperties": false, "required": ["path", "sha256", "version"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "version": {"type": "integer", "const": 1}}
    },
    "algorithm": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "opencv_version", "thread_count", "rng_seed", "candidate_scope"],
      "properties": {
        "name": {"const": "opencv_bidirectional_farneback_interpolation_v1"},
        "opencv_version": {"type": "string", "minLength": 1}, "thread_count": {"const": 1}, "rng_seed": {"const": 0},
        "candidate_scope": {"const": "technical_candidate_generation_only"}
      }
    },
    "frame_count": {"type": "integer", "minimum": 3},
    "image_format": {
      "type": "object", "additionalProperties": false, "required": ["width", "height", "channel_count", "dtype"],
      "properties": {
        "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1},
        "channel_count": {"type": "integer", "enum": [1, 3, 4]}, "dtype": {"const": "uint8"}
      }
    },
    "target_frame_indices": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
    "preserved_frame_indices": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "integer", "minimum": 0}},
    "span_executions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["start_frame_index", "end_frame_index", "span_length", "left_boundary_frame", "right_boundary_frame", "failure", "recommended_action", "target_weights"],
        "properties": {
          "start_frame_index": {"type": "integer", "minimum": 1}, "end_frame_index": {"type": "integer", "minimum": 1},
          "span_length": {"type": "integer", "minimum": 1, "maximum": 5},
          "left_boundary_frame": {"type": "integer", "minimum": 0}, "right_boundary_frame": {"type": "integer", "minimum": 2},
          "failure": {"const": "isolated_flicker"},
          "recommended_action": {"enum": ["frame_local_visual_repair", "short_span_repair"]},
          "target_weights": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false, "required": ["frame_index", "right_boundary_weight"],
              "properties": {"frame_index": {"type": "integer", "minimum": 1}, "right_boundary_weight": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1}}
            }
          }
        }
      }
    },
    "candidate_manifest": {"$ref": "#/$defs/file_binding"},
    "claims": {
      "type": "object", "additionalProperties": false,
      "required": ["technical_candidate_generated", "passing_frames_preserved", "identity_repair", "contact_deformation_repair", "before_after_visual_review", "identity_environment_visual_preservation", "runtime_repair_proof", "final_temporal_acceptance", "final_promotion"],
      "properties": {
        "technical_candidate_generated": {"const": true}, "passing_frames_preserved": {"const": true},
        "identity_repair": {"const": false}, "contact_deformation_repair": {"const": false},
        "before_after_visual_review": {"const": false}, "identity_environment_visual_preservation": {"const": false},
        "runtime_repair_proof": {"const": false}, "final_temporal_acceptance": {"const": false}, "final_promotion": {"const": false}
      }
    }
  },
  "$defs": {
    "file_binding": {
      "type": "object", "additionalProperties": false, "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
    }
  }
}
