{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/wave64-regional-repair-authority/1.0.0",
  "title": "Wave64 Rows174-176 Regional Repair Authority",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "authority_id", "rows_covered", "source_bridge_evidence",
    "accepted_parent", "regional_edit_contract", "prior_failed_attempt",
    "repair_hypothesis", "reintegration_gate", "runtime_execution_allowed",
    "promotion_allowed", "content_based_suppression"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "authority_id": {"type": "string", "minLength": 1},
    "rows_covered": {"const": [174, 175, 176]},
    "source_bridge_evidence": {"$ref": "#/$defs/file_ref"},
    "accepted_parent": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "artifact_sha256", "immutable"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "artifact_sha256": {"$ref": "#/$defs/sha256"},
        "immutable": {"const": true}
      }
    },
    "regional_edit_contract": {
      "type": "object", "additionalProperties": false,
      "required": [
        "contract_id", "status", "execution_allowed", "parent_artifact_id",
        "target", "protected_scopes", "crop", "resolution", "denoise_bounds",
        "transform", "recomposition", "mask_authority", "blocker_codes"
      ],
      "properties": {
        "contract_id": {"type": "string", "minLength": 1},
        "status": {"const": "blocked_missing_trusted_mask"},
        "execution_allowed": {"const": false},
        "parent_artifact_id": {"type": "string", "minLength": 1},
        "target": {
          "type": "object", "additionalProperties": false,
          "required": ["owner_id", "person_index", "region", "coordinate_space", "mask_binding_id"],
          "properties": {
            "owner_id": {"type": "string", "minLength": 1},
            "person_index": {"type": "integer", "minimum": 0},
            "region": {"type": "string", "minLength": 1},
            "coordinate_space": {"const": "source_pixels"},
            "mask_binding_id": {"type": "null"}
          }
        },
        "protected_scopes": {
          "type": "array", "minItems": 3, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "crop": {
          "type": "object", "additionalProperties": false,
          "required": ["padding_px", "feather_px", "bounds_policy"],
          "properties": {
            "padding_px": {"type": "integer", "minimum": 0, "maximum": 512},
            "feather_px": {"type": "integer", "minimum": 0, "maximum": 128},
            "bounds_policy": {"const": "clamp_to_parent"}
          }
        },
        "resolution": {
          "type": "object", "additionalProperties": false,
          "required": ["width", "height", "resize_policy"],
          "properties": {
            "width": {"type": "integer", "minimum": 64},
            "height": {"type": "integer", "minimum": 64},
            "resize_policy": {"const": "preserve_aspect_pad_only"}
          }
        },
        "denoise_bounds": {
          "type": "object", "additionalProperties": false,
          "required": ["minimum", "maximum", "selected"],
          "properties": {
            "minimum": {"type": "number", "minimum": 0, "maximum": 1},
            "maximum": {"type": "number", "minimum": 0, "maximum": 1},
            "selected": {"type": "null"}
          }
        },
        "transform": {
          "type": "object", "additionalProperties": false,
          "required": ["transform_id", "parameters", "parameters_sha256", "invertible", "roundtrip_evidence_id"],
          "properties": {
            "transform_id": {"type": "string", "minLength": 1},
            "parameters": {"type": "object"},
            "parameters_sha256": {"$ref": "#/$defs/sha256"},
            "invertible": {"const": true},
            "roundtrip_evidence_id": {"type": "string", "minLength": 1}
          }
        },
        "recomposition": {
          "type": "object", "additionalProperties": false,
          "required": ["method", "parent_mutation_allowed", "candidate_output_required"],
          "properties": {
            "method": {"const": "new_candidate_over_immutable_parent"},
            "parent_mutation_allowed": {"const": false},
            "candidate_output_required": {"const": true}
          }
        },
        "mask_authority": {
          "type": "object", "additionalProperties": false,
          "required": ["required_access_mode", "allowed_truth_tiers", "certificate_required", "mode_b_draft_only", "writes_gold"],
          "properties": {
            "required_access_mode": {"const": "mode_a_package_read"},
            "allowed_truth_tiers": {
              "const": ["approved_package", "certified_machine"]
            },
            "certificate_required": {"const": true},
            "mode_b_draft_only": {"const": true},
            "writes_gold": {"const": false}
          }
        },
        "blocker_codes": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "prior_failed_attempt": {
      "type": "object", "additionalProperties": false,
      "required": ["attempt_id", "defect_codes", "changed_variables", "result"],
      "properties": {
        "attempt_id": {"type": "string", "minLength": 1},
        "defect_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "changed_variables": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "result": {"const": "failed"}
      }
    },
    "repair_hypothesis": {"type": "object"},
    "reintegration_gate": {
      "type": "object", "additionalProperties": false,
      "required": [
        "gate_id", "status", "baseline_artifact_id", "candidate_artifact_id",
        "accepted_parent_retained", "required_gates", "gate_results",
        "promotion_transaction_id", "decision", "blocker_codes"
      ],
      "properties": {
        "gate_id": {"type": "string", "minLength": 1},
        "status": {"const": "blocked_no_candidate_artifact"},
        "baseline_artifact_id": {"type": "string", "minLength": 1},
        "candidate_artifact_id": {"type": "null"},
        "accepted_parent_retained": {"const": true},
        "required_gates": {
          "type": "array", "minItems": 13, "maxItems": 13, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "gate_results": {
          "type": "array", "minItems": 13, "maxItems": 13,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["gate", "status", "evidence_ids"],
            "properties": {
              "gate": {"type": "string", "minLength": 1},
              "status": {"const": "not_run"},
              "evidence_ids": {"const": []}
            }
          }
        },
        "promotion_transaction_id": {"type": "null"},
        "decision": {"const": "blocked"},
        "blocker_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "runtime_execution_allowed": {"const": false},
    "promotion_allowed": {"const": false},
    "content_based_suppression": {"const": false}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "file_ref": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
