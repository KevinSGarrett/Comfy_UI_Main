{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Wave15 Base Generation Plan",
  "required": [
    "plan_id",
    "selected_lane_id",
    "engine_family",
    "passes",
    "qa_gates"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "selected_lane_id": {
      "type": "string"
    },
    "engine_family": {
      "type": "string"
    },
    "fallback_lane_ids": {
      "type": "array"
    },
    "passes": {
      "type": "array"
    },
    "qa_gates": {
      "type": "array"
    },
    "promotion_allowed": {
      "type": "boolean"
    }
  }
}
