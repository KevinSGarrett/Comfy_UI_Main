{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave27 Frame Continuity Metrics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name", "version", "sequence_sha256", "manifest", "threshold_registry",
    "analyzer", "frame_count", "image_dimensions", "camera_intent_policy",
    "pair_metrics", "aggregate_metrics", "decisions", "non_claims"
  ],
  "properties": {
    "schema_name": {"const": "wave27_frame_continuity_metrics"},
    "version": {"type": "integer", "const": 1},
    "sequence_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "manifest": {"$ref": "#/$defs/file_binding"},
    "threshold_registry": {
      "allOf": [
        {"$ref": "#/$defs/file_binding"},
        {"type": "object", "required": ["version"], "properties": {"version": {"type": "integer", "minimum": 1}}}
      ]
    },
    "analyzer": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "opencv_version", "thread_count", "rng_seed", "rounding_digits"],
      "properties": {
        "algorithm": {"type": "string", "minLength": 1},
        "opencv_version": {"type": "string", "minLength": 1},
        "thread_count": {"type": "integer", "const": 1},
        "rng_seed": {"type": "integer", "const": 0},
        "rounding_digits": {"type": "integer", "minimum": 0, "maximum": 12}
      }
    },
    "frame_count": {"type": "integer", "minimum": 2},
    "image_dimensions": {
      "type": "object", "additionalProperties": false, "required": ["width", "height"],
      "properties": {"width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}}
    },
    "camera_intent_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["required_field", "required_value", "all_frames_declared_static", "planned_motion_supported"],
      "properties": {
        "required_field": {"type": "string", "minLength": 1},
        "required_value": {"type": "string", "minLength": 1},
        "all_frames_declared_static": {"type": "boolean"},
        "planned_motion_supported": {"type": "boolean", "const": false}
      }
    },
    "pair_metrics": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": [
          "from_frame", "to_frame", "elapsed_seconds", "luma_mae_percent", "phase_response",
          "camera_shift_x_diagonal_ratio", "camera_shift_y_diagonal_ratio",
          "camera_shift_diagonal_ratio", "flow_median_diagonal_ratio",
          "flow_p95_diagonal_ratio", "aligned_border_residual_percent", "finite"
        ],
        "properties": {
          "from_frame": {"type": "integer", "minimum": 0},
          "to_frame": {"type": "integer", "minimum": 1},
          "elapsed_seconds": {"type": "number", "exclusiveMinimum": 0},
          "luma_mae_percent": {"$ref": "#/$defs/nonnegative_number"},
          "phase_response": {"$ref": "#/$defs/nonnegative_number"},
          "camera_shift_x_diagonal_ratio": {"type": "number"},
          "camera_shift_y_diagonal_ratio": {"type": "number"},
          "camera_shift_diagonal_ratio": {"$ref": "#/$defs/nonnegative_number"},
          "flow_median_diagonal_ratio": {"$ref": "#/$defs/nonnegative_number"},
          "flow_p95_diagonal_ratio": {"$ref": "#/$defs/nonnegative_number"},
          "aligned_border_residual_percent": {"$ref": "#/$defs/nonnegative_number"},
          "finite": {"type": "boolean", "const": true}
        }
      }
    },
    "aggregate_metrics": {
      "type": "object", "additionalProperties": false,
      "required": ["max_luma_mae_percent", "min_phase_response", "max_camera_shift_diagonal_ratio", "max_flow_p95_diagonal_ratio", "max_aligned_border_residual_percent"],
      "properties": {
        "max_luma_mae_percent": {"$ref": "#/$defs/nonnegative_number"},
        "min_phase_response": {"$ref": "#/$defs/nonnegative_number"},
        "max_camera_shift_diagonal_ratio": {"$ref": "#/$defs/nonnegative_number"},
        "max_flow_p95_diagonal_ratio": {"$ref": "#/$defs/nonnegative_number"},
        "max_aligned_border_residual_percent": {"$ref": "#/$defs/nonnegative_number"}
      }
    },
    "decisions": {
      "type": "object", "additionalProperties": false,
      "required": ["motion_analysis", "object_background_camera_analysis"],
      "properties": {
        "motion_analysis": {"$ref": "#/$defs/decision"},
        "object_background_camera_analysis": {"$ref": "#/$defs/decision"}
      }
    },
    "non_claims": {
      "type": "object", "additionalProperties": false,
      "required": ["identity", "face", "body", "hands", "contact", "audio", "flicker_score_authority", "runtime_generation", "final_visual_acceptance", "promotion"],
      "properties": {
        "identity": {"const": false}, "face": {"const": false}, "body": {"const": false},
        "hands": {"const": false}, "contact": {"const": false}, "audio": {"const": false},
        "flicker_score_authority": {"const": false}, "runtime_generation": {"const": false},
        "final_visual_acceptance": {"const": false}, "promotion": {"const": false}
      }
    }
  },
  "$defs": {
    "nonnegative_number": {"type": "number", "minimum": 0},
    "file_binding": {
      "type": "object", "additionalProperties": false, "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "version": {"type": "integer", "minimum": 1}}
    },
    "decision": {
      "type": "object", "additionalProperties": false, "required": ["result", "failures"],
      "properties": {"result": {"enum": ["pass", "fail"]}, "failures": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}
    }
  }
}
