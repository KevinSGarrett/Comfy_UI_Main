{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_one_pod_migration_state.schema.json",
  "title": "Wave64 Autonomous One-Pod Migration State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "state_id", "previous_state_id", "sequence", "authoritative_pod_id",
    "legacy_pod_id", "network_volume_id", "profile_id", "candidate_pod_id", "candidate_hourly_usd",
    "passed_gates", "phase", "current_pod_remains_authoritative", "old_pod_stop_authorized",
    "execution_performed", "last_event_id", "reason_codes"
  ],
  "properties": {
    "schema_version": {"const": "wave64.aqa.one_pod_migration_state.v1"},
    "state_id": {"$ref": "#/definitions/sha256"},
    "previous_state_id": {"oneOf": [{"$ref": "#/definitions/sha256"}, {"type": "null"}]},
    "sequence": {"type": "integer", "minimum": 0},
    "authoritative_pod_id": {"type": "string", "minLength": 1},
    "legacy_pod_id": {"type": ["string", "null"]},
    "network_volume_id": {"type": "string", "minLength": 1},
    "profile_id": {"enum": ["preferred_2xa40", "performance_fallback_blackwell96"]},
    "candidate_pod_id": {"type": ["string", "null"]},
    "candidate_hourly_usd": {"type": ["number", "null"], "minimum": 0},
    "passed_gates": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "phase": {"enum": ["STOCK_WAIT", "CANDIDATE_QUALIFYING", "MIGRATION_READY", "NEW_AUTHORITATIVE", "ROLLBACK_REQUIRED", "ROLLED_BACK"]},
    "current_pod_remains_authoritative": {"type": "boolean"},
    "old_pod_stop_authorized": {"type": "boolean"},
    "execution_performed": {"const": false},
    "last_event_id": {"type": ["string", "null"]},
    "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}}
  },
  "definitions": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
