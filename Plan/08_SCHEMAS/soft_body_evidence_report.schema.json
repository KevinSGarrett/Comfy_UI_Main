{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wave21 SoftBodyEvidenceReport",
  "type": "object",
  "required": [
    "profile_id",
    "region_id",
    "profile_match_score",
    "deformation_plausibility_score",
    "pass"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "region_id": {
      "type": "string"
    },
    "profile_match_score": {
      "type": "number"
    },
    "deformation_plausibility_score": {
      "type": "number"
    },
    "identity_preserved": {
      "type": "boolean"
    },
    "pose_preserved": {
      "type": "boolean"
    },
    "body_proportions_preserved": {
      "type": "boolean"
    },
    "temporal_continuity_score": {
      "type": "number"
    },
    "pass": {
      "type": "boolean"
    }
  }
}
