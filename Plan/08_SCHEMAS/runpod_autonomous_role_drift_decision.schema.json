{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_role_drift_decision.schema.json",
  "title": "Wave64 Autonomous Role Drift Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "decision_id", "baseline_certificate_id", "current_certificate_id", "evaluated_at", "disposition", "scope_operational", "reason_codes"],
  "properties": {
    "schema_version": {"const": "wave64.aqa.role_drift_decision.v1"},
    "decision_id": {"$ref": "#/definitions/sha256"},
    "baseline_certificate_id": {"$ref": "#/definitions/sha256"},
    "current_certificate_id": {"$ref": "#/definitions/sha256"},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "disposition": {"enum": ["ACTIVE_SCOPE_UNCHANGED", "SUSPEND_BASELINE_NOT_QUALIFIED", "SUSPEND_EXPIRED", "SUSPEND_FINGERPRINT_DRIFT", "SUSPEND_SCOPE_DRIFT", "SUSPEND_BEHAVIOR_DRIFT"]},
    "scope_operational": {"type": "boolean"},
    "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}}
  },
  "definitions": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
