{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave12 Crop Boundary Contract",
  "type": "object",
  "required": [
    "safe_margin_ratio",
    "forbidden_crop_points"
  ],
  "properties": {
    "safe_margin_ratio": {
      "type": "number"
    },
    "forbidden_crop_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_crop_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auto_repair_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
