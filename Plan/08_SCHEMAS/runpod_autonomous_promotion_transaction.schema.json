{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_promotion_transaction.schema.json",
  "title": "Wave64 Autonomous Content-Addressed Promotion Transaction Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "transaction_id", "bundle_id", "candidate_sha256", "bucket",
    "key_prefix", "bundle_manifest_key", "object_keys", "integration_authority_approval_sha256",
    "disposition", "execution_performed"
  ],
  "properties": {
    "schema_version": {"const": "wave64.aqa.promotion_transaction.v1"},
    "transaction_id": {"$ref": "#/definitions/sha256"},
    "bundle_id": {"$ref": "#/definitions/sha256"},
    "candidate_sha256": {"$ref": "#/definitions/sha256"},
    "bucket": {"type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$"},
    "key_prefix": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).{1,256}$"},
    "bundle_manifest_key": {"type": "string", "minLength": 1, "maxLength": 1024},
    "object_keys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 1024}
    },
    "integration_authority_approval_sha256": {"oneOf": [{"$ref": "#/definitions/sha256"}, {"type": "null"}]},
    "disposition": {"enum": ["HELD_NON_PASS_DECISION", "HELD_PENDING_INTEGRATION_AUTHORITY", "READY_FOR_INTEGRATION_AUTHORITY_EXECUTION"]},
    "execution_performed": {"const": false}
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
