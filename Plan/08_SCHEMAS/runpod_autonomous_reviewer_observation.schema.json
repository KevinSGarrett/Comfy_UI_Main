{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_reviewer_observation.schema.json",
  "title": "Wave64 Autonomous Reviewer Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "observation_id", "job_id", "contract_id", "role_id", "model_id",
    "checkpoint_sha256", "runtime_digest", "prompt_sha256", "qualification_certificate_id",
    "decision", "structured_response_valid", "product_authority_claimed", "defects", "evidence_sha256"
  ],
  "properties": {
    "schema_version": {"const": "wave64.aqa.reviewer_observation.v1"},
    "observation_id": {"$ref": "#/definitions/sha256"},
    "job_id": {"type": "string", "pattern": "^W64-AQA-JOB-[A-Za-z0-9._-]{1,96}$"},
    "contract_id": {"$ref": "#/definitions/sha256"},
    "role_id": {"type": "string", "pattern": "^W64-AQA-ROLE-[A-Z0-9-]+$"},
    "model_id": {"type": "string", "minLength": 1},
    "checkpoint_sha256": {"$ref": "#/definitions/sha256"},
    "runtime_digest": {"$ref": "#/definitions/sha256"},
    "prompt_sha256": {"$ref": "#/definitions/sha256"},
    "qualification_certificate_id": {"$ref": "#/definitions/sha256"},
    "decision": {"enum": ["PASS", "FAIL", "ABSTAIN"]},
    "structured_response_valid": {"type": "boolean"},
    "product_authority_claimed": {"type": "boolean"},
    "defects": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["code", "severity", "locator"],
        "properties": {
          "code": {"type": "string", "minLength": 1, "maxLength": 128},
          "severity": {"enum": ["blocking", "major", "minor"]},
          "locator": {"type": "string", "minLength": 1, "maxLength": 512}
        }
      }
    },
    "evidence_sha256": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/definitions/sha256"}}
  },
  "definitions": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
