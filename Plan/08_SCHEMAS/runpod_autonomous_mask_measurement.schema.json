{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_mask_measurement.schema.json",
  "title": "Wave64 Autonomous Golden-Mask Measurement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "measurement_id", "contract_id", "candidate_sha256",
    "golden_reference_sha256", "target_binding", "evaluator_version", "geometry",
    "alpha_mode", "defect_regions", "metrics", "gate_results", "disposition"
  ],
  "properties": {
    "schema_version": {"const": "wave64.aqa.mask_measurement.v1"},
    "measurement_id": {"$ref": "#/definitions/sha256"},
    "contract_id": {"$ref": "#/definitions/sha256"},
    "candidate_sha256": {"$ref": "#/definitions/sha256"},
    "golden_reference_sha256": {"$ref": "#/definitions/sha256"},
    "target_binding": {"type": "string", "minLength": 1, "maxLength": 256},
    "evaluator_version": {"const": "w64-aqa-mask-measure-v1"},
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_width", "candidate_height", "golden_width", "golden_height"],
      "properties": {
        "candidate_width": {"type": "integer", "minimum": 1},
        "candidate_height": {"type": "integer", "minimum": 1},
        "golden_width": {"type": "integer", "minimum": 1},
        "golden_height": {"type": "integer", "minimum": 1}
      }
    },
    "alpha_mode": {"enum": ["binary", "soft_matte", "both"]},
    "defect_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "x", "y", "width", "height", "pixels"],
        "properties": {
          "category": {"enum": ["largest_missing_region", "largest_leakage_region"]},
          "x": {"type": "integer", "minimum": 0},
          "y": {"type": "integer", "minimum": 0},
          "width": {"type": "integer", "minimum": 1},
          "height": {"type": "integer", "minimum": 1},
          "pixels": {"type": "integer", "minimum": 1}
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {"type": ["number", "integer", "boolean", "string"]},
      "required": [
        "decode_success", "candidate_width", "candidate_height", "golden_width", "golden_height",
        "width_delta", "height_delta", "reference_width_delta", "reference_height_delta",
        "candidate_foreground_fraction", "golden_foreground_fraction", "intersection_over_union",
        "dice_coefficient", "foreground_completeness", "foreground_leakage_fraction",
        "false_negative_pixel_fraction", "false_positive_pixel_fraction", "alpha_mae", "alpha_rmse",
        "non_binary_pixel_fraction", "boundary_f1_tolerance_2px", "boundary_mean_distance_px",
        "boundary_p95_distance_px", "boundary_hausdorff_distance_px", "candidate_component_count",
        "golden_component_count", "component_count_delta", "candidate_hole_count", "golden_hole_count",
        "hole_count_delta", "bounding_box_iou"
      ]
    },
    "gate_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "metric", "status", "observed", "operator", "threshold", "on_failure"],
        "properties": {
          "gate_id": {"type": "string", "minLength": 1},
          "metric": {"type": "string", "minLength": 1},
          "status": {"enum": ["PASS", "FAIL", "MEASUREMENT_UNAVAILABLE"]},
          "observed": {},
          "operator": {"type": "string"},
          "threshold": {},
          "on_failure": {"enum": ["HOLD", "REPAIR", "REJECT"]}
        }
      }
    },
    "disposition": {"enum": ["PASS_DETERMINISTIC_GATES", "FAIL_DETERMINISTIC_GATES"]}
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
