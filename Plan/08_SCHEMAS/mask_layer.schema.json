{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave13 Mask Layer",
  "type": "object",
  "required": [
    "mask_id",
    "scale",
    "target_type",
    "source",
    "required_evidence"
  ],
  "properties": {
    "mask_id": {
      "type": "string"
    },
    "scale": {
      "type": "string",
      "enum": [
        "macro",
        "major",
        "minor",
        "micro",
        "nano"
      ]
    },
    "target_type": {
      "type": "string"
    },
    "person_instance_id": {
      "type": "string"
    },
    "body_region_id": {
      "type": "string"
    },
    "fabric_region_id": {
      "type": "string"
    },
    "contact_type": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "planned",
        "detector",
        "manual",
        "reference_map",
        "comfyui_runtime"
      ]
    },
    "bbox_normalized": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 4,
      "maxItems": 4
    },
    "mask_png_path": {
      "type": "string"
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
