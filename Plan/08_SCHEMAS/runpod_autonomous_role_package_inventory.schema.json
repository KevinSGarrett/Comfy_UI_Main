{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runpod_autonomous_role_package_inventory.schema.json",
  "title": "RunPod autonomous role package inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "program_id", "observed_at_utc", "scope", "runtime_policy", "packages"],
  "properties": {
    "schema_version": {"const": "wave64.aqa.role_package_inventory.v1"},
    "program_id": {"const": "W64-AQA"},
    "observed_at_utc": {"type": "string", "format": "date-time"},
    "scope": {"const": "REPOSITORY_BACKED_STATIC_AND_SCOPED_RUNTIME_EVIDENCE"},
    "runtime_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_pod_remains_authoritative", "single_gpu_role_at_a_time", "durable_root", "current_pod_only"],
      "properties": {
        "current_pod_remains_authoritative": {"const": true},
        "single_gpu_role_at_a_time": {"const": true},
        "durable_root": {"const": "/workspace"},
        "current_pod_only": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pod_id", "gpu", "physical_vram_mib", "shared_coordinator_required", "sequential_residency_required", "cpu_nvme_offload_allowed", "alternative_hardware_watcher", "alternative_pod_creation", "external_inference"],
          "properties": {
            "pod_id": {"const": "1q4ji0gg1fkhvt"},
            "gpu": {"const": "NVIDIA RTX 6000 Ada Generation"},
            "physical_vram_mib": {"const": 49140},
            "shared_coordinator_required": {"const": true},
            "sequential_residency_required": {"const": true},
            "cpu_nvme_offload_allowed": {"const": true},
            "alternative_hardware_watcher": {"const": false},
            "alternative_pod_creation": {"const": false},
            "external_inference": {"const": false}
          }
        }
      }
    },
    "packages": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package_id", "roles", "identity", "installation", "qualification", "authority"],
        "properties": {
          "package_id": {"type": "string", "pattern": "^W64-AQA-PKG-[A-Z0-9-]+$"},
          "roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "identity": {
            "type": "object",
            "additionalProperties": false,
            "required": ["display_name", "publisher", "repository_id", "source_url", "identity_state", "license_state"],
            "properties": {
              "display_name": {"type": "string", "minLength": 1},
              "publisher": {"type": "string", "minLength": 1},
              "repository_id": {"type": "string", "minLength": 1},
              "source_url": {"type": "string", "minLength": 1},
              "identity_state": {"enum": ["LOCAL_DIGEST_VERIFIED_UPSTREAM_REVISION_UNVERIFIED", "OFFICIAL_UPSTREAM_IDENTITY_VERIFIED_REVISION_UNPINNED", "OFFICIAL_UPSTREAM_IDENTITY_VERIFIED_REVISION_PINNED", "EXTERNAL_RELEASE_REQUIRED"]},
              "license_state": {"enum": ["APACHE-2.0_UPSTREAM_REPORTED_NOT_LOCALLY_ACCEPTED", "APACHE-2.0_ACCEPTED_FOR_COMFY_UI_MAIN_PROJECT_USE", "WEIGHTS_APACHE-2.0_AND_PROJECT_CODE_MIT_ACCEPTED_FOR_COMFY_UI_MAIN_PROJECT_USE", "LOCAL_RUNTIME_LICENSE_NOT_REVERIFIED", "EXTERNAL_RELEASE_REQUIRED"]}
            }
          },
          "installation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "artifact_digest", "durable_root", "evidence"],
            "properties": {
              "state": {"enum": ["INSTALLED_DIGEST_VERIFIED_ACTIVATION_SCOPED", "INSTALLED_FILE_SET_VERIFIED_ACTIVATION_PENDING", "STORAGE_INSTALL_ADMITTED_EXECUTION_PENDING", "UPSTREAM_IDENTITY_VERIFIED_NOT_INSTALLED", "EXTERNAL_CONSUMER_ONLY_NOT_INSTALLABLE"]},
              "artifact_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
              "durable_root": {"type": ["string", "null"]},
              "evidence": {"type": "string", "minLength": 1}
            }
          },
          "installation_receipt": {
            "type": "object",
            "additionalProperties": false,
            "required": ["remote_path", "sha256", "file_count", "total_bytes", "replay"],
            "properties": {
              "remote_path": {"type": "string", "pattern": "^/workspace/"},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "file_count": {"type": "integer", "minimum": 1},
              "total_bytes": {"type": "integer", "minimum": 1},
              "replay": {"const": "REUSED_VERIFIED_INSTALL"}
            }
          },
          "dependency_preflight": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "evidence", "receipt_sha256", "gaps"],
            "properties": {
              "state": {"const": "CONFIG_IDENTITY_PASS_DEPENDENCY_ACTION_REQUIRED"},
              "evidence": {"type": "string", "minLength": 1},
              "receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "gaps": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "enum": [
                    "QWEN_ASR_DISTRIBUTION_MISSING",
                    "QWEN_OMNI_UTILS_DISTRIBUTION_MISSING",
                    "TRANSFORMERS_DISTRIBUTION_MISSING",
                    "INSTALLED_TRANSFORMERS_LACKS_QWEN3_ASR_SUPPORT",
                    "INSTALLED_TRANSFORMERS_LACKS_QWEN3_OMNI_SUPPORT"
                  ]
                }
              }
            }
          },
          "dependency_environment": {
            "type": "object",
            "additionalProperties": true,
            "required": ["state", "root", "receipt_sha256", "tree_sha256", "distribution_count", "evidence"],
            "properties": {
              "state": {"enum": ["INSTALLED_METADATA_VERIFIED_IMPORT_PENDING", "INSTALLED_IMPORT_VERIFIED_RUNTIME_PENDING"]},
              "root": {"type": "string", "pattern": "^/workspace/w64_aqa/environments/"},
              "receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "tree_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "distribution_count": {"type": "integer", "minimum": 1},
              "evidence": {"type": "string", "minLength": 1}
            }
          },
          "source_pin": {
            "type": "object",
            "additionalProperties": true,
            "required": ["revision", "verified_at_utc"],
            "properties": {
              "revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
              "verified_at_utc": {"type": "string", "format": "date-time"},
              "admission_manifest": {"type": "string", "minLength": 1}
            }
          },
          "qualification": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "required_gates"],
            "properties": {
              "state": {"type": "string", "minLength": 1},
              "required_gates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
            }
          },
          "install_admission": {"type": "object", "minProperties": 1},
          "import_canary": {"type": "object", "minProperties": 1},
          "static_qualification": {"type": "object", "minProperties": 1},
          "runtime_canary": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "control_commit", "script_sha256", "receipt_sha256", "evidence", "audio_sha256", "transcript", "language", "load_seconds", "inference_seconds", "peak_used_mib", "process_exit_cleanup_delta_mib", "coordinator_lease_mode"],
            "properties": {
              "state": {"const": "EXACT_FIXTURE_TRANSCRIPTION_AND_PROCESS_EXIT_CLEANUP_PASS"},
              "control_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
              "script_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "evidence": {"type": "string", "minLength": 1},
              "audio_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "transcript": {"type": "string", "minLength": 1},
              "language": {"type": "string", "minLength": 1},
              "load_seconds": {"type": "number", "exclusiveMinimum": 0},
              "inference_seconds": {"type": "number", "exclusiveMinimum": 0},
              "peak_used_mib": {"type": "integer", "minimum": 1},
              "process_exit_cleanup_delta_mib": {"type": "integer", "maximum": 1024},
              "coordinator_lease_mode": {"const": "exclusive"}
            }
          },
          "authority": {
            "type": "object",
            "additionalProperties": false,
            "required": ["operational", "allowed_scope", "forbidden"],
            "properties": {
              "operational": {"type": "boolean"},
              "allowed_scope": {"type": "string"},
              "forbidden": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
            }
          }
        }
      }
    }
  }
}
