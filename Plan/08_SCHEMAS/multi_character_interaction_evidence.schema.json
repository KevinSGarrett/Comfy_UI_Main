{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave25 MultiCharacterInteractionEvidence",
  "type": "object",
  "required": [
    "evidence_version",
    "event_id",
    "checks"
  ],
  "properties": {
    "evidence_version": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "checks": {
      "type": "object"
    },
    "score": {
      "type": "number"
    },
    "pass": {
      "type": "boolean"
    }
  }
}
