{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Wave15 Base Generation Lane",
  "required": [
    "lane_id",
    "engine_family",
    "role",
    "status",
    "promotion_state"
  ],
  "properties": {
    "lane_id": {
      "type": "string"
    },
    "engine_family": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "default_priority": {
      "type": "integer"
    },
    "allowed_lora_families": {
      "type": "array"
    },
    "forbidden_lora_families": {
      "type": "array"
    },
    "promotion_state": {
      "type": "string"
    }
  }
}
