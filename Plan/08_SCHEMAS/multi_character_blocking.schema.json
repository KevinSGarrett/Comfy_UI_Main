  "title": "Wave11 Multi Character Blocking",
  "type": "object",
  "required": [
    "scene_id",
    "characters",
    "depth_layers",
    "occlusion_masks"
  ],
  "properties": {
    "scene_id": {
      "type": "string"
    },
    "characters": {
      "type": "array"
    },
    "depth_layers": {
      "type": "array"
    },
    "occlusion_masks": {
      "type": "array"
    },
    "identity_bleed_policy": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
