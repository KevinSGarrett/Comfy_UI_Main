{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/audio_pack_functional_index_record.schema.json",
  "title": "Audio Pack Functional Index Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "relative_path",
    "absolute_path",
    "sha256",
    "bytes",
    "extension",
    "duration_seconds",
    "format",
    "sample_rate_hz",
    "channels",
    "event_type",
    "material",
    "role",
    "intensity_band",
    "duration_band",
    "attack_characteristic",
    "sync_class",
    "room_environment_suitability",
    "loopability",
    "quality_defects",
    "license_classification",
    "attribution",
    "content_based_suppression"
  ],
  "properties": {
    "relative_path": {"type": "string", "minLength": 1},
    "absolute_path": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "bytes": {"type": "integer", "minimum": 1},
    "extension": {"type": "string", "enum": [".wav", ".mp3", ".flac", ".ogg"]},
    "duration_seconds": {"type": ["number", "null"], "minimum": 0},
    "format": {"type": "string", "minLength": 1},
    "sample_rate_hz": {"type": ["integer", "null"], "minimum": 1},
    "channels": {"type": ["integer", "null"], "minimum": 1},
    "event_type": {
      "type": "string",
      "enum": ["dialogue", "voice_reaction", "breath", "body_foley", "clothing_foley", "prop_foley", "furniture_foley", "ambience", "room_tone", "music", "impact", "action_sfx", "transition_sfx", "evaluation_reference", "unclassified"]
    },
    "material": {"type": "string", "minLength": 1},
    "role": {"type": "string", "minLength": 1},
    "intensity_band": {"type": "string", "enum": ["silent", "very_low", "low", "medium", "high", "blocked_extreme", "unknown"]},
    "duration_band": {"type": "string", "enum": ["instant", "short", "medium", "sustained", "unknown"]},
    "attack_characteristic": {"type": "string", "enum": ["sharp_transient", "soft_transient", "gradual", "sustained", "unknown"]},
    "sync_class": {"type": "string", "enum": ["frame_exact", "windowed", "ambient_free", "music_scene_phase", "evaluation_only"]},
    "room_environment_suitability": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
    "loopability": {"type": "string", "enum": ["declared_loop", "candidate", "not_indicated"]},
    "quality_defects": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "license_classification": {"type": "string", "minLength": 1},
    "attribution": {"type": "string", "minLength": 1},
    "content_based_suppression": {"const": false}
  }
}
