{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/model-compatibility-edge/1.0.0",
  "title": "Wave64 Model Compatibility Edge",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "compatibility_edge_id",
    "revision",
    "status",
    "created_at",
    "source_component",
    "target_component",
    "relation",
    "scope",
    "evidence",
    "authority",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "model_compatibility_edge"
    },
    "compatibility_edge_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "source_component": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
    },
    "target_component": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
    },
    "relation": {
      "enum": [
        "compatible",
        "incompatible",
        "conditional",
        "unknown"
      ]
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/CapabilityScope"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/EvidenceRef"
      }
    },
    "authority": {
      "enum": [
        "metadata_hypothesis",
        "static_proven",
        "runtime_proven",
        "certified"
      ]
    }
  },
  "additionalProperties": false
}
