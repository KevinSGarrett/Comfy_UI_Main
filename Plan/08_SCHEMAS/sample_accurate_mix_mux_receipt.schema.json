{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/sample_accurate_mix_mux_receipt.schema.json",
  "title": "Wave64 Row097 Sample-Accurate Mix Mux Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tracker_id",
    "item_id",
    "record_type",
    "engine_revision",
    "policy_revision",
    "policy_sha256",
    "timeline_id",
    "video_timeline_sha256",
    "expected_stems",
    "is_synthetic",
    "library_authority",
    "dependency_admissions",
    "required_gates",
    "gate_results",
    "stems",
    "exclusions",
    "mix_recipe",
    "mux",
    "decision",
    "receipt_sha256"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "tracker_id": { "type": "string", "const": "TRK-W64-097" },
    "item_id": { "type": "string", "const": "ITEM-W64-097" },
    "record_type": {
      "type": "string",
      "const": "sample_accurate_mix_mux_receipt"
    },
    "engine_revision": {
      "type": "string",
      "const": "wave64_row097_sample_accurate_mix_mux_engine_v0.1.0"
    },
    "policy_revision": {
      "type": "string",
      "const": "wave64_row097_sample_accurate_mix_mux_v0.1.0"
    },
    "policy_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timeline_id": { "type": "string", "minLength": 1 },
    "video_timeline_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "expected_stems": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stem_bus" },
      "uniqueItems": true
    },
    "is_synthetic": { "type": "boolean" },
    "library_authority": { "type": "boolean", "const": false },
    "dependency_admissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "TRK-W64-091",
        "TRK-W64-093",
        "TRK-W64-094",
        "TRK-W64-095",
        "TRK-W64-096"
      ],
      "properties": {
        "TRK-W64-091": { "$ref": "#/$defs/dependency_admission" },
        "TRK-W64-093": { "$ref": "#/$defs/dependency_admission" },
        "TRK-W64-094": { "$ref": "#/$defs/dependency_admission" },
        "TRK-W64-095": { "$ref": "#/$defs/dependency_admission" },
        "TRK-W64-096": { "$ref": "#/$defs/dependency_admission" }
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "string",
        "enum": [
          "sample_schedule",
          "bus_processing",
          "loudness",
          "true_peak",
          "stem_manifest",
          "mux_lineage"
        ]
      }
    },
    "gate_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_schedule",
        "bus_processing",
        "loudness",
        "true_peak",
        "stem_manifest",
        "mux_lineage"
      ],
      "properties": {
        "sample_schedule": { "$ref": "#/$defs/gate_result" },
        "bus_processing": { "$ref": "#/$defs/gate_result" },
        "loudness": { "$ref": "#/$defs/gate_result" },
        "true_peak": { "$ref": "#/$defs/gate_result" },
        "stem_manifest": { "$ref": "#/$defs/gate_result" },
        "mux_lineage": { "$ref": "#/$defs/gate_result" }
      }
    },
    "stems": {
      "type": "array",
      "items": { "$ref": "#/$defs/stem_record" }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stem_bus", "reason_codes"],
        "properties": {
          "stem_bus": { "type": "string", "minLength": 1 },
          "reason_codes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "mix_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_rate_hz",
        "channels",
        "target_lufs",
        "true_peak_ceiling_dbtp",
        "minimum_headroom_db",
        "ordered_stem_buses",
        "measured_lufs",
        "measured_true_peak_dbtp",
        "recipe_sha256"
      ],
      "properties": {
        "sample_rate_hz": { "type": "integer", "minimum": 8000 },
        "channels": { "type": "integer", "minimum": 1, "maximum": 8 },
        "target_lufs": { "type": "number" },
        "true_peak_ceiling_dbtp": { "type": "number" },
        "minimum_headroom_db": { "type": "number", "minimum": 0 },
        "ordered_stem_buses": {
          "type": "array",
          "items": { "$ref": "#/$defs/stem_bus" }
        },
        "measured_lufs": { "type": ["number", "null"] },
        "measured_true_peak_dbtp": { "type": ["number", "null"] },
        "recipe_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "mux": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "video_frame_count",
        "audio_sample_count",
        "endpoint_drift_samples",
        "stem_manifest_sha256",
        "mix_pcm_sha256",
        "mux_container_sha256",
        "mux_lineage_sha256",
        "reconstructable"
      ],
      "properties": {
        "video_frame_count": { "type": "integer", "minimum": 1 },
        "audio_sample_count": { "type": "integer", "minimum": 1 },
        "endpoint_drift_samples": { "type": "integer" },
        "stem_manifest_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "mix_pcm_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "mux_container_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "mux_lineage_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "reconstructable": { "type": "boolean" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "status",
        "blocker_codes",
        "product_completion",
        "row097_acceptance",
        "reason"
      ],
      "properties": {
        "route": {
          "type": "string",
          "enum": ["mix_mux", "blocked"]
        },
        "status": {
          "type": "string",
          "enum": ["mixed", "blocked"]
        },
        "blocker_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "product_completion": { "type": "boolean", "const": false },
        "row097_acceptance": {
          "type": "string",
          "enum": ["held", "fixture_only"]
        },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "receipt_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "$defs": {
    "stem_bus": {
      "type": "string",
      "enum": [
        "dialogue",
        "foley",
        "ambience",
        "music",
        "room",
        "master"
      ]
    },
    "dependency_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tracker_id",
        "dependency_satisfied",
        "blocker_codes",
        "row_complete",
        "path"
      ],
      "properties": {
        "tracker_id": { "type": "string", "minLength": 1 },
        "dependency_satisfied": { "type": "boolean" },
        "blocker_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "row_complete": { "type": "boolean" },
        "status": { "type": "string" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "gate_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason_codes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "skipped"]
        },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stem_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stem_bus",
        "asset_id",
        "source_pcm_sha256",
        "stem_pcm_sha256",
        "start_sample",
        "end_sample",
        "gain_db",
        "bus_gain_db",
        "admitted"
      ],
      "properties": {
        "stem_bus": { "$ref": "#/$defs/stem_bus" },
        "asset_id": { "type": "string", "minLength": 1 },
        "source_pcm_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "stem_pcm_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "start_sample": { "type": "integer", "minimum": 0 },
        "end_sample": { "type": "integer", "minimum": 1 },
        "gain_db": { "type": "number" },
        "bus_gain_db": { "type": "number" },
        "admitted": { "type": "boolean" }
      }
    }
  }
}
