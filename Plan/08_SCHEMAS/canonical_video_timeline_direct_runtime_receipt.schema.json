{
  "$id": "https://comfy-ui-main.local/schemas/row084-direct-runtime-receipt/1.0.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "authority": {
      "additionalProperties": true,
      "properties": {
        "direct_row084_runtime_receipt_present": {
          "const": true
        },
        "visual_review_authority_granted": {
          "type": "boolean"
        }
      },
      "required": [
        "direct_row084_runtime_receipt_present",
        "visual_review_authority_granted"
      ],
      "type": "object"
    },
    "proof_tier": {
      "enum": [
        "RUNTIME_PASS_BOUNDED",
        "VISUAL_QA_PASS_BOUNDED"
      ]
    },
    "receipt_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "record_type": {
      "const": "row084_direct_runtime_receipt"
    },
    "row_complete": {
      "const": false
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "status": {
      "const": "direct_row084_runtime_receipt_pass_bounded"
    }
  },
  "required": [
    "schema_version",
    "record_type",
    "status",
    "proof_tier",
    "bindings",
    "summary",
    "authority",
    "row_complete",
    "receipt_sha256"
  ],
  "title": "row084_direct_runtime_receipt",
  "type": "object"
}
