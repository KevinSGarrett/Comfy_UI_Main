{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-video-keyframe-authority/1.0.0",
  "title": "Hyperreal Video Keyframe Authority",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "video_keyframe_authority_id",
    "revision",
    "status",
    "created_at",
    "scope",
    "frame_index",
    "pts",
    "image_artifact",
    "character_instance_ids",
    "identity_refs",
    "pose_ref",
    "depth_ref",
    "mask_binding_refs",
    "camera_ref",
    "lighting_state_ref",
    "surface_state_refs",
    "authority_tier",
    "certificate_ref",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_video_keyframe_authority"
    },
    "video_keyframe_authority_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "scope": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ExecutionScope"
    },
    "frame_index": {
      "type": "integer",
      "minimum": 0
    },
    "pts": {
      "type": "integer",
      "minimum": 0
    },
    "image_artifact": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ArtifactRef"
    },
    "character_instance_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "identity_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "pose_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "depth_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "mask_binding_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "camera_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "lighting_state_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "surface_state_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "authority_tier": {
      "enum": [
        "draft",
        "approved_keyframe",
        "locked_boundary"
      ]
    },
    "certificate_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "authority_tier": {
            "enum": [
              "approved_keyframe",
              "locked_boundary"
            ]
          }
        },
        "required": [
          "authority_tier"
        ]
      },
      "then": {
        "properties": {
          "certificate_ref": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
          }
        }
      }
    }
  ]
}
