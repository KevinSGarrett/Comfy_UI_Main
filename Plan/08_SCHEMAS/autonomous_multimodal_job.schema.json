{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/autonomous-multimodal-job/1.0.0",
  "title": "Wave64 Autonomous Multimodal Job",
  "type": "object",
  "required": ["schema_version", "autonomous_multimodal_job_id", "revision", "request_id", "idempotency_key", "job_state", "requested_outputs", "character_package_ids", "scene_package_ids", "shot_take_index", "pass_dag_ids", "orchestration_policy", "resource_budget", "retry_budget", "qa_policy", "mask_authority_policy", "event_stream_head", "lease_and_cancellation", "accepted_artifact_ids", "terminal_output_ids", "blockers", "completion_contract", "created_at", "provenance"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "autonomous_multimodal_job_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "string" },
    "request_id": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "job_state": { "enum": ["created", "proposed", "validated", "ready", "submitted", "running", "qa_pending", "repair_pending", "blocked", "cancelled", "failed", "completed", "promoted", "rolled_back"] },
    "requested_outputs": { "type": "array", "items": { "type": "object", "required": ["output_id", "modality", "required"], "properties": { "output_id":{"type":"string"}, "modality":{"enum":["image","video","audio","av"]}, "required":{"type":"boolean"}, "acceptance_contract_id":{"type":"string"} }, "additionalProperties":false }, "minItems":1 },
    "character_package_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "scene_package_ids": { "type": "array", "items": { "type": "string" }, "minItems":1, "uniqueItems":true },
    "shot_take_index": { "type": "array", "items": { "type": "object", "required": ["scene_id", "shot_id", "take_id", "scene_package_id", "shot_pose_package_id", "dag_id", "status"], "properties": { "scene_id":{"type":"string"}, "shot_id":{"type":"string"}, "take_id":{"type":"string"}, "scene_package_id":{"type":"string"}, "shot_pose_package_id":{"type":"string"}, "dag_id":{"type":"string"}, "status":{"enum":["planned","ready","running","blocked","failed","completed","cancelled"]} }, "additionalProperties":false } },
    "pass_dag_ids": { "type": "array", "items": { "type": "string" }, "minItems":1, "uniqueItems":true },
    "orchestration_policy": { "type": "object", "required": ["planner_role_id", "validator_policy_id", "router_policy_id", "promotion_policy_id", "no_silent_substitution"], "properties": { "planner_role_id":{"type":"string"}, "validator_policy_id":{"type":"string"}, "router_policy_id":{"type":"string"}, "promotion_policy_id":{"type":"string"}, "no_silent_substitution":{"$ref":"https://comfy-ui-main.local/schemas/multimodal-contract-common/1.0.0#/$defs/NoSilentSubstitutionContract"} }, "additionalProperties":false },
    "resource_budget": { "$ref": "https://comfy-ui-main.local/schemas/multimodal-contract-common/1.0.0#/$defs/ResourceContract" },
    "retry_budget": { "$ref": "https://comfy-ui-main.local/schemas/multimodal-contract-common/1.0.0#/$defs/RetryContract" },
    "qa_policy": { "$ref": "https://comfy-ui-main.local/schemas/multimodal-contract-common/1.0.0#/$defs/QAContract" },
    "mask_authority_policy": { "type": "object", "required": ["allowed_truth_tiers", "mode_b_promotion_forbidden", "writes_gold"], "properties": { "allowed_truth_tiers":{"type":"array","items":{"type":"string"}}, "mode_b_promotion_forbidden":{"const":true}, "writes_gold":{"const":false} }, "additionalProperties":false },
    "event_stream_head": { "type": "object", "required": ["event_id", "sequence_number", "sha256"], "properties": { "event_id":{"type":["string","null"]}, "sequence_number":{"type":"integer","minimum":0}, "sha256":{"type":["string","null"],"pattern":"^[0-9a-f]{64}$"} }, "additionalProperties":false },
    "lease_and_cancellation": { "type": "object", "required": ["lease_owner", "lease_expires_at", "cancellation_requested"], "properties": { "lease_owner":{"type":["string","null"]}, "lease_expires_at":{"type":["string","null"],"format":"date-time"}, "cancellation_requested":{"type":"boolean"} }, "additionalProperties":false },
    "accepted_artifact_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems":true },
    "terminal_output_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems":true },
    "blockers": { "type": "array", "items": { "type": "object", "required": ["blocker_id", "blocker_type", "required"], "properties": { "blocker_id":{"type":"string"}, "blocker_type":{"type":"string"}, "required":{"type":"boolean"}, "details":{"type":"string"} }, "additionalProperties":false } },
    "completion_contract": { "type": "object", "required": ["all_required_outputs_accepted", "all_required_passes_resolved", "all_blocking_qa_passed", "no_required_blockers"], "properties": { "all_required_outputs_accepted":{"type":"boolean"}, "all_required_passes_resolved":{"type":"boolean"}, "all_blocking_qa_passed":{"type":"boolean"}, "no_required_blockers":{"type":"boolean"} }, "additionalProperties":false },
    "created_at": { "type": "string", "format": "date-time" },
    "provenance": { "$ref": "https://comfy-ui-main.local/schemas/multimodal-contract-common/1.0.0#/$defs/Provenance" }
  },
  "additionalProperties": false
}
