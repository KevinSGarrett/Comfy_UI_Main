{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-decoded-video-bridge-qualification/1.0.0",
  "title": "Hyperreal Decoded Video Bridge Qualification",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "decoded_video_bridge_qualification_id",
    "revision",
    "status",
    "created_at",
    "source_bundle_ref",
    "target_bundle_ref",
    "source_workflow_ref",
    "target_workflow_ref",
    "source_pixel_format",
    "target_pixel_format",
    "source_color_space",
    "target_color_space",
    "orientation_policy_id",
    "alpha_policy_id",
    "timebase_policy_id",
    "transform_chain_ref",
    "reintegration_policy_id",
    "roundtrip_metric_results",
    "supported_pass_intents",
    "certificate_ref",
    "execution_allowed",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_decoded_video_bridge_qualification"
    },
    "decoded_video_bridge_qualification_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "source_bundle_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "target_bundle_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "source_workflow_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "target_workflow_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "source_pixel_format": {
      "type": "string",
      "minLength": 1
    },
    "target_pixel_format": {
      "type": "string",
      "minLength": 1
    },
    "source_color_space": {
      "type": "string",
      "minLength": 1
    },
    "target_color_space": {
      "type": "string",
      "minLength": 1
    },
    "orientation_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "alpha_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "timebase_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "transform_chain_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "reintegration_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "roundtrip_metric_results": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/MetricResult"
      },
      "minItems": 1
    },
    "supported_pass_intents": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "certificate_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "execution_allowed": {
      "type": "boolean"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_allowed": {
            "const": true
          }
        },
        "required": [
          "execution_allowed"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "certified"
          },
          "certificate_ref": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
          }
        }
      }
    }
  ]
}
