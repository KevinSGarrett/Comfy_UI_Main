{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-operator-project/1.0.0",
  "title": "Hyperreal Operator Application Project",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "operator_project_id",
    "revision",
    "status",
    "created_at",
    "project_id",
    "title",
    "mode",
    "character_refs",
    "scene_refs",
    "shot_timeline_refs",
    "run_refs",
    "active_revision",
    "autosave_enabled",
    "raw_paths_exposed",
    "credentials_exposed",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_operator_project"
    },
    "operator_project_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "guided",
        "director",
        "expert",
        "diagnostic"
      ]
    },
    "character_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 0
    },
    "scene_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 0
    },
    "shot_timeline_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 0
    },
    "run_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 0
    },
    "active_revision": {
      "type": "integer",
      "minimum": 0
    },
    "autosave_enabled": {
      "type": "boolean"
    },
    "raw_paths_exposed": {
      "const": false
    },
    "credentials_exposed": {
      "const": false
    }
  },
  "additionalProperties": false
}
