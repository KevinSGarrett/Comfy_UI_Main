{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-application-release-manifest/1.0.0",
  "title": "Hyperreal Operator Application Release Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "application_release_manifest_id",
    "revision",
    "status",
    "created_at",
    "application_version",
    "controller_api_revision",
    "schema_catalog_ref",
    "navigation_manifest_ref",
    "command_authority_registry_ref",
    "comfyui_frontend_min_version",
    "comfyui_core_min_version",
    "release_tier",
    "surface_releases",
    "contract_test_refs",
    "component_test_refs",
    "e2e_test_refs",
    "accessibility_evidence_refs",
    "visual_regression_refs",
    "fault_injection_refs",
    "performance_evidence_refs",
    "release_decision_ref",
    "runtime_completion_claimed",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_application_release_manifest"
    },
    "application_release_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "application_version": {
      "type": "string",
      "minLength": 1
    },
    "controller_api_revision": {
      "type": "string",
      "minLength": 1
    },
    "schema_catalog_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "navigation_manifest_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "command_authority_registry_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "comfyui_frontend_min_version": {
      "type": "string",
      "minLength": 1
    },
    "comfyui_core_min_version": {
      "type": "string",
      "minLength": 1
    },
    "release_tier": {
      "enum": [
        "controller_core",
        "controller_plus_app_mode",
        "full_hybrid"
      ]
    },
    "surface_releases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "surface",
          "release_ref",
          "required_for_tier",
          "test_evidence_refs"
        ],
        "properties": {
          "surface": {
            "enum": [
              "controller_console",
              "comfyui_app_mode",
              "comfyui_frontend_extension"
            ]
          },
          "release_ref": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
          },
          "required_for_tier": {
            "type": "boolean"
          },
          "test_evidence_refs": {
            "type": "array",
            "items": {
              "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
            },
            "minItems": 1
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "contract_test_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "component_test_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "e2e_test_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "accessibility_evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "visual_regression_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "fault_injection_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "performance_evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "release_decision_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "runtime_completion_claimed": {
      "type": "boolean"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "runtime_completion_claimed": {
            "const": true
          }
        },
        "required": [
          "runtime_completion_claimed"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "certified"
          }
        }
      }
    }
  ]
}
