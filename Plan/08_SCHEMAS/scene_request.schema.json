{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ultra Hyperrealism Scene Request",
  "type": "object",
  "required": [
    "scene_id",
    "output_mode",
    "characters"
  ],
  "properties": {
    "scene_id": {
      "type": "string"
    },
    "output_mode": {
      "enum": [
        "still",
        "gif",
        "video",
        "audio",
        "full_av"
      ]
    },
    "prompt": {
      "type": "string"
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "character_id"
        ],
        "properties": {
          "character_id": {
            "type": "string"
          },
          "references": {
            "type": "object"
          },
          "locked_traits": {
            "type": "object"
          },
          "pose_target": {
            "type": "string"
          },
          "region": {
            "type": "object"
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "audio": {
      "type": "object"
    },
    "video": {
      "type": "object"
    },
    "qa_strictness": {
      "enum": [
        "draft",
        "normal",
        "strict",
        "release"
      ]
    }
  }
}
