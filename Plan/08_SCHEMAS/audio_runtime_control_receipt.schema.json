{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/audio_runtime_control_receipt.schema.json",
  "title": "Wave64 Row108 Audio Runtime Control Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "tracker_id", "item_id", "record_type", "policy_revision",
    "batch_id", "provider", "pod_id", "is_synthetic", "cache_entries",
    "items", "transfer_manifest", "budget", "lease", "ttl",
    "decision", "receipt_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "tracker_id": {"const": "TRK-W64-108"},
    "item_id": {"const": "ITEM-W64-108"},
    "record_type": {"const": "audio_runtime_control_receipt"},
    "policy_revision": {"type": "string", "minLength": 1},
    "batch_id": {"type": "string", "pattern": "^audio-batch-[a-f0-9]{24}$"},
    "provider": {"const": "runpod"},
    "pod_id": {"const": "1q4ji0gg1fkhvt"},
    "is_synthetic": {"type": "boolean"},
    "cache_entries": {"type": "array", "items": {"$ref": "#/$defs/cache"}},
    "items": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"$ref": "#/$defs/item"}},
    "transfer_manifest": {"type": "array", "items": {"$ref": "#/$defs/transfer"}},
    "budget": {
      "type": "object", "additionalProperties": false,
      "required": ["currency", "maximum_usd", "estimated_usd", "actual_usd"],
      "properties": {
        "currency": {"const": "USD"}, "maximum_usd": {"type": "number", "minimum": 0},
        "estimated_usd": {"type": "number", "minimum": 0},
        "actual_usd": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "lease": {
      "type": "object", "additionalProperties": false,
      "required": ["required", "validated", "lease_id", "project", "profile", "expires_at"],
      "properties": {
        "required": {"const": true}, "validated": {"type": "boolean"},
        "lease_id": {"type": ["string", "null"]}, "project": {"type": ["string", "null"]},
        "profile": {"type": ["string", "null"]}, "expires_at": {"type": ["string", "null"]}
      }
    },
    "ttl": {
      "type": "object", "additionalProperties": false,
      "required": ["deadline", "watchdog_armed", "final_release_verified"],
      "properties": {
        "deadline": {"type": ["string", "null"]}, "watchdog_armed": {"type": "boolean"},
        "final_release_verified": {"type": "boolean"}
      }
    },
    "decision": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "runtime_allowed", "runtime_completion", "row108_acceptance", "blocker_codes"],
      "properties": {
        "status": {"enum": ["ready", "blocked", "failed", "complete"]},
        "runtime_allowed": {"type": "boolean"}, "runtime_completion": {"type": "boolean"},
        "row108_acceptance": {"enum": ["fixture_only", "held", "accepted"]},
        "blocker_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "receipt_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "cache": {
      "type": "object", "additionalProperties": false,
      "required": ["cache_key", "identity", "output_sha256", "state"],
      "properties": {
        "cache_key": {"$ref": "#/$defs/sha256"}, "identity": {"type": "object"},
        "output_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "state": {"enum": ["miss", "hit", "invalidated"]}
      }
    },
    "item": {
      "type": "object", "additionalProperties": false,
      "required": ["item_id", "input_sha256", "estimated_peak_vram_gib", "estimated_cost_usd", "state", "attempts", "output_sha256"],
      "properties": {
        "item_id": {"type": "string"}, "input_sha256": {"$ref": "#/$defs/sha256"},
        "estimated_peak_vram_gib": {"type": "number", "minimum": 0},
        "estimated_cost_usd": {"type": "number", "minimum": 0},
        "state": {"enum": ["pending", "passed", "failed", "reused"]},
        "attempts": {"type": "integer", "minimum": 0, "maximum": 2},
        "output_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "transfer": {
      "type": "object", "additionalProperties": false,
      "required": ["source_sha256", "bytes", "destination", "verified"],
      "properties": {
        "source_sha256": {"$ref": "#/$defs/sha256"}, "bytes": {"type": "integer", "minimum": 0},
        "destination": {"type": "string", "minLength": 1}, "verified": {"type": "boolean"}
      }
    }
  }
}
