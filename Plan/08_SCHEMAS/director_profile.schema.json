{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "director_profile.schema.json",
  "title": "Wave07 Director Profile",
  "type": "object",
  "required": [
    "profile_id",
    "name",
    "primary_output",
    "default_engine_priority",
    "default_pass_sequence",
    "strict_rules"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "primary_output": {
      "type": "string"
    },
    "default_engine_priority": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "default_pass_sequence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strict_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
