{
  "$id": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/maskfactory_operational_certificate_v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "fixture_only": {
            "const": true
          }
        },
        "required": [
          "fixture_only"
        ]
      },
      "then": {
        "properties": {
          "certification_context": {
            "const": "fixture_validation"
          },
          "genuine_runtime_evidence_refs": {
            "maxItems": 0
          },
          "runtime_completion_claimed": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "certification_context": {
            "const": "production_runtime"
          }
        },
        "required": [
          "certification_context"
        ]
      },
      "then": {
        "properties": {
          "fixture_only": {
            "const": false
          },
          "genuine_runtime_evidence_refs": {
            "minItems": 1
          },
          "runtime_completion_claimed": {
            "const": false
          },
          "signature_algorithm": {
            "const": "ed25519"
          },
          "signature_trust": {
            "properties": {
              "trust_result": {
                "const": "trusted"
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "access_mode": {
      "enum": [
        "mode_a_package_read",
        "mode_b_live_predict",
        "mode_b_live_refine"
      ]
    },
    "capability_id": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "certificate_hash_profile": {
      "const": "main_domain_separated_sorted_utf8_json_v2_excluding_certificate_hash_signature_and_signature_trust"
    },
    "certificate_payload_sha256": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/sha256"
    },
    "certificate_scope": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "certification_context": {
      "enum": [
        "fixture_validation",
        "production_runtime"
      ]
    },
    "claim_class": {
      "const": "operationally_certified_artifact"
    },
    "created_at": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/timestamp"
    },
    "evidence_manifest_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "minItems": 1,
      "type": "array"
    },
    "execution_stack_ref": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
    },
    "expires_at": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/timestamp"
    },
    "fixture_only": {
      "type": "boolean"
    },
    "genuine_runtime_evidence_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "type": "array",
      "uniqueItems": true
    },
    "issued_at": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/timestamp"
    },
    "issuer_id": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "issuer_kind": {
      "enum": [
        "maskfactory_autonomous",
        "human_anchor_optional"
      ]
    },
    "maskfactory_operational_certificate_v2_id": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "media_scope": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/media_scope"
    },
    "output_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "minItems": 1,
      "type": "array"
    },
    "owner_bindings": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/owner_binding"
      },
      "minItems": 1,
      "type": "array"
    },
    "promotion_gate_policy_ref": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
    },
    "qa_bindings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "gate_id": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
          },
          "qa_record_ref": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
          },
          "result": {
            "const": "pass"
          }
        },
        "required": [
          "qa_record_ref",
          "gate_id",
          "result"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "raw_producer_certificate_payload_sha256": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/sha256"
    },
    "raw_producer_certificate_ref": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
    },
    "raw_producer_certificate_signature": {
      "minLength": 16,
      "type": "string"
    },
    "raw_producer_certificate_signature_domain": {
      "const": "maskfactory.sha256_digest_bytes.v1"
    },
    "raw_producer_certificate_signature_trust": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/signing_trust_verification"
    },
    "record_type": {
      "const": "maskfactory_operational_certificate_v2"
    },
    "release_snapshot_ref": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
    },
    "revision": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "revocation_manifest_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "minItems": 1,
      "type": "array"
    },
    "revocation_ref": {
      "oneOf": [
        {
          "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
        },
        {
          "type": "null"
        }
      ]
    },
    "runtime_completion_claimed": {
      "const": false
    },
    "runtime_provenance": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/runtime_provenance"
    },
    "schema_version": {
      "const": "2.0.0"
    },
    "serving_route_id": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "signature": {
      "minLength": 16,
      "type": "string"
    },
    "signature_algorithm": {
      "enum": [
        "ed25519",
        "ecdsa_p256_sha256",
        "local_hash_attestation"
      ]
    },
    "signature_domain": {
      "const": "comfy_ui_main.maskfactory_operational_certificate.v2"
    },
    "signature_trust": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/signing_trust_verification"
    },
    "source_artifact": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/source_artifact"
    },
    "status": {
      "enum": [
        "active",
        "expired",
        "revoked"
      ]
    },
    "transform_chain": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/transform_chain"
    }
  },
  "required": [
    "schema_version",
    "record_type",
    "maskfactory_operational_certificate_v2_id",
    "revision",
    "created_at",
    "fixture_only",
    "runtime_completion_claimed",
    "certification_context",
    "claim_class",
    "status",
    "issuer_kind",
    "issuer_id",
    "signature_algorithm",
    "raw_producer_certificate_ref",
    "raw_producer_certificate_payload_sha256",
    "raw_producer_certificate_signature_domain",
    "raw_producer_certificate_signature",
    "raw_producer_certificate_signature_trust",
    "certificate_hash_profile",
    "certificate_payload_sha256",
    "signature_domain",
    "signature",
    "signature_trust",
    "issued_at",
    "expires_at",
    "release_snapshot_ref",
    "capability_id",
    "serving_route_id",
    "access_mode",
    "execution_stack_ref",
    "runtime_provenance",
    "source_artifact",
    "media_scope",
    "output_refs",
    "owner_bindings",
    "transform_chain",
    "qa_bindings",
    "promotion_gate_policy_ref",
    "evidence_manifest_refs",
    "genuine_runtime_evidence_refs",
    "certificate_scope",
    "revocation_manifest_refs",
    "revocation_ref"
  ],
  "title": "maskfactory_operational_certificate_v2",
  "type": "object"
}
