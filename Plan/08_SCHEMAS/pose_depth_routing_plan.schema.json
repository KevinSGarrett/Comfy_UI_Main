    "engine_family",
    "control_routes"
  ],
  "properties": {
    "routing_id": {
      "type": "string"
    },
    "engine_family": {
      "type": "string"
    },
    "control_routes": {
      "type": "array"
    },
    "fallback_policy": {
      "type": "string"
    },
    "runtime_proof_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
