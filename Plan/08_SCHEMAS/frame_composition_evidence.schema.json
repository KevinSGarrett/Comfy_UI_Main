{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave12 Frame Composition Evidence",
  "type": "object",
  "required": [
    "evidence_id",
    "image_path",
    "expected_character_count",
    "detected_person_instances",
    "body_visibility_by_character",
    "crop_boundary_report",
    "merged_body_report"
  ],
  "properties": {
    "evidence_id": {
      "type": "string"
    },
    "image_path": {
      "type": "string"
    },
    "detected_person_instances": {
      "type": "array"
    },
    "detected_skeletons": {
      "type": "array"
    },
    "detected_faces": {
      "type": "array"
    },
    "body_visibility_by_character": {
      "type": "array"
    },
    "crop_boundary_report": {
      "type": "object"
    },
    "merged_body_report": {
      "type": "object"
    },
    "score": {
      "type": "number"
    }
  }
}
