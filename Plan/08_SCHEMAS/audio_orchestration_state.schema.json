{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/audio_orchestration_state.schema.json",
  "title": "Wave64 Row105 Audio Orchestration State",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tracker_id", "item_id", "record_type", "orchestrator_revision", "policy_revision", "policy_sha256", "run_id", "request_sha256", "is_synthetic", "dependency_admissions", "dag_sha256", "stages", "retry_budget", "cost_budget", "event_log", "decision", "receipt_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "tracker_id": {"const": "TRK-W64-105"},
    "item_id": {"const": "ITEM-W64-105"},
    "record_type": {"const": "audio_orchestration_state"},
    "orchestrator_revision": {"const": "wave64_row105_audio_orchestrator_v0.1.0"},
    "policy_revision": {"const": "wave64_row105_audio_orchestrator_policy_v0.1.0"},
    "policy_sha256": {"$ref": "#/$defs/sha256"},
    "run_id": {"type": "string", "pattern": "^audio-run-[a-f0-9]{24}$"},
    "request_sha256": {"$ref": "#/$defs/sha256"},
    "is_synthetic": {"type": "boolean"},
    "dependency_admissions": {"type": "object", "minProperties": 4, "additionalProperties": {"$ref": "#/$defs/dependency"}},
    "dag_sha256": {"$ref": "#/$defs/sha256"},
    "stages": {"type": "array", "minItems": 10, "items": {"$ref": "#/$defs/stage"}},
    "retry_budget": {
      "type": "object", "additionalProperties": false,
      "required": ["global_max_attempts", "global_used_attempts", "per_stage_max_attempts"],
      "properties": {
        "global_max_attempts": {"type": "integer", "minimum": 1},
        "global_used_attempts": {"type": "integer", "minimum": 0},
        "per_stage_max_attempts": {"type": "integer", "minimum": 1}
      }
    },
    "cost_budget": {
      "type": "object", "additionalProperties": false,
      "required": ["maximum_usd", "committed_usd", "currency"],
      "properties": {
        "maximum_usd": {"type": "number", "minimum": 0},
        "committed_usd": {"type": "number", "minimum": 0},
        "currency": {"const": "USD"}
      }
    },
    "event_log": {"type": "array", "items": {"$ref": "#/$defs/event"}},
    "decision": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "row105_acceptance", "runtime_completion", "publication_allowed", "blocker_codes"],
      "properties": {
        "status": {"enum": ["ready", "running", "blocked", "failed", "complete"]},
        "row105_acceptance": {"enum": ["fixture_only", "held", "accepted"]},
        "runtime_completion": {"type": "boolean"},
        "publication_allowed": {"type": "boolean"},
        "blocker_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "receipt_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "dependency": {
      "type": "object", "additionalProperties": false,
      "required": ["tracker_id", "evidence_path", "evidence_sha256", "row_complete", "dependency_satisfied", "blocker_codes"],
      "properties": {
        "tracker_id": {"type": "string", "pattern": "^TRK-W64-[0-9]{3}$"},
        "evidence_path": {"type": "string", "minLength": 1},
        "evidence_sha256": {"$ref": "#/$defs/sha256"},
        "row_complete": {"type": "boolean"},
        "dependency_satisfied": {"type": "boolean"},
        "blocker_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "stage": {
      "type": "object", "additionalProperties": false,
      "required": ["stage_id", "predecessors", "implementation_revision", "state", "attempts", "idempotency_key", "input_hashes", "output_sha256", "blocker_codes"],
      "properties": {
        "stage_id": {"type": "string", "minLength": 1},
        "predecessors": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "implementation_revision": {"type": "string", "minLength": 1},
        "state": {"enum": ["pending", "ready", "running", "pass", "reused", "blocked", "failed"]},
        "attempts": {"type": "integer", "minimum": 0},
        "idempotency_key": {"$ref": "#/$defs/sha256"},
        "input_hashes": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}},
        "output_sha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "blocker_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "event": {
      "type": "object", "additionalProperties": false,
      "required": ["sequence", "event_type", "stage_id", "payload_sha256", "previous_event_sha256", "event_sha256"],
      "properties": {
        "sequence": {"type": "integer", "minimum": 1},
        "event_type": {"enum": ["stage_passed", "stage_failed", "stage_retry_admitted"]},
        "stage_id": {"type": "string", "minLength": 1},
        "payload_sha256": {"$ref": "#/$defs/sha256"},
        "previous_event_sha256": {"$ref": "#/$defs/sha256"},
        "event_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
