{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-application-command-receipt/1.0.0",
  "title": "Hyperreal Application Command Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "application_command_receipt_id",
    "revision",
    "status",
    "created_at",
    "command_ref",
    "authorization_ref",
    "accepted_at",
    "result",
    "correlation_id",
    "aggregate_ref",
    "aggregate_version_before",
    "aggregate_version_after",
    "result_ref",
    "error_code",
    "safe_next_command_ids",
    "idempotency_replayed",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_application_command_receipt"
    },
    "application_command_receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "command_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "authorization_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "accepted_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "result": {
      "enum": [
        "accepted",
        "rejected",
        "duplicate",
        "conflict",
        "deferred",
        "completed",
        "failed"
      ]
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "aggregate_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "aggregate_version_before": {
      "type": "integer",
      "minimum": 0
    },
    "aggregate_version_after": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "result_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "safe_next_command_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "idempotency_replayed": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
