{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wave22 PhysicalContactGraph",
  "type": "object",
  "required": ["contract_version", "contact_graph_id", "contact_edges"],
  "properties": {
    "contract_version": {"const": "wave22.v1"},
    "contact_graph_id": {"type": "string", "minLength": 1},
    "scene_id": {"type": ["string", "null"], "minLength": 1},
    "source_image_id": {"type": ["string", "null"], "minLength": 1},
    "contact_edges": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "contact_edge.schema.json"}
    },
    "qa_goals": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["source_target_ownership", "pressure_intensity_valid", "occlusion_valid", "duration_valid", "audio_force_valid", "deformation_evidence_pass", "preservation_pass"]
      }
    }
  },
  "additionalProperties": false
}
