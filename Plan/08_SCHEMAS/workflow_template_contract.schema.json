{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Template Contract",
  "type": "object",
  "required": [
    "module_id",
    "template_id",
    "template_status",
    "must_have",
    "must_not_have"
  ],
  "properties": {
    "module_id": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "template_status": {
      "type": "string"
    },
    "must_have": {
      "type": "array"
    },
    "must_not_have": {
      "type": "array"
    },
    "expected_owner_wave": {
      "type": [
        "integer",
        "null"
      ]
    }
  }
}
