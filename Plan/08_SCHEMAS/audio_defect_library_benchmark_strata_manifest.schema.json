{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/audio_defect_library_benchmark_strata_manifest.schema.json",
  "title": "Wave64 Row075 Audio Defect Library Benchmark Strata Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "tracker_id",
    "item_id",
    "strata_registry_revision",
    "threshold_registry_revision",
    "detector_revision",
    "authority",
    "selection_policy",
    "source_retained_records",
    "strata_targets",
    "candidates",
    "counts",
    "truth_defect_status",
    "row109_synthetic_partition_references",
    "blocker_codes",
    "decision"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "artifact_type": {
      "type": "string",
      "const": "audio_defect_library_benchmark_strata_manifest"
    },
    "tracker_id": { "type": "string", "const": "TRK-W64-075" },
    "item_id": { "type": "string", "const": "ITEM-W64-075" },
    "strata_registry_revision": {
      "type": "string",
      "const": "wave64_row075_audio_defect_library_benchmark_strata_v0.1.0"
    },
    "threshold_registry_revision": {
      "type": "string",
      "const": "wave64_row075_audio_defect_thresholds_v0.1.0"
    },
    "detector_revision": {
      "type": "string",
      "const": "wave64_row075_audio_defect_classifier_v0.1.0"
    },
    "authority": {
      "type": "string",
      "const": "candidate_shortlist_pending_truth_defects"
    },
    "selection_policy": {
      "type": "string",
      "const": "retained_shortlist_synthetic_fixture_truth_no_pcm_library_decode"
    },
    "source_retained_records": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes", "records_scanned"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 0 },
        "records_scanned": { "type": "integer", "minimum": 0 }
      }
    },
    "strata_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stratum_target" }
    },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate" }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strata_targets",
        "strata_filled",
        "strata_unfilled",
        "candidates_selected",
        "truth_labeled",
        "truth_unlabeled"
      ],
      "properties": {
        "strata_targets": { "type": "integer", "minimum": 0 },
        "strata_filled": { "type": "integer", "minimum": 0 },
        "strata_unfilled": { "type": "integer", "minimum": 0 },
        "candidates_selected": { "type": "integer", "minimum": 0 },
        "truth_labeled": { "type": "integer", "minimum": 0 },
        "truth_unlabeled": { "type": "integer", "minimum": 0 },
        "truth_pending": { "type": "integer", "minimum": 0 },
        "truth_blocked": { "type": "integer", "minimum": 0 },
        "truth_label_stops": { "type": "integer", "minimum": 0 }
      }
    },
    "truth_defect_status": {
      "enum": ["absent", "pending", "partial", "complete"]
    },
    "row109_synthetic_partition_references": {
      "$ref": "#/$defs/row109_synthetic_partition_references"
    },
    "blocker_codes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "library_authority",
        "row_complete",
        "product_completion",
        "threshold_authority_unfrozen",
        "benchmark_strata_calibrated"
      ],
      "properties": {
        "status": { "enum": ["blocked", "pass"] },
        "library_authority": { "type": "boolean" },
        "row_complete": { "type": "boolean" },
        "product_completion": { "type": "boolean" },
        "threshold_authority_unfrozen": { "type": "boolean" },
        "benchmark_strata_calibrated": { "type": "boolean" },
        "safe_next_action": { "type": "string", "minLength": 1 }
      }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "row109_synthetic_partition_references": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "tracker_id",
        "item_id",
        "policy_registry_path",
        "policy_registry_revision",
        "corpus_case_index_path",
        "partition_ids",
        "binding_scope",
        "pcm_decode_authorized",
        "threshold_authority_unfrozen",
        "library_authority"
      ],
      "properties": {
        "authority": {
          "type": "string",
          "const": "synthetic_fixture_partition_references_only"
        },
        "tracker_id": { "type": "string", "const": "TRK-W64-109" },
        "item_id": { "type": "string", "const": "ITEM-W64-109" },
        "policy_registry_path": { "type": "string", "minLength": 1 },
        "policy_registry_revision": {
          "type": "string",
          "const": "wave64_row109_audio_benchmark_corpus_policy_v0.1.0"
        },
        "corpus_case_index_path": { "type": "string", "minLength": 1 },
        "partition_ids": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": ["train", "calibration", "held_out_test", "adversarial"]
          }
        },
        "binding_scope": {
          "type": "string",
          "const": "synthetic_partition_ids_only"
        },
        "pcm_decode_authorized": { "type": "boolean", "const": false },
        "threshold_authority_unfrozen": { "type": "boolean", "const": false },
        "library_authority": { "type": "boolean", "const": false },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stratum_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stratum_id",
        "role",
        "event_type",
        "extension",
        "defect_status",
        "max_candidates"
      ],
      "properties": {
        "stratum_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "event_type": { "type": "string", "minLength": 1 },
        "extension": { "type": "string", "pattern": "^\\.[a-z0-9]+$" },
        "defect_status": { "enum": ["pass", "blocked"] },
        "max_candidates": { "type": "integer", "minimum": 1 }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "stratum_id",
        "relative_path",
        "asset_id",
        "role",
        "event_type",
        "extension",
        "defect_status",
        "source_sha256",
        "canonical_pcm_sha256",
        "truth_severe_defect_codes",
        "truth_label_status"
      ],
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "stratum_id": { "type": "string", "minLength": 1 },
        "relative_path": { "type": "string", "minLength": 1 },
        "asset_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "event_type": { "type": "string", "minLength": 1 },
        "extension": { "type": "string", "minLength": 1 },
        "defect_status": { "enum": ["pass", "blocked"] },
        "technical_defect_pass": { "type": "boolean" },
        "production_eligibility": {
          "type": ["string", "null"],
          "enum": ["eligible", "limited", "ineligible", "unknown", null]
        },
        "severe_defect_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "sample_rate_hz": { "type": ["integer", "null"], "minimum": 1 },
        "channels": { "type": ["integer", "null"], "minimum": 1 },
        "frame_count": { "type": ["integer", "null"], "minimum": 0 },
        "source_sha256": {
          "oneOf": [
            { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            { "type": "null" }
          ]
        },
        "canonical_pcm_sha256": {
          "oneOf": [
            { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            { "type": "null" }
          ]
        },
        "truth_severe_defect_codes": {
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            { "type": "null" }
          ]
        },
        "truth_label_status": {
          "enum": ["unlabeled", "pending", "labeled", "blocked"]
        },
        "truth_label_stop": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/truth_label_stop" }
          ]
        },
        "blocker_code": { "type": ["string", "null"] }
      }
    },
    "truth_label_stop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "classes",
        "blocker_codes",
        "measured_severe_defect_codes_not_promoted",
        "detail"
      ],
      "properties": {
        "status": { "type": "string", "const": "stop" },
        "classes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "enum": ["D", "F"] }
        },
        "blocker_codes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "measured_severe_defect_codes_not_promoted": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "detail": { "type": "string", "minLength": 1 }
      }
    }
  }
}
