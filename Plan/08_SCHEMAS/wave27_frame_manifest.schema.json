{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave27 Frame Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "manifest_version",
    "frame_count",
    "frames",
    "sequence_sha256"
  ],
  "properties": {
    "schema_name": {
      "type": "string",
      "const": "wave27_frame_manifest"
    },
    "manifest_version": {
      "type": "integer",
      "minimum": 1
    },
    "frame_count": {
      "type": "integer",
      "minimum": 1
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "frame_index",
          "time_seconds",
          "source_route",
          "engine_name",
          "shot_id",
          "visible_characters",
          "camera_state",
          "qa_scores",
          "repair_status",
          "artifact_path",
          "artifact_sha256",
          "artifact_bytes"
        ],
        "properties": {
          "frame_index": {
            "type": "integer",
            "minimum": 0
          },
          "time_seconds": {
            "type": "number",
            "minimum": 0
          },
          "source_route": {
            "type": "string",
            "minLength": 1
          },
          "engine_name": {
            "type": "string",
            "minLength": 1
          },
          "shot_id": {
            "type": "string",
            "minLength": 1
          },
          "visible_characters": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "camera_state": {
            "type": "object"
          },
          "qa_scores": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "identity_drift_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "flicker_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "pose_continuity_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "depth_continuity_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "contact_continuity_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "export_integrity_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "overall_temporal_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            }
          },
          "repair_status": {
            "type": "string",
            "enum": [
              "none",
              "repaired",
              "needs_repair",
              "unknown"
            ]
          },
          "artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "artifact_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "artifact_bytes": {
            "type": "integer",
            "minimum": 1
          },
          "keyframe_phase": {
            "type": "string",
            "minLength": 1
          },
          "identity_targets": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "contact_state": {
            "type": "object"
          },
          "deformation_state": {
            "type": "object"
          },
          "export_target": {
            "type": "string",
            "enum": [
              "gif",
              "mp4",
              "webm"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "sequence_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
