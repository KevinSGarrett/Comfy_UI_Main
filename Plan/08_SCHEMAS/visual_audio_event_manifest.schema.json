{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/visual_audio_event_manifest.schema.json",
  "title": "Visual Audio Event Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "video_sha256", "timeline", "detectors", "events", "coverage"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "manifest_id": {"type": "string", "minLength": 1},
    "video_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "scene_state_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "timeline": {
      "type": "object",
      "required": ["time_base", "frame_count", "duration_seconds", "target_sample_rate_hz"],
      "properties": {
        "time_base": {"type": "string", "minLength": 1},
        "frame_count": {"type": "integer", "minimum": 1},
        "duration_seconds": {"type": "number", "exclusiveMinimum": 0},
        "target_sample_rate_hz": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "detectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "revision"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "revision": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "event_id", "event_type", "source_owner", "target_owner", "start_frame",
          "anchor_frame", "end_frame", "anchor_seconds", "anchor_sample", "material",
          "force_band", "expected_layers", "confidence", "authority_ceiling", "evidence"
        ],
        "properties": {
          "event_id": {"type": "string", "minLength": 1},
          "event_type": {"type": "string", "minLength": 1},
          "source_owner": {"type": ["string", "null"]},
          "target_owner": {"type": ["string", "null"]},
          "source_body_part": {"type": ["string", "null"]},
          "target_body_part": {"type": ["string", "null"]},
          "start_frame": {"type": "integer", "minimum": 0},
          "anchor_frame": {"type": "integer", "minimum": 0},
          "end_frame": {"type": "integer", "minimum": 0},
          "anchor_seconds": {"type": "number", "minimum": 0},
          "anchor_sample": {"type": "integer", "minimum": 0},
          "material": {"type": "string", "minLength": 1},
          "footwear": {"type": ["string", "null"]},
          "force_band": {"type": "string", "minLength": 1},
          "expected_layers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "authority_ceiling": {"enum": ["candidate", "technical", "certification"]},
          "evidence": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": true}}
        },
        "additionalProperties": false
      }
    },
    "coverage": {
      "type": "object",
      "required": ["required_events", "covered_events", "silent_events", "blocked_events"],
      "properties": {
        "required_events": {"type": "integer", "minimum": 0},
        "covered_events": {"type": "integer", "minimum": 0},
        "silent_events": {"type": "integer", "minimum": 0},
        "blocked_events": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  }
}
