{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Civitai Raw Cache Manifest",
  "type": "object",
  "required": [
    "model_id",
    "model_version_id",
    "fetched_at",
    "api_base_url",
    "raw_files",
    "normalization_version"
  ],
  "properties": {
    "model_id": {
      "type": [
        "integer",
        "string",
        "null"
      ]
    },
    "model_version_id": {
      "type": [
        "integer",
        "string",
        "null"
      ]
    },
    "fetched_at": {
      "type": "string"
    },
    "api_base_url": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "request_urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "raw_files": {
      "type": "object"
    },
    "raw_sha256": {
      "type": "object"
    },
    "fetch_status": {
      "type": "string"
    },
    "errors": {
      "type": "array"
    },
    "normalization_version": {
      "type": "string"
    }
  },
  "additionalProperties": true
}