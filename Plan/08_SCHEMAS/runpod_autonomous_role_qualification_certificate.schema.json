{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_role_qualification_certificate.schema.json",
  "title": "Wave64 Autonomous Scoped Role Qualification Certificate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "certificate_id", "report_sha256", "role_id", "model_id",
    "checkpoint_sha256", "runtime_digest", "prompt_sha256", "corpus_sha256", "execution_matrix_sha256",
    "issued_at", "expires_at", "scope", "thresholds", "metrics", "coverage_categories",
    "qualification_disposition", "operational_authority_granted", "reason_codes"
  ],
  "properties": {
    "schema_version": {"const": "wave64.aqa.role_qualification_certificate.v1"},
    "certificate_id": {"$ref": "#/definitions/sha256"},
    "report_sha256": {"$ref": "#/definitions/sha256"},
    "role_id": {"type": "string", "pattern": "^W64-AQA-ROLE-[A-Z0-9-]+$"},
    "model_id": {"type": "string", "minLength": 1},
    "checkpoint_sha256": {"$ref": "#/definitions/sha256"},
    "runtime_digest": {"$ref": "#/definitions/sha256"},
    "prompt_sha256": {"$ref": "#/definitions/sha256"},
    "corpus_sha256": {"$ref": "#/definitions/sha256"},
    "execution_matrix_sha256": {"$ref": "#/definitions/sha256"},
    "authority_scope": {"enum": ["DECLARED_ROLE_SCOPE", "REFUSAL_DISCIPLINE_SCOPE_ONLY"]},
    "issued_at": {"type": "string"},
    "expires_at": {"type": "string"},
    "scope": {"type": "object"},
    "thresholds": {"type": "object"},
    "metrics": {
      "type": "object", "additionalProperties": false,
      "required": ["fixture_count", "calibration_fixture_count", "held_out_fixture_count", "run_count", "held_out_run_count", "repeatability_fixture_count", "false_accept_rate", "false_reject_rate", "invalid_schema_rate", "repeatability_rate", "refusal_correctness_rate"],
      "properties": {
        "fixture_count": {"type": "integer", "minimum": 0},
        "calibration_fixture_count": {"type": "integer", "minimum": 0},
        "held_out_fixture_count": {"type": "integer", "minimum": 0},
        "run_count": {"type": "integer", "minimum": 0},
        "held_out_run_count": {"type": "integer", "minimum": 0},
        "repeatability_fixture_count": {"type": "integer", "minimum": 0},
        "false_accept_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "false_reject_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "invalid_schema_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "repeatability_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "refusal_correctness_rate": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "coverage_categories": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "qualification_disposition": {"enum": ["QUALIFIED_FOR_DECLARED_SCOPE", "QUALIFIED_REFUSAL_DISCIPLINE_SCOPE_ONLY", "FAILED_QUALIFICATION"]},
    "operational_authority_granted": {"type": "boolean"},
    "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}}
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
