{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_review_disagreement_decision.schema.json",
  "title": "Wave64 Autonomous Independent Review Disagreement Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "decision_id", "job_id", "contract_id", "evaluated_at",
    "primary_observation_id", "juror_observation_id", "arbiter_observation_id",
    "independence_verified", "deterministic_hard_gates_pass", "disposition",
    "product_decision", "promotion_authorized", "reason_codes"
  ],
  "properties": {
    "schema_version": {"const": "wave64.aqa.review_disagreement_decision.v1"},
    "decision_id": {"$ref": "#/definitions/sha256"},
    "job_id": {"type": "string", "minLength": 1},
    "contract_id": {"$ref": "#/definitions/sha256"},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "primary_observation_id": {"$ref": "#/definitions/sha256"},
    "juror_observation_id": {"$ref": "#/definitions/sha256"},
    "arbiter_observation_id": {"oneOf": [{"$ref": "#/definitions/sha256"}, {"type": "null"}]},
    "independence_verified": {"type": "boolean"},
    "deterministic_hard_gates_pass": {"type": "boolean"},
    "disposition": {"enum": ["CONSENSUS_PASS", "CONSENSUS_FAIL", "HARD_GATE_FAIL", "BLOCKED_INDEPENDENCE", "BLOCKED_ABSTENTION", "BLOCKED_ARBITRATION_REQUIRED", "ARBITRATED_PASS", "ARBITRATED_FAIL"]},
    "product_decision": {"enum": ["PASS", "FAIL", "BLOCKED"]},
    "promotion_authorized": {"const": false},
    "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}}
  },
  "definitions": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
