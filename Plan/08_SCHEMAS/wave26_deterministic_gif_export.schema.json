{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave26 Deterministic GIF Export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name", "version", "source_bindings", "exporter_registry", "algorithm",
    "loop_profile", "frame_count", "dimensions", "frame_durations_ms", "loop_count",
    "candidate_gif", "technical_seam", "claims"
  ],
  "properties": {
    "schema_name": {"const": "wave26_deterministic_gif_export"},
    "version": {"type": "integer", "const": 1},
    "source_bindings": {
      "type": "object", "additionalProperties": false, "required": ["frame_manifest", "temporal_evidence"],
      "properties": {"frame_manifest": {"$ref": "#/$defs/file_binding"}, "temporal_evidence": {"$ref": "#/$defs/file_binding"}}
    },
    "exporter_registry": {
      "type": "object", "additionalProperties": false, "required": ["path", "sha256", "version"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "version": {"type": "integer", "const": 1}}
    },
    "algorithm": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "pillow_version", "palette_colors", "transparency_index", "alpha_threshold", "minimum_frame_duration_ms", "dither", "optimize", "disposal", "candidate_scope"],
      "properties": {
        "name": {"const": "pillow_global_palette_gif89a_v1"}, "pillow_version": {"type": "string", "minLength": 1},
        "palette_colors": {"type": "integer", "const": 255}, "transparency_index": {"type": "integer", "const": 255},
        "alpha_threshold": {"type": "integer", "minimum": 0, "maximum": 255}, "dither": {"const": "none"},
        "minimum_frame_duration_ms": {"type": "integer", "const": 10},
        "optimize": {"const": false}, "disposal": {"type": "integer", "const": 2},
        "candidate_scope": {"const": "technical_gif_export_only"}
      }
    },
    "loop_profile": {"type": "string", "minLength": 1},
    "frame_count": {"type": "integer", "minimum": 1},
    "dimensions": {
      "type": "object", "additionalProperties": false, "required": ["width", "height"],
      "properties": {"width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}}
    },
    "frame_durations_ms": {"type": "array", "minItems": 1, "items": {"type": "integer", "minimum": 10}},
    "loop_count": {"type": "integer", "const": 0},
    "candidate_gif": {
      "type": "object", "additionalProperties": false, "required": ["path", "sha256", "bytes", "container_header"],
      "properties": {"path": {"const": "candidate.gif"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "bytes": {"type": "integer", "minimum": 1}, "container_header": {"enum": ["GIF87a", "GIF89a"]}}
    },
    "technical_seam": {
      "type": "object", "additionalProperties": false, "required": ["metric_name", "source_rgba_mean_absolute_difference_normalized", "visual_pass_claimed"],
      "properties": {"metric_name": {"const": "source_first_last_rgba_mean_absolute_difference_normalized"}, "source_rgba_mean_absolute_difference_normalized": {"type": "number", "minimum": 0, "maximum": 1}, "visual_pass_claimed": {"const": false}}
    },
    "claims": {
      "type": "object", "additionalProperties": false,
      "required": ["technical_gif_export_generated", "manifest_timing_applied", "runtime_generation_proof", "production_candidate", "loop_playback_visual_review", "identity_no_popping_visual_pass", "contact_deformation_visual_pass", "final_export_certification", "final_promotion"],
      "properties": {
        "technical_gif_export_generated": {"const": true}, "manifest_timing_applied": {"const": true},
        "runtime_generation_proof": {"const": false}, "production_candidate": {"const": false},
        "loop_playback_visual_review": {"const": false}, "identity_no_popping_visual_pass": {"const": false},
        "contact_deformation_visual_pass": {"const": false}, "final_export_certification": {"const": false}, "final_promotion": {"const": false}
      }
    }
  },
  "$defs": {
    "file_binding": {
      "type": "object", "additionalProperties": false, "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
    }
  }
}
