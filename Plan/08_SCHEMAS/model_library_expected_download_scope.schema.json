{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/model-library-expected-download-scope/1.0.0",
  "title": "Wave64 Model Library Expected Download Scope",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "expected_download_scope_id",
    "revision",
    "status",
    "created_at",
    "main_task_id",
    "source_snapshot_ref",
    "scope_asset_manifest_ref",
    "expected_catalog_artifact_count",
    "expected_model_binary_count",
    "included_asset_identity_sha256",
    "declared_exclusions",
    "scope_sha256",
    "scope_declared_complete",
    "runtime_authority_granted",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "model_library_expected_download_scope"
    },
    "expected_download_scope_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "main_task_id": {
      "const": "019f422f-88b1-7382-872b-21de2089e983"
    },
    "source_snapshot_ref": {
      "allOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
        },
        {
          "type": "object",
          "properties": {
            "record_type": {
              "const": "model_library_source_snapshot"
            }
          },
          "required": [
            "record_type"
          ]
        }
      ]
    },
    "scope_asset_manifest_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
    },
    "expected_catalog_artifact_count": {
      "type": "integer",
      "minimum": 1
    },
    "expected_model_binary_count": {
      "type": "integer",
      "minimum": 1
    },
    "included_asset_identity_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "declared_exclusions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "reason_code",
          "authority"
        ],
        "properties": {
          "asset_id": {
            "type": "string",
            "minLength": 1
          },
          "reason_code": {
            "type": "string",
            "minLength": 1
          },
          "authority": {
            "enum": [
              "user_scope_declaration",
              "main_task_scope_authority"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "scope_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "scope_declared_complete": {
      "const": true
    },
    "runtime_authority_granted": {
      "const": false
    }
  },
  "additionalProperties": false
}
