{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/model-benchmark-suite/1.0.0",
  "title": "Wave64 Model Benchmark Suite",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "benchmark_suite_id",
    "revision",
    "status",
    "created_at",
    "capability_scope",
    "cases",
    "parameter_sweeps",
    "metric_ids",
    "gate_ids",
    "holdout_policy",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "model_benchmark_suite"
    },
    "benchmark_suite_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "capability_scope": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/CapabilityScope"
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "input_artifact_ids",
          "baseline_bundle_id",
          "expected_changes",
          "protected_invariants",
          "seed_set"
        ],
        "properties": {
          "case_id": {
            "type": "string"
          },
          "input_artifact_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "baseline_bundle_id": {
            "type": "string"
          },
          "expected_changes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "protected_invariants": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "seed_set": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "minItems": 1
          },
          "mask_binding_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "parameter_sweeps": {
      "type": "object"
    },
    "metric_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "gate_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "holdout_policy": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
