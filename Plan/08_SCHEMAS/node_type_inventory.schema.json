{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wave03.node_type_inventory.schema.json",
  "title": "Wave03 Node Type Inventory",
  "type": "object",
  "required": [
    "schema_version",
    "source_file",
    "node_types"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    },
    "node_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_type",
          "count"
        ],
        "properties": {
          "node_type": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        }
      }
    }
  }
}
