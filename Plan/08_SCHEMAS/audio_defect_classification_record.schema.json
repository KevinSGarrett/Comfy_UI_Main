{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/audio_defect_classification_record.schema.json",
  "title": "Wave64 Row075 Audio Defect Classification Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tracker_id",
    "item_id",
    "detector_revision",
    "threshold_registry_revision",
    "asset_id",
    "source_sha256",
    "canonical_pcm_sha256",
    "source_before_sha256",
    "source_after_sha256",
    "sample_rate_hz",
    "channels",
    "frame_count",
    "thresholds",
    "defects",
    "taxonomy_coverage",
    "decision"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "tracker_id": { "type": "string", "const": "TRK-W64-075" },
    "item_id": { "type": "string", "const": "ITEM-W64-075" },
    "detector_revision": {
      "type": "string",
      "const": "wave64_row075_audio_defect_classifier_v0.1.0"
    },
    "threshold_registry_revision": {
      "type": "string",
      "const": "wave64_row075_audio_defect_thresholds_v0.1.0"
    },
    "asset_id": { "type": "string", "minLength": 1 },
    "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "canonical_pcm_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_before_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_after_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sample_rate_hz": { "type": "integer", "minimum": 1 },
    "channels": { "type": "integer", "minimum": 1 },
    "frame_count": { "type": "integer", "minimum": 1 },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clipping_abs_threshold",
        "clipping_ratio_threshold",
        "click_delta_threshold",
        "dropout_silence_dbfs",
        "dropout_min_ms",
        "hiss_highband_ratio_threshold",
        "hum_tonal_ratio_threshold",
        "noise_rms_dbfs_threshold",
        "truncation_edge_dbfs",
        "channel_policy",
        "unknown_fail_closed",
        "source_mutation_allowed"
      ],
      "properties": {
        "clipping_abs_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "clipping_ratio_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "click_delta_threshold": { "type": "number", "minimum": 0 },
        "dropout_silence_dbfs": { "type": "number" },
        "dropout_min_ms": { "type": "number", "minimum": 0 },
        "hiss_highband_ratio_threshold": { "type": "number", "minimum": 0 },
        "hum_tonal_ratio_threshold": { "type": "number", "minimum": 0 },
        "noise_rms_dbfs_threshold": { "type": "number" },
        "truncation_edge_dbfs": { "type": "number" },
        "channel_policy": { "type": "string", "const": "max_abs_mono" },
        "unknown_fail_closed": { "type": "boolean", "const": true },
        "source_mutation_allowed": { "type": "boolean", "const": false }
      }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect_label" }
    },
    "taxonomy_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_codes",
        "evaluated_codes",
        "unknown_codes",
        "all_required_codes_evaluated"
      ],
      "properties": {
        "required_codes": {
          "type": "array",
          "minItems": 11,
          "items": { "$ref": "#/$defs/defect_code" }
        },
        "evaluated_codes": {
          "type": "array",
          "items": { "$ref": "#/$defs/defect_code" }
        },
        "unknown_codes": {
          "type": "array",
          "items": { "$ref": "#/$defs/defect_code" }
        },
        "all_required_codes_evaluated": { "type": "boolean" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "blocker_codes",
        "library_authority",
        "source_bytes_unchanged",
        "visibility_preserved",
        "production_eligibility",
        "severe_defect_present",
        "unknown_or_ambiguous"
      ],
      "properties": {
        "status": { "enum": ["pass", "blocked"] },
        "blocker_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "library_authority": { "type": "boolean" },
        "source_bytes_unchanged": { "type": "boolean" },
        "visibility_preserved": { "type": "boolean", "const": true },
        "production_eligibility": {
          "enum": ["eligible", "limited", "ineligible", "unknown"]
        },
        "severe_defect_present": { "type": "boolean" },
        "unknown_or_ambiguous": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "defect_code": {
      "type": "string",
      "enum": [
        "clipping",
        "hiss",
        "hum",
        "clicks",
        "dropouts",
        "codec_damage",
        "excessive_noise",
        "unintelligible_speech_contamination",
        "severe_pre_reverb",
        "truncation",
        "unsuitable_background_layers"
      ]
    },
    "defect_label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defect_code",
        "severity",
        "confidence",
        "evidence",
        "detector_revision",
        "threshold_revision",
        "source_sha256",
        "canonical_pcm_sha256"
      ],
      "properties": {
        "defect_code": { "$ref": "#/$defs/defect_code" },
        "severity": { "enum": ["none", "mild", "moderate", "severe", "unknown"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sample_start",
            "sample_end",
            "metric_name",
            "metric_value",
            "threshold_value",
            "method_id"
          ],
          "properties": {
            "sample_start": { "type": "integer", "minimum": 0 },
            "sample_end": { "type": "integer", "minimum": 0 },
            "metric_name": { "type": "string", "minLength": 1 },
            "metric_value": { "type": "number" },
            "threshold_value": { "type": "number" },
            "method_id": { "type": "string", "minLength": 1 }
          }
        },
        "detector_revision": { "type": "string", "minLength": 1 },
        "threshold_revision": { "type": "string", "minLength": 1 },
        "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "canonical_pcm_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
