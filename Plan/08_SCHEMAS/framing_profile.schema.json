{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "framing_profile.schema.json",
  "title": "Framing Profile",
  "type": "object",
  "required": [
    "composition_preset",
    "crop_policy",
    "headroom",
    "footroom",
    "side_margin"
  ],
  "properties": {
    "composition_preset": {
      "type": "string"
    },
    "crop_policy": {
      "type": "string"
    },
    "headroom": {
      "type": "string"
    },
    "footroom": {
      "type": "string"
    },
    "side_margin": {
      "type": "string"
    },
    "horizon_line": {
      "type": "string"
    },
    "must_not_crop": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "intentional_crop_allowed": {
      "type": "boolean"
    }
  }
}
