{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/autonomous-planner-proposal/1.0.0",
  "title": "Wave64 Autonomous Planner Proposal",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "planner_proposal_id",
    "revision",
    "status",
    "created_at",
    "autonomous_stack_ref",
    "retrieval_bundle_ref",
    "objective",
    "proposed_passes",
    "proposed_selection_request_ids",
    "proposed_prompt_package_ids",
    "repair_hypotheses",
    "alternatives",
    "confidence",
    "abstain",
    "abstention_reasons",
    "evidence_ids",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "autonomous_planner_proposal"
    },
    "planner_proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "autonomous_stack_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
    },
    "retrieval_bundle_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
    },
    "objective": {
      "type": "object"
    },
    "proposed_passes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "proposed_selection_request_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposed_prompt_package_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repair_hypotheses": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "abstain": {
      "type": "boolean"
    },
    "abstention_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
