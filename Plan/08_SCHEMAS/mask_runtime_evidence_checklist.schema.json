{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mask Runtime Evidence Checklist",
  "type": "object",
  "required": [
    "checklist_id",
    "required_files",
    "per_mask_required_fields"
  ],
  "properties": {
    "checklist_id": {
      "type": "string"
    },
    "required_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "per_mask_required_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "promotion_required_statuses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
