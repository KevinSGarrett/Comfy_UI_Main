{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Person Instance Mask",
  "type": "object",
  "required": [
    "person_instance_id",
    "character_id",
    "mask_id"
  ],
  "properties": {
    "person_instance_id": {
      "type": "string"
    },
    "character_id": {
      "type": "string"
    },
    "mask_id": {
      "type": "string"
    },
    "bbox_normalized": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4
    },
    "occlusion_order": {
      "type": "integer"
    }
  }
}
