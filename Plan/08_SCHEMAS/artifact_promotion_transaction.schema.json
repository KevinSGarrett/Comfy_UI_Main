{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/artifact-promotion-transaction/1.0.0",
  "title": "Wave64 Artifact Promotion Transaction",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "promotion_transaction_id",
    "revision",
    "status",
    "created_at",
    "artifact_ref",
    "qa_evaluation_refs",
    "policy_decision_ref",
    "prior_accepted_parent_ref",
    "idempotency_key",
    "decision",
    "committed_event_ref",
    "decision_authority",
    "generator_or_reviewer_self_promotion",
    "exactly_once",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "artifact_promotion_transaction"
    },
    "promotion_transaction_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "artifact_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "qa_evaluation_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
      },
      "minItems": 1
    },
    "policy_decision_ref": {
      "allOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "object",
          "properties": {
            "record_type": {
              "const": "autonomous_policy_decision"
            }
          },
          "required": [
            "record_type"
          ]
        }
      ]
    },
    "prior_accepted_parent_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": [
        "commit",
        "reject",
        "revoke"
      ]
    },
    "committed_event_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "decision_authority": {
      "const": "deterministic_promotion_policy"
    },
    "generator_or_reviewer_self_promotion": {
      "const": false
    },
    "exactly_once": {
      "const": true
    }
  },
  "additionalProperties": false
}
