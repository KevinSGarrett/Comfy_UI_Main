{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wave18 SkinMaterialContract",
  "type": "object",
  "required": [
    "contract_version",
    "source_image_id",
    "target_regions",
    "surface_profile",
    "required_evidence_gates"
  ],
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "source_image_id": {
      "type": "string",
      "minLength": 1
    },
    "character_id": {
      "type": "string"
    },
    "target_regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "surface_profile": {
      "type": "string",
      "minLength": 1
    },
    "pass_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "qa_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_evidence_gates": {
      "type": "array",
      "const": [
        "surface_texture_check",
        "lighting_consistency",
        "material_state_continuity",
        "visual_score_threshold"
      ]
    }
  }
}
