{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/engine-model-capability-card/1.0.0",
  "title": "Wave64 Engine Model Capability Card",
  "type": "object",
  "required": ["schema_version", "capability_card_id", "engine_family", "model", "modalities", "pass_intents", "input_contract", "output_contract", "edit_and_control_methods", "scope", "compatibility", "runtime_envelopes", "benchmark_certificates", "authority_status", "updated_at"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "capability_card_id": { "type": "string", "minLength": 1 },
    "engine_family": { "type": "string", "minLength": 1 },
    "model": {
      "type": "object",
      "required": ["model_id", "revision", "sha256"],
      "properties": {
        "model_id": { "type": "string" },
        "revision": { "type": "string" },
        "sha256": { "type": ["string", "null"], "pattern": "^[A-Fa-f0-9]{64}$" },
        "source": { "type": "string" },
        "license_use_record_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "modalities": { "type": "array", "items": { "enum": ["image", "video", "audio", "av"] }, "minItems": 1, "uniqueItems": true },
    "pass_intents": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
    "input_contract": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "output_contract": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
    "edit_and_control_methods": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "scope": {
      "type": "object",
      "required": ["regions_or_spans", "character_count", "resolution_or_duration", "mask_authority_tiers"],
      "properties": {
        "regions_or_spans": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "character_count": { "type": "object", "required": ["minimum", "maximum_certified"], "properties": { "minimum": {"type":"integer", "minimum":0}, "maximum_certified": {"type":"integer", "minimum":0} }, "additionalProperties": false },
        "resolution_or_duration": { "type": "array", "items": { "type": "object" } },
        "mask_authority_tiers": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "required": ["vae_families", "text_encoder_families", "adapter_families", "control_families", "workflow_module_ids"],
      "properties": {
        "vae_families": { "type": "array", "items": { "type": "string" } },
        "text_encoder_families": { "type": "array", "items": { "type": "string" } },
        "adapter_families": { "type": "array", "items": { "type": "string" } },
        "control_families": { "type": "array", "items": { "type": "string" } },
        "workflow_module_ids": { "type": "array", "items": { "type": "string" } },
        "custom_node_lock_ids": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "runtime_envelopes": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["runtime_profile_id", "precision", "peak_vram_mib", "status"], "properties": { "runtime_profile_id": {"type":"string"}, "precision": {"type":"string"}, "peak_vram_mib": {"type":"integer", "minimum":0}, "peak_ram_mib": {"type":"integer", "minimum":0}, "status": {"enum":["planned","measured","certified","revoked"]} }, "additionalProperties": true } },
    "benchmark_certificates": { "type": "array", "items": { "type": "object", "required": ["certificate_id", "bucket_id", "status"], "properties": { "certificate_id": {"type":"string"}, "bucket_id": {"type":"string"}, "status": {"enum":["planned","candidate","certified","expired","revoked"]}, "evidence_ids": {"type":"array", "items":{"type":"string"}}, "expires_at": {"type":["string","null"], "format":"date-time"} }, "additionalProperties": false } },
    "known_failures": { "type": "array", "items": { "type": "string" } },
    "authority_status": { "enum": ["research_unselected", "planned", "candidate", "certified", "suspended", "revoked"] },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
