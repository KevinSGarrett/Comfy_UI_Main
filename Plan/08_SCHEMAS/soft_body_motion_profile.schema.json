{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wave21 SoftBodyMotionProfile",
  "type": "object",
  "required": [
    "motion_profile_id",
    "bounce",
    "jiggle",
    "ripple"
  ],
  "properties": {
    "motion_profile_id": {
      "type": "string"
    },
    "bounce": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "jiggle": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ripple": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "temporal_frames_required": {
      "type": "integer",
      "minimum": 0
    }
  }
}
