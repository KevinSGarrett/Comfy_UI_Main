{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-audio-stem-manifest/1.0.0",
  "title": "Hyperreal Audio Stem Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "audio_stem_manifest_id",
    "revision",
    "status",
    "created_at",
    "scope",
    "canonical_clock",
    "stems",
    "stem_ids_unique",
    "all_events_accounted",
    "nondestructive_lineage",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_audio_stem_manifest"
    },
    "audio_stem_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "scope": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ExecutionScope"
    },
    "canonical_clock": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/MediaSpan"
    },
    "stems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stem_id",
          "event_ids",
          "owner",
          "artifact",
          "sample_rate_hz",
          "channels",
          "sample_count",
          "start_sample",
          "dry",
          "source_route_decision_ref",
          "processing_recipe_ref"
        ],
        "properties": {
          "stem_id": {
            "type": "string",
            "minLength": 1
          },
          "event_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "owner": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/OwnerRef"
          },
          "artifact": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ArtifactRef"
          },
          "sample_rate_hz": {
            "type": "integer",
            "minimum": 8000
          },
          "channels": {
            "type": "integer",
            "minimum": 1,
            "maximum": 16
          },
          "sample_count": {
            "type": "integer",
            "minimum": 1
          },
          "start_sample": {
            "type": "integer",
            "minimum": 0
          },
          "dry": {
            "type": "boolean"
          },
          "source_route_decision_ref": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
          },
          "processing_recipe_ref": {
            "oneOf": [
              {
                "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "stem_ids_unique": {
      "const": true
    },
    "all_events_accounted": {
      "const": true
    },
    "nondestructive_lineage": {
      "const": true
    }
  },
  "additionalProperties": false
}
