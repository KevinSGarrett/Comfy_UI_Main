{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_image_shadow_evidence.schema.json",
  "title": "Wave64 Autonomous Image Shadow Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "evidence_id", "generated_at", "row_id", "source",
    "technical_contract", "measurement", "codex_visual_review", "strict_model_gate",
    "product_promotion_eligible", "overall_disposition"
  ],
  "properties": {
    "schema_version": {"const": "wave64.aqa.image_shadow_evidence.v1"},
    "evidence_id": {"$ref": "#/definitions/sha256"},
    "generated_at": {"type": "string", "format": "date-time"},
    "row_id": {"const": "W64-AQA-004"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_relative_path", "artifact_sha256", "lineage_manifest_relative_path",
        "lineage_manifest_sha256", "visual_qa_relative_path", "visual_qa_sha256",
        "global_review_relative_path", "global_review_sha256", "all_hashes_match"
      ],
      "properties": {
        "artifact_relative_path": {"$ref": "#/definitions/relative_path"},
        "artifact_sha256": {"$ref": "#/definitions/sha256"},
        "lineage_manifest_relative_path": {"$ref": "#/definitions/relative_path"},
        "lineage_manifest_sha256": {"$ref": "#/definitions/sha256"},
        "visual_qa_relative_path": {"$ref": "#/definitions/relative_path"},
        "visual_qa_sha256": {"$ref": "#/definitions/sha256"},
        "global_review_relative_path": {"$ref": "#/definitions/relative_path"},
        "global_review_sha256": {"$ref": "#/definitions/sha256"},
        "all_hashes_match": {"const": true}
      }
    },
    "technical_contract": {
      "type": "object",
      "required": ["schema_version", "contract_id", "modality", "preflight_disposition", "promotion_disposition"],
      "properties": {
        "schema_version": {"const": "wave64.aqa.job_contract.v1"},
        "modality": {"const": "image"},
        "preflight_disposition": {"const": "READY_FOR_LEASE"},
        "promotion_disposition": {"const": "EVIDENCE_ONLY"}
      }
    },
    "measurement": {
      "type": "object",
      "required": ["schema_version", "measurement_id", "artifact_sha256", "disposition"],
      "properties": {
        "schema_version": {"const": "wave64.aqa.image_measurement.v1"},
        "artifact_sha256": {"$ref": "#/definitions/sha256"},
        "disposition": {"enum": ["PASS_DETERMINISTIC_GATES", "FAIL_DETERMINISTIC_GATES"]}
      }
    },
    "codex_visual_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority", "whole_image_inspected", "status", "blocking_findings",
        "passing_regions", "strict_model_runtime_claimed"
      ],
      "properties": {
        "authority": {"const": "codex_final_visual_qa"},
        "whole_image_inspected": {"const": true},
        "status": {"const": "REJECT_KNOWN_BLOCKING_DEFECTS"},
        "blocking_findings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "passing_regions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "strict_model_runtime_claimed": {"const": false}
      }
    },
    "strict_model_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_id", "model", "checkpoint_digest", "admission_evidence_sha256",
        "runtime_executed", "disposition", "blocker_code"
      ],
      "properties": {
        "role_id": {"const": "W64-AQA-ROLE-STRICT-VISUAL"},
        "model": {"const": "qwen2.5vl:32b"},
        "checkpoint_digest": {"$ref": "#/definitions/sha256"},
        "admission_evidence_sha256": {"$ref": "#/definitions/sha256"},
        "runtime_executed": {"const": false},
        "disposition": {"const": "HELD_ACTIVE_FOREIGN_GPU_WORKLOAD"},
        "blocker_code": {"const": "ACTIVE_FOREIGN_GPU_WORKLOAD_PRESENT"}
      }
    },
    "product_promotion_eligible": {"const": false},
    "overall_disposition": {
      "enum": [
        "PASS_DETERMINISTIC_IMAGE_GATES_REJECT_VISUAL_DEFECTS_STRICT_RUNTIME_HELD",
        "FAIL_DETERMINISTIC_IMAGE_GATES"
      ]
    }
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "relative_path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).{1,512}$"}
  }
}
