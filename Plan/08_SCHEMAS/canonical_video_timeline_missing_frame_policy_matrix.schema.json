{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/canonical-video-timeline-missing-frame-policy-matrix/1.0.0",
  "title": "Wave64 Canonical Video Timeline Missing-Frame Policy Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "matrix_id",
    "revision",
    "status",
    "created_at",
    "cases",
    "summary",
    "authority",
    "production_completion_allowed",
    "row_complete",
    "matrix_sha256",
    "provenance"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": {
      "const": "canonical_video_timeline_missing_frame_policy_matrix"
    },
    "matrix_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["fixture_missing_frame_policy_partial", "blocked"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "cases": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "expected_policy",
          "timeline_id",
          "timeline_sha256",
          "frame_rate_mode",
          "missing_frame_count",
          "applied_policies",
          "policy_applied",
          "within_tolerance",
          "runtime_policy_complete",
          "row_complete"
        ],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "expected_policy": {
            "enum": ["preserve_gap", "explicit_gap"]
          },
          "timeline_id": { "type": "string", "minLength": 1 },
          "timeline_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "frame_rate_mode": { "enum": ["fixed", "fractional", "vfr"] },
          "missing_frame_count": { "type": "integer", "minimum": 1 },
          "applied_policies": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": ["preserve_gap", "explicit_gap"]
            }
          },
          "policy_applied": { "const": true },
          "within_tolerance": { "type": "boolean" },
          "runtime_policy_complete": { "const": false },
          "row_complete": { "const": false }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_count",
        "passed_count",
        "failed_count",
        "all_within_tolerance",
        "policies_covered",
        "preserve_gap_covered",
        "explicit_gap_covered",
        "runtime_policy_complete",
        "mux_replay_included",
        "runtime_media_decode_invoked",
        "benchmark_authority_granted",
        "visual_review_authority_granted"
      ],
      "properties": {
        "case_count": { "type": "integer", "minimum": 2 },
        "passed_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "all_within_tolerance": { "type": "boolean" },
        "policies_covered": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["preserve_gap", "explicit_gap"]
          }
        },
        "preserve_gap_covered": { "const": true },
        "explicit_gap_covered": { "const": true },
        "runtime_policy_complete": { "const": false },
        "mux_replay_included": { "const": false },
        "runtime_media_decode_invoked": { "const": false },
        "benchmark_authority_granted": { "const": false },
        "visual_review_authority_granted": { "const": false }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_matrix_only",
        "missing_frame_policy_runtime_complete",
        "fixed_vfr_benchmark_pass",
        "mux_replay_proof_present",
        "combined_visual_review_present"
      ],
      "properties": {
        "fixture_matrix_only": { "const": true },
        "missing_frame_policy_runtime_complete": { "const": false },
        "fixed_vfr_benchmark_pass": { "const": false },
        "mux_replay_proof_present": { "const": false },
        "combined_visual_review_present": { "const": false }
      }
    },
    "production_completion_allowed": { "const": false },
    "row_complete": { "const": false },
    "matrix_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
