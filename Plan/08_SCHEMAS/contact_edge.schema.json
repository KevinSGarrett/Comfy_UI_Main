{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wave22 ContactEdge",
  "type": "object",
  "required": [
    "edge_id",
    "source_owner_id",
    "source_region_id",
    "target_owner_id",
    "target_region_id",
    "contact_edge_type",
    "pressure",
    "intensity",
    "occlusion",
    "duration",
    "audio_force_class"
  ],
  "properties": {
    "edge_id": {"type": "string", "minLength": 1},
    "source_owner_id": {"type": "string", "minLength": 1},
    "source_region_id": {"type": "string", "minLength": 1},
    "source_region_type": {"type": "string", "minLength": 1},
    "target_owner_id": {"type": "string", "minLength": 1},
    "target_region_id": {"type": "string", "minLength": 1},
    "target_region_type": {"type": "string", "minLength": 1},
    "contact_edge_type": {
      "type": "string",
      "enum": ["touch", "press", "squeeze", "pull", "push", "support", "rest", "cover", "occlude", "compress", "slide", "drag", "impact", "rebound"]
    },
    "pressure": {
      "type": "string",
      "enum": ["none", "feather", "light", "medium", "firm", "heavy"]
    },
    "intensity": {
      "type": "string",
      "enum": ["none", "subtle", "visible", "strong", "extreme_blocked_by_default"]
    },
    "occlusion": {
      "type": "string",
      "enum": ["none", "partial_edge", "partial_region", "majority_region", "full_region", "ambiguous_blocked"]
    },
    "duration": {
      "type": "string",
      "enum": ["instantaneous", "brief", "held", "sustained", "repeated", "rhythmic", "unresolved"]
    },
    "audio_force_class": {
      "type": "string",
      "enum": ["silent_contact", "soft_fabric_rustle", "skin_surface_contact", "firm_surface_contact", "object_tap", "object_drag", "furniture_creak", "impact_thud", "rebound_release"]
    },
    "mask_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
