{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/model-intelligence-report/1.0.0",
  "title": "Wave64 Model Intelligence Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "model_report_id",
    "revision",
    "status",
    "created_at",
    "subject_refs",
    "report_scope",
    "authority_summary",
    "certified_uses",
    "untested_uses",
    "best_contexts",
    "worst_contexts",
    "failure_summary",
    "resource_summary",
    "report_notes",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "model_intelligence_report"
    },
    "model_report_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "subject_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
      },
      "minItems": 1
    },
    "report_scope": {
      "enum": [
        "asset",
        "bundle",
        "capability_bucket",
        "selection_decision"
      ]
    },
    "authority_summary": {
      "type": "object"
    },
    "certified_uses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "untested_uses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "best_contexts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "worst_contexts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_summary": {
      "type": "object"
    },
    "resource_summary": {
      "type": "object"
    },
    "report_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "note_type",
          "text",
          "evidence_ids"
        ],
        "properties": {
          "note_type": {
            "enum": [
              "generated_summary",
              "human_annotation",
              "policy_note"
            ]
          },
          "text": {
            "type": "string"
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "supersedes_report_id": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
