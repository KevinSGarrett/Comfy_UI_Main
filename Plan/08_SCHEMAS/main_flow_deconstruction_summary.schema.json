{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave04 Main Flow Deconstruction Summary",
  "type": "object",
  "required": [
    "node_count",
    "link_count",
    "save_image_lanes",
    "lora_catalog_nodes",
    "critical_wave04_findings"
  ],
  "properties": {
    "generated_at_utc": {
      "type": "string"
    },
    "source_main_flow_path": {
      "type": "string"
    },
    "source_main_flow_sha256": {
      "type": "string"
    },
    "main_flow_id": {
      "type": "string"
    },
    "revision": {
      "type": "integer"
    },
    "last_node_id": {
      "type": "integer"
    },
    "last_link_id": {
      "type": "integer"
    },
    "node_count": {
      "type": "integer"
    },
    "link_count": {
      "type": "integer"
    },
    "mode_counts": {
      "type": "object"
    },
    "node_type_counts": {
      "type": "object"
    },
    "enabled_non_disabled_nodes": {
      "type": "integer"
    },
    "disabled_or_muted_nodes_mode2": {
      "type": "integer"
    },
    "save_image_lanes": {
      "type": "integer"
    },
    "preview_nodes": {
      "type": "integer"
    },
    "note_nodes": {
      "type": "integer"
    },
    "lora_catalog_nodes": {
      "type": "integer"
    },
    "lora_catalog_engine_counts": {
      "type": "object"
    },
    "lora_catalog_status_counts": {
      "type": "object"
    },
    "critical_wave04_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
