{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/orchestrator-event-payload-envelope/1.0.0",
  "title": "Wave64 Orchestrator Event Payload Envelope",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "event_payload_envelope_id",
    "revision",
    "status",
    "created_at",
    "event_type",
    "payload_schema_id",
    "payload_schema_revision",
    "payload",
    "payload_sha256",
    "schema_validation_passed",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "orchestrator_event_payload_envelope"
    },
    "event_payload_envelope_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "payload_schema_id": {
      "type": "string",
      "minLength": 1
    },
    "payload_schema_revision": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    },
    "payload_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "schema_validation_passed": {
      "const": true
    }
  },
  "additionalProperties": false
}
