{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/shot-pose-package/1.0.0",
  "title": "Wave64 Shot and Pose Package",
  "type": "object",
  "required": ["schema_version", "shot_pose_package_id", "revision", "package_sha256", "scene_id", "shot_id", "take_id", "media_clock_span_id", "skeleton_taxonomy_id", "source_authority", "timebase", "camera", "output_frame", "instances", "contacts", "events", "coordinate_spaces", "created_at"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "shot_pose_package_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "package_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "scene_id": { "type": "string", "minLength": 1 },
    "shot_id": { "type": "string", "minLength": 1 },
    "take_id": { "type": "string", "minLength": 1 },
    "media_clock_span_id": { "type": "string", "minLength": 1 },
    "skeleton_taxonomy_id": { "type": "string", "minLength": 1 },
    "source_authority": { "enum": ["operator_authored", "validated_estimator", "approved_package", "machine_draft"] },
    "timebase": {
      "type": "object",
      "required": ["numerator", "denominator", "start_frame", "end_frame"],
      "properties": {
        "numerator": { "type": "integer", "minimum": 1 },
        "denominator": { "type": "integer", "minimum": 1 },
        "start_frame": { "type": "integer", "minimum": 0 },
        "end_frame": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "camera": {
      "type": "object",
      "required": ["projection", "framing", "lens_mm", "pose"],
      "properties": {
        "projection": { "enum": ["perspective", "orthographic", "panoramic"] },
        "framing": { "type": "string" },
        "lens_mm": { "type": "number", "exclusiveMinimum": 0 },
        "pose": {
          "type": "object",
          "required": ["position", "look_at", "up"],
          "properties": {
            "position": { "type": "array", "prefixItems": [{"type":"number"},{"type":"number"},{"type":"number"}], "items": false },
            "look_at": { "type": "array", "prefixItems": [{"type":"number"},{"type":"number"},{"type":"number"}], "items": false },
            "up": { "type": "array", "prefixItems": [{"type":"number"},{"type":"number"},{"type":"number"}], "items": false }
          },
          "additionalProperties": false
        },
        "depth_of_field": {
          "type": "object",
          "required": ["focus_m", "aperture_f"],
          "properties": {
            "focus_m": { "type": "number", "exclusiveMinimum": 0 },
            "aperture_f": { "type": "number", "exclusiveMinimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "output_frame": {
      "type": "object",
      "required": ["width", "height", "safe_margin_normalized"],
      "properties": {
        "width": { "type": "integer", "minimum": 64 },
        "height": { "type": "integer", "minimum": 64 },
        "safe_margin_normalized": { "type": "number", "minimum": 0, "maximum": 0.5 }
      },
      "additionalProperties": false
    },
    "instances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["character_instance_id", "character_id", "character_revision", "person_index", "mask_provider_person_index", "render_order", "skeleton", "bbox_normalized", "depth_layer", "visibility", "region_ownership", "protected_regions", "keyframes"],
        "properties": {
          "character_instance_id": { "type": "string", "minLength": 1 },
          "character_id": { "type": "string" },
          "character_revision": { "type": "string" },
          "person_index": { "type": "integer", "minimum": 0 },
          "mask_provider_person_index": { "type": "integer", "minimum": 0 },
          "render_order": { "type": "integer", "minimum": 0 },
          "skeleton": {
            "type": "object",
            "required": ["skeleton_id", "taxonomy_id", "skeleton_sha256", "source_authority"],
            "properties": {
              "skeleton_id": { "type": "string", "minLength": 1 },
              "taxonomy_id": { "type": "string", "minLength": 1 },
              "skeleton_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "source_authority": { "enum": ["operator_authored", "validated_estimator", "approved_package", "machine_draft"] }
            },
            "additionalProperties": false
          },
          "bbox_normalized": { "type": "array", "prefixItems": [{"type":"number"},{"type":"number"},{"type":"number"},{"type":"number"}], "items": false },
          "silhouette_artifact_id": { "type": ["string", "null"] },
          "depth_layer": { "type": "integer" },
          "visibility": { "type": "object", "additionalProperties": { "type": ["number", "boolean", "string"] } },
          "occluded_by_instance_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "region_ownership": { "type": "object", "additionalProperties": { "type": "string" } },
          "protected_regions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "keyframes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["keyframe_id", "pts", "skeleton_sha256", "pose_delta_sha256"],
              "properties": {
                "keyframe_id": { "type": "string", "minLength": 1 },
                "pts": { "type": "integer", "minimum": 0 },
                "skeleton_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                "pose_delta_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "contacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["contact_id", "kind", "participants", "media_clock_span_id", "ownership_resolved", "constraints"],
        "properties": {
          "contact_id": { "type": "string" },
          "kind": { "enum": ["person_person", "hand_object", "body_support", "wardrobe_body", "person_environment", "object_object"] },
          "participants": {
            "type": "array", "minItems": 2,
            "items": {
              "type": "object",
              "required": ["owner_instance_id", "region_or_object_id"],
              "properties": {
                "owner_instance_id": { "type": "string", "minLength": 1 },
                "region_or_object_id": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "media_clock_span_id": { "type": "string", "minLength": 1 },
          "ownership_resolved": { "type": "boolean" },
          "constraints": {
            "type": "object",
            "required": ["reciprocal", "shared_contact_mask_required", "contact_owner_resolved"],
            "properties": {
              "reciprocal": { "const": true },
              "shared_contact_mask_required": { "type": "boolean" },
              "contact_owner_resolved": { "const": true }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "events": { "type": "array", "items": { "type": "object", "required": ["event_id", "event_type", "pts", "owner_instance_id", "payload_schema_id", "payload_sha256"], "properties": { "event_id": {"type":"string"}, "event_type": {"type":"string"}, "pts": {"type":"integer", "minimum":0}, "owner_instance_id": {"type":["string","null"]}, "payload_schema_id": {"type":"string", "minLength":1}, "payload_sha256": {"type":"string", "pattern":"^[0-9a-f]{64}$"} }, "additionalProperties": false } },
    "coordinate_spaces": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["id", "width", "height", "coordinate_space_sha256"], "properties": { "id":{"type":"string","minLength":1}, "width":{"type":"integer","minimum":1}, "height":{"type":"integer","minimum":1}, "coordinate_space_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"} }, "additionalProperties":false } },
    "qa_goal_ids": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
