{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_campaign_result.schema.json",
  "title": "Wave64 RunPod Autonomous Campaign Sealed Result",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "result_id", "campaign_id", "contract_sha256", "journal_head_sha256", "merkle_root_sha256", "disposition", "jobs", "evidence", "metrics", "cleanup", "authority", "proposed_delta", "deferred_work_queue"],
  "properties": {
    "schema_version": {"const": "wave64.aqa.campaign_result.v1"},
    "result_id": {"$ref": "#/definitions/sha256"},
    "campaign_id": {"$ref": "#/definitions/sha256"},
    "contract_sha256": {"$ref": "#/definitions/sha256"},
    "journal_head_sha256": {"$ref": "#/definitions/sha256"},
    "merkle_root_sha256": {"$ref": "#/definitions/sha256"},
    "disposition": {"enum": ["COMPLETE", "PARTIAL_BLOCKED", "PARTIAL_DEFERRED", "ABORTED"]},
    "jobs": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["node_id", "terminal_state", "attempts", "evidence_sha256", "evidence_path", "reason"], "properties": {"node_id": {"type": "string"}, "terminal_state": {"enum": ["PASS", "FAIL", "BLOCKED", "ABSTAINED", "QUARANTINED", "ROLLED_BACK", "DEFERRED"]}, "attempts": {"type": "integer", "minimum": 0}, "evidence_sha256": {"$ref": "#/definitions/sha256"}, "evidence_path": {"type": "string", "pattern": "^(?![A-Za-z]:|/|.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"}, "reason": {"type": "string"}}}},
    "evidence": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["sha256", "relative_path", "media_type", "size_bytes"], "properties": {"sha256": {"$ref": "#/definitions/sha256"}, "relative_path": {"type": "string", "pattern": "^(?![A-Za-z]:|/|.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"}, "media_type": {"type": "string"}, "size_bytes": {"type": "integer", "minimum": 0}}}},
    "metrics": {"type": "object", "additionalProperties": false, "required": ["autonomous_terminalization_rate", "interruption_rate", "evidence_completeness_rate", "restart_replay_rate", "scope_authority_violations", "known_bad_false_accepts", "known_good_false_rejects", "codex_agreement_rate", "juror_disagreement_rate", "abstention_rate", "first_pass_validation_rate", "repair_success_rate", "regression_escape_rate", "rework_rate", "accepted_artifacts_per_hour", "gpu_seconds_per_accepted_artifact", "cpu_seconds_per_accepted_artifact", "storage_growth_bytes", "model_reloads", "lease_wait_seconds", "coordinator_churn", "interruption_count", "deferred_job_count", "raw_evidence_bytes", "compacted_evidence_bytes"], "properties": {"autonomous_terminalization_rate": {"$ref": "#/definitions/nullable_rate"}, "interruption_rate": {"$ref": "#/definitions/nullable_rate"}, "evidence_completeness_rate": {"$ref": "#/definitions/nullable_rate"}, "restart_replay_rate": {"$ref": "#/definitions/nullable_rate"}, "scope_authority_violations": {"$ref": "#/definitions/nullable_count"}, "known_bad_false_accepts": {"$ref": "#/definitions/nullable_count"}, "known_good_false_rejects": {"$ref": "#/definitions/nullable_count"}, "codex_agreement_rate": {"$ref": "#/definitions/nullable_rate"}, "juror_disagreement_rate": {"$ref": "#/definitions/nullable_rate"}, "abstention_rate": {"$ref": "#/definitions/nullable_rate"}, "first_pass_validation_rate": {"$ref": "#/definitions/nullable_rate"}, "repair_success_rate": {"$ref": "#/definitions/nullable_rate"}, "regression_escape_rate": {"$ref": "#/definitions/nullable_rate"}, "rework_rate": {"$ref": "#/definitions/nullable_rate"}, "accepted_artifacts_per_hour": {"type": ["number", "null"], "minimum": 0}, "gpu_seconds_per_accepted_artifact": {"type": ["number", "null"], "minimum": 0}, "cpu_seconds_per_accepted_artifact": {"type": ["number", "null"], "minimum": 0}, "storage_growth_bytes": {"type": ["integer", "null"], "minimum": 0}, "model_reloads": {"type": "integer", "minimum": 0}, "lease_wait_seconds": {"type": ["number", "null"], "minimum": 0}, "coordinator_churn": {"type": "integer", "minimum": 0}, "interruption_count": {"type": ["integer", "null"], "minimum": 0}, "deferred_job_count": {"type": "integer", "minimum": 0}, "raw_evidence_bytes": {"type": ["integer", "null"], "minimum": 0}, "compacted_evidence_bytes": {"type": ["integer", "null"], "minimum": 0}}},
    "cleanup": {"type": "object", "additionalProperties": false, "required": ["measured", "complete", "residual_paths", "measurement_sha256"], "properties": {"measured": {"type": "boolean"}, "complete": {"type": ["boolean", "null"]}, "residual_paths": {"type": "array", "items": {"type": "string"}}, "measurement_sha256": {"anyOf": [{"$ref": "#/definitions/sha256"}, {"type": "null"}]}}},
    "authority": {"type": "object", "additionalProperties": false, "required": ["self_promoted", "git_pushed", "thresholds_weakened", "final_acceptance_authority"], "properties": {"self_promoted": {"const": false}, "git_pushed": {"const": false}, "thresholds_weakened": {"const": false}, "final_acceptance_authority": {"const": "CODEX"}}},
    "proposed_delta": {"type": ["object", "null"], "additionalProperties": false, "required": ["manifest_sha256", "relative_path"], "properties": {"manifest_sha256": {"$ref": "#/definitions/sha256"}, "relative_path": {"type": "string", "pattern": "^(?![A-Za-z]:|/|.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"}}},
    "deferred_work_queue": {"type": ["object", "null"], "additionalProperties": false, "required": ["queue_id", "contract_sha256", "jobs", "resume_requires_fresh_admission", "content_sha256", "relative_path"], "properties": {"queue_id": {"$ref": "#/definitions/sha256"}, "contract_sha256": {"$ref": "#/definitions/sha256"}, "jobs": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["node_id", "phase", "job_sha256", "reason"], "properties": {"node_id": {"type": "string"}, "phase": {"enum": ["CPU", "GPU"]}, "job_sha256": {"$ref": "#/definitions/sha256"}, "reason": {"type": "string"}}}}, "resume_requires_fresh_admission": {"const": true}, "content_sha256": {"$ref": "#/definitions/sha256"}, "relative_path": {"type": "string", "pattern": "^(?![A-Za-z]:|/|.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"}}}
  },
  "definitions": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "rate": {"type": "number", "minimum": 0, "maximum": 1}, "nullable_rate": {"anyOf": [{"$ref": "#/definitions/rate"}, {"type": "null"}]}, "nullable_count": {"type": ["integer", "null"], "minimum": 0}}
}
