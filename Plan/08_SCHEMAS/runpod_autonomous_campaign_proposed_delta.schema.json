{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_campaign_proposed_delta.schema.json",
  "title": "Wave64 Campaign Proposed Plan Items Tracker Delta",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "delta_id", "campaign_id", "base_commit_sha256", "changes", "authority"],
  "properties": {
    "schema_version": {"const": "wave64.aqa.campaign_proposed_delta.v1"},
    "delta_id": {"$ref": "#/definitions/sha256"},
    "campaign_id": {"$ref": "#/definitions/sha256"},
    "base_commit_sha256": {"$ref": "#/definitions/sha256"},
    "changes": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["relative_path", "operation", "candidate_sha256", "evidence_sha256"], "properties": {"relative_path": {"type": "string", "pattern": "^(?![A-Za-z]:|/|.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"}, "operation": {"enum": ["ADD", "MODIFY"]}, "candidate_sha256": {"$ref": "#/definitions/sha256"}, "evidence_sha256": {"$ref": "#/definitions/sha256"}}}},
    "authority": {"type": "object", "additionalProperties": false, "required": ["candidate_only", "may_commit", "final_acceptance_authority"], "properties": {"candidate_only": {"const": true}, "may_commit": {"const": false}, "final_acceptance_authority": {"const": "CODEX"}}}
  },
  "definitions": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
