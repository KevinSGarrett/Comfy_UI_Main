{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave27 Visual Review Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "packet_version",
    "source_bindings",
    "frames",
    "preview_artifacts",
    "prerequisites",
    "prerequisite_evidence_results",
    "missing_prerequisite_categories",
    "review_assets_ready",
    "prerequisites_complete",
    "visual_review_complete",
    "status",
    "decision_scope",
    "final_temporal_visual_pass",
    "final_acceptance_claimed"
  ],
  "properties": {
    "schema_name": {
      "type": "string",
      "const": "wave27_visual_review_packet"
    },
    "packet_version": {
      "type": "integer",
      "minimum": 1
    },
    "source_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_path",
        "manifest_sha256",
        "manifest_sequence_sha256",
        "evidence_path",
        "evidence_sha256",
        "frame_count"
      ],
      "properties": {
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "manifest_sequence_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "evidence_path": {
          "type": "string",
          "minLength": 1
        },
        "evidence_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "frame_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "frame_index",
          "time_seconds",
          "artifact_path",
          "artifact_sha256",
          "artifact_bytes",
          "image_width",
          "image_height",
          "adjacent_next_index",
          "adjacent_next_time_delta_seconds"
        ],
        "properties": {
          "frame_index": {
            "type": "integer",
            "minimum": 0
          },
          "time_seconds": {
            "type": "number",
            "minimum": 0
          },
          "artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "artifact_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "artifact_bytes": {
            "type": "integer",
            "minimum": 1
          },
          "image_width": {
            "type": "integer",
            "minimum": 1
          },
          "image_height": {
            "type": "integer",
            "minimum": 1
          },
          "adjacent_next_index": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0
              },
              {
                "type": "null"
              }
            ]
          },
          "adjacent_next_time_delta_seconds": {
            "oneOf": [
              {
                "type": "number",
                "minimum": 0
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    },
    "preview_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_grid",
        "review_playback_gif"
      ],
      "properties": {
        "frame_grid": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "bytes",
            "width",
            "height"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            },
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "review_playback_gif": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "bytes",
            "frame_count",
            "durations_ms"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            },
            "frame_count": {
              "type": "integer",
              "minimum": 1
            },
            "durations_ms": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    },
    "prerequisites": {
      "$ref": "wave27_visual_review_prerequisites.schema.json"
    },
    "prerequisite_evidence_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category",
          "status",
          "path",
          "declared_sha256",
          "observed_sha256",
          "reason",
          "path_check",
          "sha256_check",
          "evidence_type_check",
          "sequence_sha256_check",
          "result_check",
          "evidence_result",
          "prerequisite_satisfied"
        ],
        "properties": {
          "category": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "verified",
              "missing",
              "not_required"
            ]
          },
          "path": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "declared_sha256": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              {
                "type": "null"
              }
            ]
          },
          "observed_sha256": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              {
                "type": "null"
              }
            ]
          },
          "reason": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "path_check": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "sha256_check": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "evidence_type_check": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "sequence_sha256_check": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "result_check": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "evidence_result": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "pass",
                  "fail",
                  "blocked"
                ]
              },
              {
                "type": "null"
              }
            ]
          },
          "prerequisite_satisfied": {
            "type": "boolean"
          }
        }
      }
    },
    "missing_prerequisite_categories": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "review_assets_ready": {
      "type": "boolean"
    },
    "prerequisites_complete": {
      "type": "boolean"
    },
    "visual_review_complete": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "blocked_missing_prerequisites",
        "ready_for_visual_review",
        "visual_review_recorded_pending_codex_authority"
      ]
    },
    "decision_scope": {
      "type": "string",
      "const": "review_preparation_only"
    },
    "final_temporal_visual_pass": {
      "type": "boolean",
      "const": false
    },
    "final_acceptance_claimed": {
      "type": "boolean",
      "const": false
    }
  }
}
