{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave25 MergePreventionReport",
  "type": "object",
  "required": [
    "report_id",
    "event_id",
    "pass",
    "failure_flags"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "pass": {
      "type": "boolean"
    },
    "failure_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score": {
      "type": "number"
    }
  }
}
