{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/wave64_human_audio_review_record.schema.json",
  "title": "Wave64 Human Audio Review Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "record_version", "review_id", "request_sha256", "authority_type", "reviewer_identity", "independence_attestation", "playback_conditions", "section_results", "category_results", "observed_transcript", "defects", "decision", "reviewed_at"],
  "properties": {
    "schema_name": {"const": "wave64_human_audio_review_record"},
    "record_version": {"const": 1},
    "review_id": {"type": "string", "minLength": 1},
    "request_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "authority_type": {"const": "human"},
    "reviewer_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer_id", "authority_id", "role"],
      "properties": {
        "reviewer_id": {"type": "string", "minLength": 1},
        "authority_id": {"type": "string", "minLength": 1},
        "role": {"const": "playback_reviewer"}
      }
    },
    "independence_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["not_generator", "no_conflict", "reviewed_exact_hash"],
      "properties": {
        "not_generator": {"const": true},
        "no_conflict": {"const": true},
        "reviewed_exact_hash": {"const": true}
      }
    },
    "playback_conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device_class", "environment", "full_playback_count", "reasonable_listening_level"],
      "properties": {
        "device_class": {"type": "string", "minLength": 1},
        "environment": {"type": "string", "minLength": 1},
        "full_playback_count": {"type": "integer", "minimum": 1},
        "reasonable_listening_level": {"const": true}
      }
    },
    "section_results": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/result"}},
    "category_results": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/scoredResult"}},
    "observed_transcript": {"type": "string"},
    "defects": {"type": "array", "items": {"$ref": "#/$defs/defect"}},
    "decision": {"type": "string", "enum": ["PASS", "PASS_WITH_ISSUES", "FAIL"]},
    "reviewed_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "not_applicable_reason"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["reviewed", "not_applicable"]},
        "not_applicable_reason": {"type": ["string", "null"]}
      }
    },
    "scoredResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "score", "not_applicable_reason", "notes"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["scored", "not_applicable"]},
        "score": {"type": ["number", "null"], "minimum": 0, "maximum": 5},
        "not_applicable_reason": {"type": ["string", "null"]},
        "notes": {"type": "string"}
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "description"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
        "description": {"type": "string", "minLength": 1}
      }
    }
  }
}
