{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source_inventory_entry.schema.json",
  "title": "Wave Source Inventory Entry",
  "type": "object",
  "required": [
    "source_label",
    "uploaded_name",
    "size_bytes",
    "sha256",
    "source_role"
  ],
  "properties": {
    "source_label": {
      "type": "string"
    },
    "uploaded_name": {
      "type": "string"
    },
    "sandbox_path": {
      "type": "string"
    },
    "size_bytes": {
      "type": "integer"
    },
    "sha256": {
      "type": "string"
    },
    "wave01_ingest_status": {
      "type": "string"
    },
    "source_role": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
