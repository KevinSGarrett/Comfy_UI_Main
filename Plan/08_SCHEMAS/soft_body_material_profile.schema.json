{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wave21 SoftBodyMaterialProfile",
  "type": "object",
  "required": [
    "profile_id",
    "material_family",
    "firmness",
    "softness",
    "sag",
    "compression",
    "rebound"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "material_family": {
      "type": "string"
    },
    "firmness": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "softness": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sag": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "bounce": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ripple": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "jiggle": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "compression": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rebound": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recommended_mask_scale": {
      "type": "string"
    }
  }
}
