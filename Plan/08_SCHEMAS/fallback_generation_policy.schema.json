{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Wave15 Fallback Generation Policy",
  "required": [
    "policy_id",
    "fallback_order",
    "hard_stop_conditions"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "max_base_lane_attempts": {
      "type": "integer"
    },
    "fallback_order": {
      "type": "array"
    },
    "hard_stop_conditions": {
      "type": "array"
    }
  }
}
