{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "facial_gold_prediction_manifest.schema.json",
  "title": "Facial Gold Prediction Manifest",
  "type": "object",
  "required": ["schema_version", "created_at", "route_id", "route_model_identity", "route_configuration_sha256", "dataset_id", "run_id", "producer_contract", "samples"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "created_at": {"type": "string", "minLength": 1},
    "route_id": {"type": "string", "minLength": 1},
    "route_model_identity": {
      "type": "object",
      "required": ["model_id", "model_sha256"],
      "properties": {
        "model_id": {"type": "string", "minLength": 1},
        "model_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}
      }
    },
    "route_configuration_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "candidate_target_classes": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "neck_candidate_authority": {
      "type": "object",
      "required": ["kind", "authority_id", "implementation_path", "implementation_sha256", "gold_derived"],
      "properties": {
        "kind": {"const": "fixed_non_gold_reconstruction"},
        "authority_id": {"type": "string", "minLength": 1},
        "implementation_path": {"type": "string", "minLength": 1},
        "implementation_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
        "gold_derived": {"const": false}
      },
      "additionalProperties": false
    },
    "dataset_id": {"enum": ["celebamask_hq_shard_0", "lapa"]},
    "split": {"enum": ["train", "val", "test"]},
    "run_id": {"type": "string", "minLength": 1},
    "boundary_tolerance_pixels": {"type": "integer", "minimum": 0, "maximum": 10},
    "producer_contract": {
      "type": "object",
      "required": ["originals_only", "gold_paths_exposed_to_route", "prediction_generated_before_evaluation", "route_input_image_paths"],
      "properties": {
        "originals_only": {"const": true},
        "gold_paths_exposed_to_route": {"const": false},
        "prediction_generated_before_evaluation": {"const": true},
        "route_input_image_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "landmark_normalization": {
      "type": "object",
      "required": ["method", "indices", "authority_source"],
      "properties": {
        "method": {"const": "interocular_index_pair"},
        "indices": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 0}},
        "authority_source": {"type": "string", "minLength": 1}
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sample_id", "source_path", "source_sha256", "source_size", "prediction_path", "prediction_sha256", "transforms"],
        "properties": {
          "sample_id": {"type": "string", "minLength": 1},
          "source_path": {"type": "string", "minLength": 1},
          "source_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
          "source_size": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}},
          "prediction_path": {"type": "string", "minLength": 1},
          "prediction_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
          "prediction_landmarks_path": {"type": "string"},
          "prediction_landmarks_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
          "mode": {"enum": ["semantic", "landmarks", "semantic_and_landmarks"]},
          "classes": {"type": "array", "items": {"type": "string"}},
          "protected_neighbors": {"type": "object"},
          "composition": {
            "type": "object",
            "required": ["enabled", "composition_rule_id", "target_class", "base_prediction_path", "base_prediction_sha256", "composition_output_sha256"],
            "properties": {
              "enabled": {"const": true},
              "composition_rule_id": {"enum": ["celeb_skin_nested_union_v1", "u_lip_dilate_exclusive_v1"]},
              "target_class": {"enum": ["skin", "u_lip"]},
              "union_sources": {"type": "array", "minItems": 9, "maxItems": 9, "items": {"type": "string"}},
              "base_prediction_path": {"type": "string", "minLength": 1},
              "base_prediction_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
              "composition_input_hashes": {
                "type": "object",
                "required": ["skin", "l_brow", "r_brow", "l_eye", "r_eye", "nose", "mouth", "u_lip", "l_lip"],
                "properties": {
                  "skin": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
                  "l_brow": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
                  "r_brow": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
                  "l_eye": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
                  "r_eye": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
                  "nose": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
                  "mouth": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
                  "u_lip": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
                  "l_lip": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}
                },
                "additionalProperties": false
              },
              "base_skin_sha256_preserved": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
              "composition_source_hashes": {
                "type": "object",
                "required": ["u_lip"],
                "properties": {
                  "u_lip": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}
                },
                "additionalProperties": false
              },
              "composition_exclusion_hashes": {
                "type": "object",
                "required": ["mouth", "l_lip"],
                "properties": {
                  "mouth": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
                  "l_lip": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}
                },
                "additionalProperties": false
              },
              "base_u_lip_sha256_preserved": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
              "fixed_parameters": {
                "type": "object",
                "required": ["operator", "kernel", "iterations", "exclude_from_new_pixels"],
                "properties": {
                  "operator": {"const": "binary_dilation"},
                  "kernel": {"const": "square_3x3"},
                  "iterations": {"const": 1},
                  "exclude_from_new_pixels": {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 2,
                    "prefixItems": [
                      {"const": "mouth"},
                      {"const": "l_lip"}
                    ]
                  }
                },
                "additionalProperties": false
              },
              "composition_output_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}
            },
            "allOf": [
              {
                "if": {"properties": {"composition_rule_id": {"const": "celeb_skin_nested_union_v1"}}},
                "then": {
                  "required": ["union_sources", "composition_input_hashes", "base_skin_sha256_preserved"],
                  "properties": {
                    "target_class": {"const": "skin"}
                  }
                }
              },
              {
                "if": {"properties": {"composition_rule_id": {"const": "u_lip_dilate_exclusive_v1"}}},
                "then": {
                  "required": ["composition_source_hashes", "composition_exclusion_hashes", "base_u_lip_sha256_preserved", "fixed_parameters"],
                  "properties": {
                    "target_class": {"const": "u_lip"}
                  }
                }
              }
            ],
            "additionalProperties": false
          },
          "transforms": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["op"],
              "properties": {
                "op": {"enum": ["identity", "resize", "pad", "crop", "horizontal_flip"]},
                "from_size": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}},
                "to_size": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}},
                "size": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}},
                "left": {"type": "integer", "minimum": 0},
                "top": {"type": "integer", "minimum": 0},
                "right": {"type": "integer", "minimum": 0},
                "bottom": {"type": "integer", "minimum": 0},
                "x": {"type": "integer", "minimum": 0},
                "y": {"type": "integer", "minimum": 0}
              },
              "allOf": [
                {"if": {"properties": {"op": {"const": "horizontal_flip"}}}, "then": {"required": ["size"]}},
                {"if": {"properties": {"op": {"enum": ["identity", "resize"]}}}, "then": {"required": ["from_size", "to_size"]}},
                {"if": {"properties": {"op": {"const": "pad"}}}, "then": {"required": ["from_size", "to_size", "left", "top", "right", "bottom"]}},
                {"if": {"properties": {"op": {"const": "crop"}}}, "then": {"required": ["from_size", "to_size", "x", "y"]}}
              ]
            }
          }
        }
      }
    }
  }
}
