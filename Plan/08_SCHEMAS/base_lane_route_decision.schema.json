{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Wave15 Base Lane Route Decision",
  "required": [
    "decision_id",
    "selected_lane_id",
    "decision_reasons"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "selected_lane_id": {
      "type": "string"
    },
    "fallback_lane_ids": {
      "type": "array"
    },
    "decision_reasons": {
      "type": "array"
    },
    "blocked_reasons": {
      "type": "array"
    }
  }
}
