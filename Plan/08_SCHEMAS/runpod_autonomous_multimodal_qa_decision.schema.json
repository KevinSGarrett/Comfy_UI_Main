{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RunPodAutonomousMultimodalQaDecision",
  "type": "object",
  "required": [
    "schema_version",
    "program_id",
    "job_id",
    "modality",
    "authority",
    "lineage",
    "measurements",
    "reviewers",
    "attempt_state",
    "blocking_defects",
    "decision",
    "rollback_parent_sha256",
    "promotion_claimed"
  ],
  "properties": {
    "schema_version": {"const": "wave64.aqa.decision.v1"},
    "program_id": {"const": "W64-AQA"},
    "job_id": {"type": "string", "minLength": 1},
    "modality": {"enum": ["image", "video", "audio", "av", "mask", "workflow"]},
    "authority": {
      "type": "object",
      "required": ["host", "pod_id", "ec2_forbidden", "fail_closed"],
      "properties": {
        "host": {"const": "runpod"},
        "pod_id": {"type": "string", "minLength": 1},
        "ec2_forbidden": {"const": true},
        "fail_closed": {"const": true}
      },
      "additionalProperties": true
    },
    "lineage": {
      "type": "object",
      "required": ["candidate_sha256", "workflow_sha256", "quality_contract_sha256"],
      "properties": {
        "candidate_sha256": {"$ref": "#/definitions/sha256"},
        "workflow_sha256": {"$ref": "#/definitions/sha256"},
        "quality_contract_sha256": {"$ref": "#/definitions/sha256"},
        "source_sha256": {"$ref": "#/definitions/nullable_sha256"}
      },
      "additionalProperties": true
    },
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["metric_id", "applicable", "passed", "implementation_version"],
        "properties": {
          "metric_id": {"type": "string", "minLength": 1},
          "applicable": {"type": "boolean"},
          "passed": {"type": "boolean"},
          "value": {},
          "threshold": {},
          "implementation_version": {"type": "string", "minLength": 1},
          "evidence_sha256": {"$ref": "#/definitions/nullable_sha256"}
        },
        "additionalProperties": true
      }
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role_id", "state", "product_authority", "response_valid"],
        "properties": {
          "role_id": {"type": "string", "pattern": "^W64-AQA-ROLE-"},
          "state": {"type": "string", "minLength": 1},
          "model": {"type": ["string", "null"]},
          "digest": {"type": ["string", "null"]},
          "calibration_id": {"type": ["string", "null"]},
          "product_authority": {"type": "boolean"},
          "response_valid": {"type": "boolean"},
          "observation_sha256": {"$ref": "#/definitions/nullable_sha256"}
        },
        "additionalProperties": true
      }
    },
    "attempt_state": {
      "type": "object",
      "required": ["defect_attempt", "total_generation_attempt", "consecutive_no_progress", "ceilings"],
      "properties": {
        "defect_attempt": {"type": "integer", "minimum": 0, "maximum": 2},
        "total_generation_attempt": {"type": "integer", "minimum": 1, "maximum": 4},
        "consecutive_no_progress": {"type": "integer", "minimum": 0, "maximum": 2},
        "ceilings": {
          "type": "object",
          "required": ["per_defect", "total_generation", "no_progress"],
          "properties": {
            "per_defect": {"const": 2},
            "total_generation": {"const": 4},
            "no_progress": {"const": 2}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "blocking_defects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "detail"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "severity": {"enum": ["blocking", "major", "minor"]},
          "detail": {"type": "string", "minLength": 1},
          "locator": {"type": ["string", "null"]}
        },
        "additionalProperties": true
      }
    },
    "decision": {"enum": ["PASS", "REPAIR", "REJECT", "BLOCKED", "HUMAN_EXCEPTION_REQUIRED"]},
    "workflow_patch": {
      "type": ["object", "null"],
      "properties": {
        "accepted_workflow_sha256": {"$ref": "#/definitions/nullable_sha256"},
        "candidate_workflow_sha256": {"$ref": "#/definitions/nullable_sha256"},
        "patch_sha256": {"$ref": "#/definitions/nullable_sha256"},
        "static_validation_passed": {"type": "boolean"},
        "sandbox_validation_passed": {"type": "boolean"},
        "regression_passed": {"type": "boolean"},
        "promotion_authorized": {"const": false}
      },
      "additionalProperties": true
    },
    "rollback_parent_sha256": {"$ref": "#/definitions/nullable_sha256"},
    "promotion_claimed": {"const": false},
    "cost_usd": {"type": ["number", "null"], "minimum": 0},
    "runtime_receipt_sha256": {"$ref": "#/definitions/nullable_sha256"}
  },
  "additionalProperties": false,
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nullable_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
  }
}
