{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave12 Merged Body Detection Report",
  "type": "object",
  "required": [
    "merged_body_detected",
    "unassigned_body_fragments",
    "instance_separation_pass"
  ],
  "properties": {
    "merged_body_detected": {
      "type": "boolean"
    },
    "merged_body_regions": {
      "type": "array"
    },
    "unassigned_body_fragments": {
      "type": "integer"
    },
    "instance_separation_pass": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
