{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave26 Reference Video Frame Manifest Record",
  "type": "object",
  "required": [
    "source_video_id",
    "frame_id",
    "frame_index",
    "timestamp_seconds",
    "frame_path_or_asset_id",
    "width",
    "height",
    "qa_status"
  ],
  "properties": {
    "source_video_id": {
      "type": "string"
    },
    "frame_id": {
      "type": "string"
    },
    "frame_index": {
      "type": "integer"
    },
    "timestamp_seconds": {
      "type": "number"
    },
    "frame_path_or_asset_id": {
      "type": "string"
    },
    "width": {
      "type": "integer"
    },
    "height": {
      "type": "integer"
    },
    "pose_state_id": {
      "type": "string"
    },
    "depth_state_id": {
      "type": "string"
    },
    "mask_state_id": {
      "type": "string"
    },
    "contact_state_id": {
      "type": "string"
    },
    "qa_status": {
      "type": "string"
    }
  }
}
