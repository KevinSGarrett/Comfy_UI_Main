{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lens_profile.schema.json",
  "title": "Lens Profile",
  "type": "object",
  "required": [
    "id",
    "focal_length_mm",
    "look",
    "best_for",
    "risk"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "focal_length_mm": {
      "type": "number"
    },
    "look": {
      "type": "string"
    },
    "best_for": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_subject_distance": {
      "type": "string"
    }
  }
}
