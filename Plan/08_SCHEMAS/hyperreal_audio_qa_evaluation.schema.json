{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-audio-qa-evaluation/1.0.0",
  "title": "Hyperreal Audio QA Evaluation",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "audio_qa_evaluation_id",
    "revision",
    "status",
    "created_at",
    "scope",
    "artifact_ref",
    "stem_manifest_ref",
    "evaluated_span",
    "metric_results",
    "defects",
    "critic_observation_refs",
    "listening_review_ref",
    "decision",
    "uncertainty",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_audio_qa_evaluation"
    },
    "audio_qa_evaluation_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "scope": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ExecutionScope"
    },
    "artifact_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "stem_manifest_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
    },
    "evaluated_span": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/MediaSpan"
    },
    "metric_results": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/MetricResult"
      },
      "minItems": 1
    },
    "defects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "defect_id",
          "defect_class",
          "severity",
          "span",
          "owner",
          "evidence_ref"
        ],
        "properties": {
          "defect_id": {
            "type": "string",
            "minLength": 1
          },
          "defect_class": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": [
              "info",
              "minor",
              "major",
              "critical"
            ]
          },
          "span": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/MediaSpan"
          },
          "owner": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/OwnerRef"
          },
          "evidence_ref": {
            "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
          }
        },
        "additionalProperties": false
      }
    },
    "critic_observation_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "listening_review_ref": {
      "oneOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "decision": {
      "enum": [
        "accept",
        "repair",
        "reroute",
        "reject",
        "human_review"
      ]
    },
    "uncertainty": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
