{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wave20 HardAnatomyRepairContract",
  "type": "object",
  "required": [
    "contract_version",
    "source_image_id",
    "repair_regions",
    "crop_plans",
    "qa_goals"
  ],
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "source_image_id": {
      "type": "string"
    },
    "character_id": {
      "type": "string"
    },
    "repair_regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "crop_plans": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "qa_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "global_preservation_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
