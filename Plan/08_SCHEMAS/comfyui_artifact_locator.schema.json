{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/comfyui-artifact-locator/1.0.0",
  "title": "Wave64 ComfyUI Artifact Locator",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "artifact_locator_id",
    "revision",
    "status",
    "created_at",
    "scheme",
    "runtime_id",
    "folder_root_id",
    "folder_type",
    "subfolder",
    "filename",
    "node_id",
    "output_slot",
    "view_parameters",
    "bytes",
    "sha256",
    "media_type",
    "cas_artifact_id",
    "s3_object_version_id",
    "absolute_path_allowed",
    "path_traversal_allowed",
    "verified_at",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "comfyui_artifact_locator"
    },
    "artifact_locator_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "scheme": {
      "enum": [
        "comfyui_output",
        "cas",
        "s3"
      ]
    },
    "runtime_id": {
      "type": "string",
      "minLength": 1
    },
    "folder_root_id": {
      "type": "string",
      "minLength": 1
    },
    "folder_type": {
      "enum": [
        "input",
        "output",
        "temp",
        "cas",
        "s3"
      ]
    },
    "subfolder": {
      "type": "string",
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
    },
    "filename": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*[\\\\/])(?!\\.\\.?$).+$"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "output_slot": {
      "type": "integer",
      "minimum": 0
    },
    "view_parameters": {
      "type": "object",
      "required": [
        "filename",
        "subfolder",
        "type"
      ],
      "properties": {
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "subfolder": {
          "type": "string",
          "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
        },
        "type": {
          "enum": [
            "input",
            "output",
            "temp"
          ]
        }
      },
      "additionalProperties": false
    },
    "bytes": {
      "type": "integer",
      "minimum": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "media_type": {
      "type": "string",
      "minLength": 1
    },
    "cas_artifact_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "s3_object_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "absolute_path_allowed": {
      "const": false
    },
    "path_traversal_allowed": {
      "const": false
    },
    "verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
