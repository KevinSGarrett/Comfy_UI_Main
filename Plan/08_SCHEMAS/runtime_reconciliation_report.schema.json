{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/runtime-reconciliation-report/1.0.0",
  "title": "Wave64 Runtime Reconciliation Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "runtime_reconciliation_report_id",
    "revision",
    "status",
    "created_at",
    "submission_envelope_ref",
    "execution_receipt_refs",
    "outbox_state",
    "event_store_state",
    "runtime_observations",
    "classification",
    "selected_action",
    "reason_codes",
    "comfyui_queue_history_authority",
    "durable_event_store_authority",
    "ambiguous_attempt_cross_host_failover_allowed",
    "promotion_exactly_once",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "runtime_reconciliation_report"
    },
    "runtime_reconciliation_report_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "submission_envelope_ref": {
      "allOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "object",
          "properties": {
            "record_type": {
              "const": "comfyui_submission_envelope"
            }
          },
          "required": [
            "record_type"
          ]
        }
      ]
    },
    "execution_receipt_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
      }
    },
    "outbox_state": {
      "type": "string",
      "minLength": 1
    },
    "event_store_state": {
      "type": "string",
      "minLength": 1
    },
    "runtime_observations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source",
          "snapshot_sha256",
          "observed_state"
        ],
        "properties": {
          "source": {
            "enum": [
              "jobs",
              "queue",
              "history",
              "files",
              "cas"
            ]
          },
          "snapshot_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "observed_state": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "classification": {
      "enum": [
        "not_submitted",
        "pending",
        "running",
        "terminal_consistent",
        "orphaned",
        "duplicate",
        "ambiguous"
      ]
    },
    "selected_action": {
      "enum": [
        "submit",
        "observe",
        "collect_outputs",
        "cancel_targeted",
        "retry_same_runtime",
        "repair_new_attempt",
        "block_no_failover",
        "quarantine_duplicate",
        "promote_once",
        "no_action"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "comfyui_queue_history_authority": {
      "const": "observation_only"
    },
    "durable_event_store_authority": {
      "const": true
    },
    "ambiguous_attempt_cross_host_failover_allowed": {
      "const": false
    },
    "promotion_exactly_once": {
      "const": true
    }
  },
  "additionalProperties": false
}
