{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/audio_component_adapter_record.schema.json",
  "title": "Wave64 Row111 Audio Component Adapter Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "component_id", "capability", "source_path", "source_sha256",
    "source_bytes", "disposition", "adapter_contract", "authority_ceiling",
    "limitations", "completed_proof_guard"
  ],
  "properties": {
    "component_id": {"type": "string", "pattern": "^W64-AUD-COMP-[0-9]{2}$"},
    "capability": {"type": "string", "minLength": 1},
    "source_path": {"type": "string", "pattern": "^Plan/07_IMPLEMENTATION/scripts/[A-Za-z0-9_]+\\.py$"},
    "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_bytes": {"type": "integer", "minimum": 1},
    "disposition": {"enum": ["reuse_direct", "adapt_once", "evidence_only_hold", "replace_with_reason"]},
    "adapter_contract": {"type": ["string", "null"]},
    "authority_ceiling": {"enum": ["structural", "candidate", "technical_qa", "production"]},
    "limitations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "completed_proof_guard": {"const": true}
  }
}
