{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave26 Reference Video Manifest",
  "type": "object",
  "required": [
    "source_video_id",
    "file_extension",
    "duration_seconds",
    "fps",
    "frame_count",
    "width",
    "height",
    "extraction_profile_id"
  ],
  "properties": {
    "source_video_id": {
      "type": "string"
    },
    "original_path_or_asset_id": {
      "type": "string"
    },
    "file_extension": {
      "type": "string"
    },
    "container_format": {
      "type": "string"
    },
    "duration_seconds": {
      "type": "number"
    },
    "fps": {
      "type": "number"
    },
    "frame_count": {
      "type": "integer"
    },
    "width": {
      "type": "integer"
    },
    "height": {
      "type": "integer"
    },
    "audio_present": {
      "type": "boolean"
    },
    "fingerprint": {
      "type": "string"
    },
    "extraction_profile_id": {
      "type": "string"
    }
  }
}
