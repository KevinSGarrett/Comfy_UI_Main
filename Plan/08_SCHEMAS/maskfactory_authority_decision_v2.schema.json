{
  "$id": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/maskfactory_authority_decision_v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "fixture_only": {
            "const": true
          }
        },
        "required": [
          "fixture_only"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "enum": [
              "diagnostic_only",
              "blocked"
            ]
          },
          "eligible_for_intended_use": {
            "const": false
          },
          "genuine_runtime_evidence_refs": {
            "maxItems": 0
          },
          "intended_use": {
            "not": {
              "const": "promotion_bound"
            }
          },
          "observed_authority": {
            "properties": {
              "authority_state": {
                "not": {
                  "const": "certified"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "eligible_for_intended_use": {
            "const": true
          }
        },
        "required": [
          "eligible_for_intended_use"
        ]
      },
      "then": {
        "properties": {
          "blockers": {
            "maxItems": 0
          },
          "criterion_evaluations": {
            "items": {
              "properties": {
                "status": {
                  "const": "pass"
                }
              }
            }
          },
          "decision": {
            "const": "eligible"
          },
          "genuine_runtime_evidence_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "eligible"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "eligible_for_intended_use": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "enum": [
              "diagnostic_only",
              "blocked"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "eligible_for_intended_use": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "eligible_for_intended_use": {
            "const": true
          },
          "required_authority_state": {
            "const": "certified"
          }
        },
        "required": [
          "eligible_for_intended_use",
          "required_authority_state"
        ]
      },
      "then": {
        "properties": {
          "certificate_signature_trust": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/signing_trust_verification",
            "properties": {
              "trust_result": {
                "const": "trusted"
              }
            }
          },
          "certificate_temporal_evaluation": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/certificate_temporal_evaluation",
            "properties": {
              "temporal_decision": {
                "const": "valid"
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "access_mode": {
      "enum": [
        "mode_a_package_read",
        "mode_b_live_predict",
        "mode_b_live_refine"
      ]
    },
    "blockers": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/blocker"
      },
      "type": "array"
    },
    "certificate_signature_trust": {
      "oneOf": [
        {
          "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/signing_trust_verification"
        },
        {
          "type": "null"
        }
      ]
    },
    "certificate_temporal_evaluation": {
      "oneOf": [
        {
          "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/certificate_temporal_evaluation"
        },
        {
          "type": "null"
        }
      ]
    },
    "consumer_policy_ref": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
    },
    "consumer_policy_sha256": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/sha256"
    },
    "created_at": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/timestamp"
    },
    "criterion_evaluations": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "comparator": {
            "enum": [
              "gte",
              "lte",
              "eq",
              "boolean_true",
              "no_blockers"
            ]
          },
          "criterion_id": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
          },
          "evidence_ref": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
          },
          "observed": {
            "type": [
              "number",
              "integer",
              "boolean",
              "string"
            ]
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "blocked"
            ]
          },
          "threshold": {
            "type": [
              "number",
              "integer",
              "boolean",
              "string"
            ]
          }
        },
        "required": [
          "criterion_id",
          "comparator",
          "threshold",
          "observed",
          "status",
          "evidence_ref"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "crosswalk_rule_id": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "decision": {
      "enum": [
        "eligible",
        "diagnostic_only",
        "blocked"
      ]
    },
    "decision_at": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/timestamp"
    },
    "decision_evidence_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "minItems": 1,
      "type": "array"
    },
    "eligible_for_intended_use": {
      "type": "boolean"
    },
    "fixture_only": {
      "type": "boolean"
    },
    "genuine_runtime_evidence_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "type": "array",
      "uniqueItems": true
    },
    "intended_use": {
      "enum": [
        "diagnostic",
        "preview",
        "repair",
        "promotion_bound"
      ]
    },
    "maskfactory_authority_decision_v2_id": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "observed_authority": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/authority"
    },
    "record_type": {
      "const": "maskfactory_authority_decision_v2"
    },
    "required_authority_state": {
      "enum": [
        "invalid",
        "hypothesis",
        "draft",
        "qa_passed_noncertified",
        "certified"
      ]
    },
    "required_certificate_scope": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
      },
      "type": "array",
      "uniqueItems": true
    },
    "required_claim_classes": {
      "items": {
        "enum": [
          "invalid",
          "machine_candidate",
          "qa_passed_machine_candidate",
          "operationally_certified_artifact",
          "independent_real_accuracy_anchor",
          "training_gold"
        ]
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "required_issuer_kinds": {
      "items": {
        "enum": [
          "maskfactory_autonomous",
          "human_anchor_optional",
          "none"
        ]
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "result_ref": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
    },
    "revision": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "runtime_completion_claimed": {
      "const": false
    },
    "schema_version": {
      "const": "2.0.0"
    }
  },
  "required": [
    "schema_version",
    "record_type",
    "maskfactory_authority_decision_v2_id",
    "revision",
    "created_at",
    "fixture_only",
    "runtime_completion_claimed",
    "result_ref",
    "access_mode",
    "observed_authority",
    "required_authority_state",
    "required_issuer_kinds",
    "required_claim_classes",
    "required_certificate_scope",
    "intended_use",
    "decision",
    "eligible_for_intended_use",
    "decision_at",
    "certificate_temporal_evaluation",
    "certificate_signature_trust",
    "decision_evidence_refs",
    "genuine_runtime_evidence_refs",
    "consumer_policy_ref",
    "consumer_policy_sha256",
    "criterion_evaluations",
    "crosswalk_rule_id",
    "blockers"
  ],
  "title": "maskfactory_authority_decision_v2",
  "type": "object"
}
