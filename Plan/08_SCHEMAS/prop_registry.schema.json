{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave09 Prop Registry",
  "type": "object",
  "required": [
    "prop_registry_id",
    "props"
  ],
  "properties": {
    "prop_registry_id": {
      "type": "string"
    },
    "props": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "prop_id",
          "prop_type",
          "anchor_id"
        ]
      }
    }
  },
  "additionalProperties": true
}
