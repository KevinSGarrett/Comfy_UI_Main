{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/runpod_sole_production_platform_policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "program_id", "policy_id", "status", "active_platform", "runpod", "guarded_migration_watcher", "local", "legacy_cloud", "execution_rules", "tracker_reclassification", "evidence_policy", "authority"],
  "properties": {
    "schema_version": {"const": "wave64.runpod_sole_production_platform_policy.v1"},
    "program_id": {"const": "W64-AQA"},
    "policy_id": {"const": "W64-RUNPOD-SOLE-PRODUCTION-20260722"},
    "status": {"const": "RUNPOD_SOLE_ACTIVE_PRODUCTION_LOCAL_AND_CURRENT_RUNPOD_ONLY"},
    "active_platform": {"const": "RUNPOD"},
    "runpod": {
      "type": "object", "additionalProperties": false,
      "required": ["pod_id", "project", "production_runtime", "production_storage", "gpu_coordinator_required", "foreign_hold_override_forbidden"],
      "properties": {
        "pod_id": {"const": "1q4ji0gg1fkhvt"}, "project": {"const": "comfyui_main"},
        "production_runtime": {"const": true}, "production_storage": {"const": true},
        "gpu_coordinator_required": {"const": true}, "foreign_hold_override_forbidden": {"const": true}
      }
    },
    "guarded_migration_watcher": {
      "type": "object", "additionalProperties": false,
      "required": ["automation_id", "status", "interval_minutes", "region", "cloud_type", "gpu_type", "gpu_count", "maximum_total_hourly_usd", "network_volume_id", "candidate_container_disk_gb", "competing_watcher_forbidden", "independent_project_migration_forbidden", "current_pod_authoritative_until_verified_migration_complete", "old_pod_stop_requires_candidate_volume_disk_dual_gpu_coordinator_and_rollback_checks", "aws_access", "pod_termination"],
      "properties": {
        "automation_id": {"const": "runpod-us-wa-1-2xa40-guarded-migration-watcher"},
        "status": {"const": "ACTIVE_USER_AUTHORIZED_SINGLETON"},
        "interval_minutes": {"const": 10}, "region": {"const": "US-WA-1"},
        "cloud_type": {"const": "SECURE_CLOUD"}, "gpu_type": {"const": "NVIDIA A40"},
        "gpu_count": {"const": 2}, "maximum_total_hourly_usd": {"const": 0.70},
        "network_volume_id": {"const": "o9qv2ld91c"}, "candidate_container_disk_gb": {"const": 100},
        "competing_watcher_forbidden": {"const": true}, "independent_project_migration_forbidden": {"const": true},
        "current_pod_authoritative_until_verified_migration_complete": {"const": true},
        "old_pod_stop_requires_candidate_volume_disk_dual_gpu_coordinator_and_rollback_checks": {"const": true},
        "aws_access": {"const": false}, "pod_termination": {"const": false}
      }
    },
    "local": {
      "type": "object", "additionalProperties": false,
      "required": ["cpu_only_work_allowed_without_lease", "repository_work_allowed", "evidence_validation_allowed"],
      "properties": {"cpu_only_work_allowed_without_lease": {"const": true}, "repository_work_allowed": {"const": true}, "evidence_validation_allowed": {"const": true}}
    },
    "legacy_cloud": {
      "type": "object", "additionalProperties": false,
      "required": ["platforms", "classification", "active_production_blocker", "automatic_access_allowed", "explicit_user_authorization_categories"],
      "properties": {
        "platforms": {"const": ["AWS", "S3", "EC2"]},
        "classification": {"const": "HISTORICAL_MIGRATION_EVIDENCE_AUDIT_ONLY"},
        "active_production_blocker": {"const": false}, "automatic_access_allowed": {"const": false},
        "explicit_user_authorization_categories": {"const": ["archival", "recovery", "cost", "shutdown", "reconciliation"]}
      }
    },
    "execution_rules": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"type": "string"}},
    "tracker_reclassification": {
      "type": "object", "additionalProperties": false,
      "required": ["tracker_id", "classification", "required_for_runpod_production", "next_action"],
      "properties": {
        "tracker_id": {"const": "W64-AQA-012"}, "classification": {"const": "LEGACY_AWS_EVIDENCE_LINEAGE_RETAINED_AUDIT_ONLY"},
        "required_for_runpod_production": {"const": false}, "next_action": {"const": "NONE_UNLESS_EXPLICIT_USER_AUTHORIZATION"}
      }
    },
    "evidence_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["retain_existing_aws_s3_ec2_evidence", "delete_existing_evidence", "rerun_existing_evidence", "reinterpret_as_runpod_authority"],
      "properties": {
        "retain_existing_aws_s3_ec2_evidence": {"const": true}, "delete_existing_evidence": {"const": false},
        "rerun_existing_evidence": {"const": false}, "reinterpret_as_runpod_authority": {"const": false}
      }
    },
    "authority": {
      "type": "object", "additionalProperties": false,
      "required": ["platform_selection", "runpod_production", "aws_production", "s3_production", "ec2_production", "gpu_runtime", "product_promotion"],
      "properties": {
        "platform_selection": {"const": true}, "runpod_production": {"const": true},
        "aws_production": {"const": false}, "s3_production": {"const": false}, "ec2_production": {"const": false},
        "gpu_runtime": {"const": false}, "product_promotion": {"const": false}
      }
    }
  }
}
