{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/model-drift-event/1.0.0",
  "title": "Wave64 Model Drift Event",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "drift_event_id",
    "revision",
    "status",
    "created_at",
    "drift_type",
    "changed_refs",
    "baseline_snapshot_id",
    "observed_snapshot_id",
    "affected_certificate_ids",
    "affected_route_ids",
    "severity",
    "required_action",
    "evidence",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "model_drift_event"
    },
    "drift_event_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "drift_type": {
      "enum": [
        "model_hash",
        "component",
        "workflow",
        "runtime",
        "prompt_template",
        "reviewer",
        "data",
        "metric",
        "workload"
      ]
    },
    "changed_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
      },
      "minItems": 1
    },
    "baseline_snapshot_id": {
      "type": "string"
    },
    "observed_snapshot_id": {
      "type": "string"
    },
    "affected_certificate_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_route_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity": {
      "enum": [
        "info",
        "caution",
        "suspend",
        "revoke"
      ]
    },
    "required_action": {
      "enum": [
        "monitor",
        "rebenchmark",
        "suspend",
        "revoke",
        "rollback"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/EvidenceRef"
      }
    }
  },
  "additionalProperties": false
}
