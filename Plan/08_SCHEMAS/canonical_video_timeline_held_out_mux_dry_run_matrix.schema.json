{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/canonical-video-timeline-held-out-mux-dry-run-matrix/1.0.0",
  "title": "Wave64 Canonical Video Timeline Held-Out Mux Dry-Run Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "matrix_id",
    "revision",
    "status",
    "created_at",
    "cases",
    "summary",
    "authority",
    "production_completion_allowed",
    "row_complete",
    "matrix_sha256",
    "provenance"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": {
      "const": "canonical_video_timeline_held_out_mux_dry_run_matrix"
    },
    "matrix_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["fixture_mux_dry_run_partial", "blocked"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "cases": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "partition",
          "timeline_id",
          "timeline_sha256",
          "frame_rate_mode",
          "checked_frame_count",
          "within_tolerance",
          "audio_stream_binding",
          "container_binding",
          "stream_identities_bound",
          "mux_command_planned",
          "mux_command_executed",
          "dry_run_mux_plan_sha256",
          "dry_run_hash_deterministic",
          "row_complete"
        ],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "partition": { "const": "held_out" },
          "timeline_id": { "type": "string", "minLength": 1 },
          "timeline_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "frame_rate_mode": { "enum": ["fixed", "fractional", "vfr"] },
          "checked_frame_count": { "type": "integer", "minimum": 1 },
          "within_tolerance": { "type": "boolean" },
          "audio_stream_binding": { "type": "string", "minLength": 1 },
          "container_binding": { "type": "string", "minLength": 1 },
          "stream_identities_bound": { "const": true },
          "mux_command_planned": { "const": true },
          "mux_command_executed": { "const": false },
          "dry_run_mux_plan_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "dry_run_hash_deterministic": { "const": true },
          "row_complete": { "const": false }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_count",
        "passed_count",
        "failed_count",
        "all_within_tolerance",
        "modes_covered",
        "stream_identities_bound",
        "dry_run_mux_hash_check_passed",
        "mux_replay_included",
        "runtime_media_decode_invoked",
        "benchmark_authority_granted",
        "visual_review_authority_granted"
      ],
      "properties": {
        "case_count": { "type": "integer", "minimum": 2 },
        "passed_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "all_within_tolerance": { "type": "boolean" },
        "modes_covered": {
          "type": "array",
          "items": { "enum": ["fixed", "fractional", "vfr"] },
          "minItems": 1,
          "uniqueItems": true
        },
        "stream_identities_bound": { "const": true },
        "dry_run_mux_hash_check_passed": { "type": "boolean" },
        "mux_replay_included": { "const": false },
        "runtime_media_decode_invoked": { "const": false },
        "benchmark_authority_granted": { "const": false },
        "visual_review_authority_granted": { "const": false }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_matrix_only",
        "dry_run_plan_only",
        "fixed_vfr_benchmark_pass",
        "mux_replay_proof_present",
        "combined_visual_review_present"
      ],
      "properties": {
        "fixture_matrix_only": { "const": true },
        "dry_run_plan_only": { "const": true },
        "fixed_vfr_benchmark_pass": { "const": false },
        "mux_replay_proof_present": { "const": false },
        "combined_visual_review_present": { "const": false }
      }
    },
    "production_completion_allowed": { "const": false },
    "row_complete": { "const": false },
    "matrix_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
