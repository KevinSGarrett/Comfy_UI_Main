    "character_id",
    "character_version",
    "status",
    "voice_traits"
  ],
  "properties": {
    "voice_profile_id": {
      "type": "string"
    },
    "character_id": {
      "type": "string"
    },
    "character_version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "voice_source_class": {
      "type": "string"
    },
    "voice_traits": {
      "type": "object"
    },
    "reference_audio_manifest": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "qa_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
