    "from_state": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "to_state": {
      "type": "string",
      "minLength": 1
    },
    "payload_schema_id": {
      "type": "string",
      "minLength": 1
    },
