{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wave22 OcclusionContactReport",
  "type": "object",
  "required": [
    "edge_id",
    "occlusion_pass",
    "contact_shadow_pass"
  ],
  "properties": {
    "edge_id": {
      "type": "string"
    },
    "occlusion_pass": {
      "type": "boolean"
    },
    "contact_shadow_pass": {
      "type": "boolean"
    },
    "failure_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
