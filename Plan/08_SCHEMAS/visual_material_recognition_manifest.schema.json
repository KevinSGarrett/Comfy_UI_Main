{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/visual_material_recognition_manifest.schema.json",
  "title": "Visual Material Recognition Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "manifest_id",
    "revision",
    "run_id",
    "scene_id",
    "shot_id",
    "take_id",
    "is_synthetic",
    "video_sha256",
    "created_at",
    "status",
    "timeline_binding",
    "scene_registry_binding",
    "classifier_stack",
    "dependency_authority",
    "runtime_authority",
    "taxonomy",
    "material_decisions",
    "metrics",
    "thresholds",
    "threshold_violations",
    "authority_summary",
    "authority_ceiling",
    "production_completion_allowed",
    "row_complete",
    "provenance",
    "manifest_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "visual_material_recognition_manifest"},
    "manifest_id": {"type": "string", "minLength": 1},
    "revision": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "scene_id": {"type": "string", "minLength": 1},
    "shot_id": {"type": "string", "minLength": 1},
    "take_id": {"type": "string", "minLength": 1},
    "is_synthetic": {"type": "boolean"},
    "video_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "created_at": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["candidate_hold", "technical_partial", "blocked"]
    },
    "timeline_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeline_id",
        "timeline_sha256",
        "frame_count",
        "frame_rate",
        "frame_time_origin_seconds"
      ],
      "properties": {
        "timeline_id": {"type": "string", "minLength": 1},
        "timeline_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "frame_count": {"type": "integer", "minimum": 1},
        "frame_rate": {"type": "number", "exclusiveMinimum": 0},
        "frame_time_origin_seconds": {"type": "number"}
      }
    },
    "scene_registry_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_registry_id",
        "scene_registry_sha256",
        "frame_span_id",
        "entity_region_count"
      ],
      "properties": {
        "scene_registry_id": {"type": "string", "minLength": 1},
        "scene_registry_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "frame_span_id": {"type": "string", "minLength": 1},
        "entity_region_count": {"type": "integer", "minimum": 1}
      }
    },
    "classifier_stack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classifier_id",
        "weights_sha256",
        "preprocessing_sha256",
        "class_map_sha256",
        "revision"
      ],
      "properties": {
        "classifier_id": {"type": "string", "minLength": 1},
        "weights_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "preprocessing_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "class_map_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "revision": {"type": "string", "minLength": 1}
      }
    },
    "dependency_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["row085_complete", "row088_complete", "dependency_ready"],
      "properties": {
        "row085_complete": {"type": "boolean"},
        "row088_complete": {"type": "boolean"},
        "dependency_ready": {"type": "boolean"}
      }
    },
    "runtime_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "material_benchmark_pass",
        "runtime_receipt_present",
        "combined_frame_contact_audio_review_present",
        "runtime_ready"
      ],
      "properties": {
        "material_benchmark_pass": {"type": "boolean"},
        "runtime_receipt_present": {"type": "boolean"},
        "combined_frame_contact_audio_review_present": {"type": "boolean"},
        "runtime_ready": {"type": "boolean"}
      }
    },
    "taxonomy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_material_classes",
        "governed_aliases",
        "broader_class_map"
      ],
      "properties": {
        "required_material_classes": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "string",
            "enum": [
              "hardwood",
              "carpet",
              "tile",
              "skin",
              "fabric",
              "leather",
              "metal",
              "glass"
            ]
          }
        },
        "governed_aliases": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "hardwood",
              "carpet",
              "tile",
              "skin",
              "fabric",
              "leather",
              "metal",
              "glass"
            ]
          }
        },
        "broader_class_map": {
          "type": "object",
          "additionalProperties": {"type": "string", "minLength": 1}
        }
      }
    },
    "material_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/material_decision"}
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_count",
        "observed_class_count",
        "broader_class_count",
        "abstention_count",
        "disagreement_count",
        "contact_region_count",
        "required_classes_covered",
        "required_class_coverage_count"
      ],
      "properties": {
        "decision_count": {"type": "integer", "minimum": 0},
        "observed_class_count": {"type": "integer", "minimum": 0},
        "broader_class_count": {"type": "integer", "minimum": 0},
        "abstention_count": {"type": "integer", "minimum": 0},
        "disagreement_count": {"type": "integer", "minimum": 0},
        "contact_region_count": {"type": "integer", "minimum": 0},
        "required_classes_covered": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "required_class_coverage_count": {"type": "integer", "minimum": 0}
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_class_confidence",
        "min_agreeing_independent_sources",
        "max_abstention_ratio",
        "min_texture_quality"
      ],
      "properties": {
        "min_class_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "min_agreeing_independent_sources": {"type": "integer", "minimum": 2},
        "max_abstention_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "min_texture_quality": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "threshold_violations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "authority_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "material_certification_allowed",
        "unsupported_material_claims",
        "hold_reasons"
      ],
      "properties": {
        "material_certification_allowed": {"type": "boolean"},
        "unsupported_material_claims": {"type": "boolean"},
        "hold_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "authority_ceiling": {
      "type": "string",
      "enum": ["candidate", "technical", "certification"]
    },
    "production_completion_allowed": {"type": "boolean"},
    "row_complete": {"type": "boolean"},
    "provenance": {"type": "object"},
    "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "$defs": {
    "material_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "frame_index",
        "pts",
        "owner_id",
        "track_id",
        "region_id",
        "region_kind",
        "observed_class",
        "broader_class",
        "decision_state",
        "confidence",
        "ambiguity",
        "abstention_reason",
        "evidence_sources",
        "texture_evidence",
        "contact_context",
        "fusion"
      ],
      "properties": {
        "decision_id": {"type": "string", "minLength": 1},
        "frame_index": {"type": "integer", "minimum": 0},
        "pts": {"type": "integer", "minimum": 0},
        "owner_id": {"type": "string", "minLength": 1},
        "track_id": {"type": "string", "minLength": 1},
        "region_id": {"type": "string", "minLength": 1},
        "region_kind": {
          "type": "string",
          "enum": [
            "surface",
            "object",
            "clothing_region",
            "contact_region",
            "skin_region"
          ]
        },
        "observed_class": {
          "type": ["string", "null"],
          "enum": [
            "hardwood",
            "carpet",
            "tile",
            "skin",
            "fabric",
            "leather",
            "metal",
            "glass",
            null
          ]
        },
        "broader_class": {
          "type": ["string", "null"],
          "enum": [
            "hard_floor",
            "soft_floor",
            "textile",
            "organic_surface",
            "rigid_object",
            "unknown_material",
            null
          ]
        },
        "decision_state": {
          "type": "string",
          "enum": ["observed_class", "broader_class", "abstain"]
        },
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "ambiguity": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "unsupported"]
        },
        "abstention_reason": {"type": ["string", "null"]},
        "evidence_sources": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/evidence_source"}
        },
        "texture_evidence": {"$ref": "#/$defs/texture_evidence"},
        "contact_context": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/contact_context"}
          ]
        },
        "fusion": {"$ref": "#/$defs/fusion"}
      }
    },
    "evidence_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source_id", "observation_sha256", "supports_class"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "scene_registry",
            "material_classifier",
            "texture_evidence",
            "contact_context"
          ]
        },
        "source_id": {"type": "string", "minLength": 1},
        "observation_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "supports_class": {
          "type": "string",
          "enum": [
            "hardwood",
            "carpet",
            "tile",
            "skin",
            "fabric",
            "leather",
            "metal",
            "glass"
          ]
        }
      }
    },
    "texture_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feature_digest_sha256",
        "resolution_px",
        "crop_authority",
        "quality_score"
      ],
      "properties": {
        "feature_digest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "resolution_px": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"type": "integer", "minimum": 1}
        },
        "crop_authority": {"type": "string", "minLength": 1},
        "quality_score": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "contact_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contact_id",
        "source_owner_id",
        "target_owner_id",
        "ownership_state"
      ],
      "properties": {
        "contact_id": {"type": "string", "minLength": 1},
        "source_owner_id": {"type": "string", "minLength": 1},
        "target_owner_id": {"type": "string", "minLength": 1},
        "ownership_state": {
          "type": "string",
          "enum": ["trusted", "candidate", "unknown", "absent"]
        }
      }
    },
    "fusion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "independent_source_count",
        "agreeing_source_count",
        "disagreement",
        "fusion_rule"
      ],
      "properties": {
        "independent_source_count": {"type": "integer", "minimum": 1},
        "agreeing_source_count": {"type": "integer", "minimum": 0},
        "disagreement": {"type": "boolean"},
        "fusion_rule": {"type": "string", "minLength": 1}
      }
    }
  }
}
