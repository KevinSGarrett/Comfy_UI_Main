{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave24 Instance Layout Evidence",
  "type": "object",
  "required": [
    "evidence_version",
    "checks"
  ],
  "properties": {
    "evidence_version": {
      "type": "string"
    },
    "checks": {
      "type": "object"
    },
    "score": {
      "type": "number"
    },
    "pass": {
      "type": "boolean"
    },
    "failure_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
