{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mask Module Contract",
  "type": "object",
  "required": [
    "module_id",
    "purpose",
    "inputs",
    "outputs"
  ],
  "properties": {
    "module_id": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_runtime_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
