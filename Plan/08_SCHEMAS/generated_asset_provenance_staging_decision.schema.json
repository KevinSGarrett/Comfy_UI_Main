{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/generated_asset_provenance_staging_decision.schema.json",
  "title": "Wave64 Row102 Generated Asset Provenance Staging Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tracker_id",
    "item_id",
    "record_type",
    "evaluator_revision",
    "policy_revision",
    "policy_sha256",
    "candidate_id",
    "is_synthetic",
    "library_authority",
    "selector_visible",
    "dependency_admissions",
    "required_gates",
    "gate_results",
    "signals",
    "provenance_binding",
    "decision",
    "receipt_sha256"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "tracker_id": { "type": "string", "const": "TRK-W64-102" },
    "item_id": { "type": "string", "const": "ITEM-W64-102" },
    "record_type": {
      "type": "string",
      "const": "generated_asset_provenance_staging_decision"
    },
    "evaluator_revision": {
      "type": "string",
      "const": "wave64_row102_generated_asset_provenance_evaluator_v0.1.0"
    },
    "policy_revision": {
      "type": "string",
      "const": "wave64_row102_generated_asset_provenance_policy_v0.1.0"
    },
    "policy_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "is_synthetic": { "type": "boolean" },
    "library_authority": { "type": "boolean", "const": false },
    "selector_visible": { "type": "boolean" },
    "dependency_admissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "TRK-W64-068",
        "TRK-W64-098",
        "TRK-W64-099",
        "TRK-W64-100",
        "TRK-W64-101"
      ],
      "properties": {
        "TRK-W64-068": { "$ref": "#/$defs/dependency_admission" },
        "TRK-W64-098": { "$ref": "#/$defs/dependency_admission" },
        "TRK-W64-099": { "$ref": "#/$defs/dependency_admission" },
        "TRK-W64-100": { "$ref": "#/$defs/dependency_admission" },
        "TRK-W64-101": { "$ref": "#/$defs/dependency_admission" }
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "input_hashes",
          "prompt_hash",
          "engine_hashes",
          "seed",
          "output_hash",
          "rights",
          "staging_boundary"
        ]
      }
    },
    "gate_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_hashes",
        "prompt_hash",
        "engine_hashes",
        "seed",
        "output_hash",
        "rights",
        "staging_boundary"
      ],
      "properties": {
        "input_hashes": { "$ref": "#/$defs/gate_result" },
        "prompt_hash": { "$ref": "#/$defs/gate_result" },
        "engine_hashes": { "$ref": "#/$defs/gate_result" },
        "seed": { "$ref": "#/$defs/gate_result" },
        "output_hash": { "$ref": "#/$defs/gate_result" },
        "rights": { "$ref": "#/$defs/gate_result" },
        "staging_boundary": { "$ref": "#/$defs/gate_result" }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_hash_count",
        "all_input_hashes_valid",
        "prompt_hash_present",
        "engine_model_sha256_present",
        "engine_configuration_sha256_present",
        "engine_environment_sha256_present",
        "seed_present",
        "output_sha256_present",
        "canonical_pcm_sha256_present",
        "rights_decision",
        "rights_decision_sha256_present",
        "promotion_state",
        "content_based_suppression",
        "path_outside_approved_library",
        "selector_visible"
      ],
      "properties": {
        "input_hash_count": { "type": "integer", "minimum": 0 },
        "all_input_hashes_valid": { "type": "boolean" },
        "prompt_hash_present": { "type": "boolean" },
        "engine_model_sha256_present": { "type": "boolean" },
        "engine_configuration_sha256_present": { "type": "boolean" },
        "engine_environment_sha256_present": { "type": "boolean" },
        "seed_present": { "type": "boolean" },
        "output_sha256_present": { "type": "boolean" },
        "canonical_pcm_sha256_present": { "type": "boolean" },
        "rights_decision": {
          "type": "string",
          "enum": ["pass", "blocked", "failed", "missing"]
        },
        "rights_decision_sha256_present": { "type": "boolean" },
        "promotion_state": {
          "type": "string",
          "enum": [
            "staged_candidate",
            "rejected",
            "promoted",
            "revoked",
            "superseded",
            "missing"
          ]
        },
        "content_based_suppression": { "type": "boolean" },
        "path_outside_approved_library": { "type": "boolean" },
        "selector_visible": { "type": "boolean" }
      }
    },
    "provenance_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "immutable",
        "generated_asset_id",
        "output_path",
        "output_sha256",
        "canonical_pcm_sha256",
        "structured_prompt_sha256",
        "rights_decision_sha256",
        "qa_state",
        "promotion_state"
      ],
      "properties": {
        "immutable": { "type": "boolean", "const": true },
        "generated_asset_id": { "type": "string", "minLength": 1 },
        "output_path": { "type": "string", "minLength": 1 },
        "output_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "canonical_pcm_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "structured_prompt_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "rights_decision_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "qa_state": { "type": "string", "minLength": 1 },
        "promotion_state": { "type": "string", "minLength": 1 }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "status",
        "reason",
        "blocker_codes",
        "explanation",
        "product_completion",
        "row102_acceptance"
      ],
      "properties": {
        "route": {
          "type": "string",
          "enum": ["stage_candidate", "reject_candidate"]
        },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "reason": { "type": "string", "minLength": 1 },
        "blocker_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "explanation": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "product_completion": { "type": "boolean", "const": false },
        "row102_acceptance": {
          "type": "string",
          "enum": ["fixture_only", "held"]
        }
      }
    },
    "receipt_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "$defs": {
    "dependency_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tracker_id",
        "dependency_satisfied",
        "blocker_codes",
        "row_complete",
        "status",
        "path"
      ],
      "properties": {
        "tracker_id": { "type": "string", "minLength": 1 },
        "dependency_satisfied": { "type": "boolean" },
        "blocker_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "row_complete": { "type": "boolean" },
        "status": { "type": "string" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "gate_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason_codes"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
