{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/hyperreal-application-error-envelope/1.0.0",
  "title": "Hyperreal Application Error Envelope",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "application_error_envelope_id",
    "revision",
    "status",
    "created_at",
    "correlation_id",
    "error_class",
    "error_code",
    "title",
    "plain_language_detail",
    "affected_refs",
    "retryable",
    "preserve_operator_input",
    "safe_next_command_ids",
    "evidence_refs",
    "secret_or_raw_path_present",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "hyperreal_application_error_envelope"
    },
    "application_error_envelope_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "validated",
        "certified",
        "accepted",
        "rejected",
        "blocked",
        "revoked"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/Provenance"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "error_class": {
      "enum": [
        "validation",
        "authorization",
        "conflict",
        "dependency_missing",
        "runtime_unavailable",
        "submission_ambiguous",
        "lease_lost",
        "artifact_missing",
        "qa_blocked",
        "promotion_blocked",
        "model_unqualified",
        "mask_authority_missing",
        "projection_stale",
        "offline"
      ]
    },
    "error_code": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "plain_language_detail": {
      "type": "string",
      "minLength": 1
    },
    "affected_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 1
    },
    "retryable": {
      "type": "boolean"
    },
    "preserve_operator_input": {
      "const": true
    },
    "safe_next_command_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/hyperreal-media-common/1.0.0#/$defs/ImmutableRecordRef"
      },
      "minItems": 0
    },
    "secret_or_raw_path_present": {
      "const": false
    }
  },
  "additionalProperties": false
}
