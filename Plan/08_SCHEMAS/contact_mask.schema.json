{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Mask",
  "type": "object",
  "required": [
    "mask_id",
    "contact_type",
    "participants",
    "scale"
  ],
  "properties": {
    "mask_id": {
      "type": "string"
    },
    "contact_type": {
      "type": "string"
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scale": {
      "type": "string"
    },
    "requires_shadow_evidence": {
      "type": "boolean"
    }
  }
}
