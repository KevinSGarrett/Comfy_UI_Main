{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/canonical-video-timeline-synthetic-runtime-climb-ledger/1.0.0",
  "title": "Wave64 Canonical Video Timeline Synthetic Runtime Climb Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "ledger_id",
    "revision",
    "is_synthetic",
    "proof_tier",
    "highest_proof_tier_achieved",
    "climb_targets",
    "production_benchmark",
    "runtime_mux_replay_pass",
    "visual_review_claimed",
    "row_complete",
    "production_completion_allowed",
    "authority_ceiling",
    "hold_reasons",
    "fixture_bindings",
    "cut_detector_calibration_expectations",
    "camera_motion_bindings",
    "fixture_mux_plan_replay",
    "combined_visual_review_protocol",
    "provenance",
    "ledger_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "row084_synthetic_runtime_climb_ledger" },
    "ledger_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "is_synthetic": { "const": true },
    "proof_tier": { "const": "CONTRACT_PASS_BOUNDED" },
    "highest_proof_tier_achieved": { "const": "CONTRACT_PASS_BOUNDED" },
    "climb_targets": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "enum": ["RUNTIME_PASS_BOUNDED", "VISUAL_QA_PASS_BOUNDED"]
      },
      "uniqueItems": true
    },
    "production_benchmark": { "const": false },
    "runtime_mux_replay_pass": { "const": false },
    "visual_review_claimed": { "const": false },
    "row_complete": { "const": false },
    "production_completion_allowed": { "const": false },
    "authority_ceiling": { "const": "fixture_synthetic_climb_only" },
    "hold_reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "fixture_bindings": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fixture_name",
          "role",
          "fixture_file_sha256",
          "compiled_digest",
          "compiled_digest_field",
          "is_synthetic",
          "row_complete"
        ],
        "properties": {
          "fixture_name": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "fixture_file_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "compiled_digest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "compiled_digest_field": {
            "enum": ["stable_receipt_sha256", "media_sha256"]
          },
          "is_synthetic": { "const": true },
          "row_complete": { "const": false }
        }
      }
    },
    "cut_detector_calibration_expectations": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "algorithm_id",
          "source_fixture",
          "source_fixture_file_sha256",
          "source_contract_sha256",
          "expected_true_positives",
          "expected_false_positives",
          "expected_false_negatives",
          "expected_precision",
          "expected_recall",
          "min_confidence_gate",
          "runtime_detector_complete"
        ],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "algorithm_id": {
            "enum": ["fixture_ledger_v1", "fixture_histogram_diff_v1"]
          },
          "source_fixture": { "type": "string", "minLength": 1 },
          "source_fixture_file_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "source_contract_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "expected_true_positives": { "type": "integer", "minimum": 0 },
          "expected_false_positives": { "const": 0 },
          "expected_false_negatives": { "const": 0 },
          "expected_precision": { "type": "number", "minimum": 0, "maximum": 1 },
          "expected_recall": { "type": "number", "minimum": 0, "maximum": 1 },
          "min_confidence_gate": { "type": "number", "minimum": 0, "maximum": 1 },
          "runtime_detector_complete": { "const": false }
        }
      }
    },
    "camera_motion_bindings": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "expected_policy",
          "source_fixture",
          "source_fixture_file_sha256",
          "source_matrix_sha256",
          "camera_motion_normalization_complete"
        ],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "expected_policy": {
            "enum": [
              "not_evaluated",
              "blocked_until_calibrated",
              "distinguish_from_cuts"
            ]
          },
          "source_fixture": { "type": "string", "minLength": 1 },
          "source_fixture_file_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "source_matrix_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "camera_motion_normalization_complete": { "const": false }
        }
      }
    },
    "fixture_mux_plan_replay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_mode",
        "fixture_media_audio",
        "fixture_media_container",
        "fixture_audio_stream_sha256",
        "fixture_container_sha256",
        "case_count",
        "cases",
        "all_plan_replays_passed",
        "mux_command_executed",
        "mux_replay_executed",
        "runtime_media_decode_invoked",
        "ffmpeg_invoked"
      ],
      "properties": {
        "replay_mode": { "const": "fixture_mux_plan_replay" },
        "fixture_media_audio": { "type": "string", "minLength": 1 },
        "fixture_media_container": { "type": "string", "minLength": 1 },
        "fixture_audio_stream_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "fixture_container_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "case_count": { "type": "integer", "minimum": 3 },
        "cases": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "case_id",
              "dry_run_mux_plan_sha256",
              "planned_mux_command_envelope_sha256",
              "fixture_audio_stream_sha256",
              "fixture_container_sha256",
              "plan_replay_passed",
              "mux_command_executed",
              "mux_replay_executed"
            ],
            "properties": {
              "case_id": { "type": "string", "minLength": 1 },
              "dry_run_mux_plan_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "planned_mux_command_envelope_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "fixture_audio_stream_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "fixture_container_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "plan_replay_passed": { "const": true },
              "mux_command_executed": { "const": false },
              "mux_replay_executed": { "const": false }
            }
          }
        },
        "all_plan_replays_passed": { "const": true },
        "mux_command_executed": { "const": false },
        "mux_replay_executed": { "const": false },
        "runtime_media_decode_invoked": { "const": false },
        "ffmpeg_invoked": { "const": false }
      }
    },
    "combined_visual_review_protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_id",
        "protocol_sha256",
        "source_fixture",
        "source_fixture_file_sha256",
        "review_method",
        "required_surfaces",
        "all_surfaces_bound",
        "visual_review_authority_granted",
        "combined_visual_review_present"
      ],
      "properties": {
        "protocol_id": { "type": "string", "minLength": 1 },
        "protocol_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_fixture": { "type": "string", "minLength": 1 },
        "source_fixture_file_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "review_method": { "const": "combined_frame_contact_audio_review" },
        "required_surfaces": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "enum": [
              "audio_stream_binding",
              "camera_motion_policy",
              "contact_placeholder",
              "cut_epochs",
              "frame_timeline"
            ]
          },
          "uniqueItems": true
        },
        "all_surfaces_bound": { "const": true },
        "visual_review_authority_granted": { "const": false },
        "combined_visual_review_present": { "const": false }
      }
    },
    "provenance": {
      "type": "object",
      "minProperties": 1
    },
    "ledger_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
