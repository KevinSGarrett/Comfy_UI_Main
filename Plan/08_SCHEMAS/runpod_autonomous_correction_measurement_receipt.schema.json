{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_correction_measurement_receipt.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "job_id", "contract_id", "candidate_artifact_sha256", "hard_gates_pass", "candidate_total_score", "candidate_protected_scores", "deterministic", "runtime_measurement_performed", "disposition"],
  "properties": {
    "schema_version": {"const": "wave64.aqa.correction_measurement_receipt.v1"},
    "receipt_id": {"$ref": "#/definitions/sha256"},
    "job_id": {"type": "string", "pattern": "^W64-AQA-JOB-"},
    "contract_id": {"$ref": "#/definitions/sha256"},
    "candidate_artifact_sha256": {"$ref": "#/definitions/sha256"},
    "hard_gates_pass": {"type": "boolean"},
    "candidate_total_score": {"type": "number", "minimum": 0, "maximum": 1},
    "candidate_protected_scores": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}},
    "deterministic": {"const": true},
    "runtime_measurement_performed": {"const": false},
    "disposition": {"const": "PASS_SYNTHETIC_DETERMINISTIC_MEASUREMENT_ONLY"}
  },
  "definitions": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
