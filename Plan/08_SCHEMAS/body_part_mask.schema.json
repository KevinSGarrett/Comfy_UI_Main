{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Body Part Mask",
  "type": "object",
  "required": [
    "mask_id",
    "person_instance_id",
    "body_region_id",
    "scale"
  ],
  "properties": {
    "mask_id": {
      "type": "string"
    },
    "person_instance_id": {
      "type": "string"
    },
    "body_region_id": {
      "type": "string"
    },
    "scale": {
      "type": "string"
    },
    "side": {
      "type": "string",
      "enum": [
        "left",
        "right",
        "center",
        "unknown"
      ]
    }
  }
}
