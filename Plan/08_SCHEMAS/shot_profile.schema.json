{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shot_profile.schema.json",
  "title": "Shot Profile",
  "type": "object",
  "required": [
    "id",
    "target_visibility",
    "primary_use",
    "qa_checks"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "target_visibility": {
      "type": "string"
    },
    "recommended_aspect_ratios": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "primary_use": {
      "type": "string"
    },
    "qa_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
