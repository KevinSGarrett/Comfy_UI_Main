{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/multimodal-pass-specification/1.0.0",
  "title": "Wave64 Canonical Multimodal Pass Specification",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "pass_specification_id",
    "revision",
    "status",
    "created_at",
    "job_ref",
    "dag_id",
    "pass_intent",
    "modality",
    "dependency_pass_ids",
    "input_artifact_refs",
    "selection_context_ref",
    "selection_request_ref",
    "target_contract_sha256",
    "protected_contract_sha256",
    "mask_binding_ids",
    "qa_gate_ids",
    "resource_class_id",
    "max_attempts",
    "accepted_parent_immutable",
    "contains_execution_attempt",
    "contains_promotion_decision",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "multimodal_pass_specification"
    },
    "pass_specification_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "job_ref": {
      "allOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "object",
          "properties": {
            "record_type": {
              "const": "autonomous_multimodal_job"
            }
          },
          "required": [
            "record_type"
          ]
        }
      ]
    },
    "dag_id": {
      "type": "string",
      "minLength": 1
    },
    "pass_intent": {
      "type": "string",
      "minLength": 1
    },
    "modality": {
      "enum": [
        "image",
        "video",
        "audio",
        "av",
        "analysis"
      ]
    },
    "dependency_pass_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "input_artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
      }
    },
    "selection_context_ref": {
      "allOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "object",
          "properties": {
            "record_type": {
              "const": "model_selection_context"
            }
          },
          "required": [
            "record_type"
          ]
        }
      ]
    },
    "selection_request_ref": {
      "allOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "object",
          "properties": {
            "record_type": {
              "const": "contextual_model_selection_request"
            }
          },
          "required": [
            "record_type"
          ]
        }
      ]
    },
    "target_contract_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "protected_contract_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "mask_binding_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "qa_gate_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "resource_class_id": {
      "type": "string",
      "minLength": 1
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "accepted_parent_immutable": {
      "const": true
    },
    "contains_execution_attempt": {
      "const": false
    },
    "contains_promotion_decision": {
      "const": false
    }
  },
  "additionalProperties": false
}
