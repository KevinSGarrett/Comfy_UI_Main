{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/autonomous-tool-authorization/1.0.0",
  "title": "Wave64 Autonomous Tool Authorization",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "tool_authorization_id",
    "revision",
    "status",
    "created_at",
    "tool_request_ref",
    "decision",
    "allowlisted_target_id",
    "authorization_policy_id",
    "policy_revision",
    "reason_codes",
    "expires_at",
    "credential_exposure",
    "registry_mutation",
    "certificate_or_promotion_authority",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "autonomous_tool_authorization"
    },
    "tool_authorization_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "tool_request_ref": {
      "allOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "object",
          "properties": {
            "record_type": {
              "const": "autonomous_tool_request"
            }
          },
          "required": [
            "record_type"
          ]
        }
      ]
    },
    "decision": {
      "enum": [
        "allowed",
        "denied"
      ]
    },
    "allowlisted_target_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "authorization_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_revision": {
      "type": "string",
      "minLength": 1
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "credential_exposure": {
      "const": false
    },
    "registry_mutation": {
      "const": false
    },
    "certificate_or_promotion_authority": {
      "const": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "allowed"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "allowlisted_target_id": {
            "type": "string",
            "minLength": 1
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  ]
}
