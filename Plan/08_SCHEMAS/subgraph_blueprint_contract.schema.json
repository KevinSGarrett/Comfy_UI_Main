{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subgraph Blueprint Contract",
  "type": "object",
  "required": [
    "subgraph_id",
    "name",
    "purpose",
    "owner_wave",
    "inputs",
    "outputs",
    "qa_rules"
  ],
  "properties": {
    "subgraph_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "owner_wave": {
      "type": "integer"
    },
    "inputs": {
      "type": "array"
    },
    "outputs": {
      "type": "array"
    },
    "required_node_classes": {
      "type": "array"
    },
    "patchable_inputs": {
      "type": "array"
    },
    "qa_rules": {
      "type": "array"
    },
    "promotion_lifecycle": {
      "type": "array"
    }
  }
}
