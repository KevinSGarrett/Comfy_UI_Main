{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/controller-contract-authority-registry/1.0.0",
  "title": "Wave64 Controller Contract Authority Registry",
  "type": "object",
  "required": [
    "schema_version",
    "registry_id",
    "revision",
    "status",
    "rows_covered",
    "runtime_scope",
    "component_responsibilities",
    "decision_authority_matrix",
    "namespace_reservations",
    "revision_policy",
    "revision_history_fixture",
    "exception_fixture",
    "id_namespaces",
    "relationship_rules",
    "synthetic_entity_graph",
    "never_waivable_rules",
    "content_based_suppression",
    "runtime_completion_claimed"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "registry_id": { "const": "wave64_controller_contract_authority_registry_v1" },
    "revision": { "type": "string", "minLength": 1 },
    "status": { "const": "synthetic_contract_enforcement_active" },
    "rows_covered": {
      "const": [149, 150, 151, 152, 153]
    },
    "runtime_scope": { "const": "synthetic_contract_validation_only" },
    "component_responsibilities": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["component_id", "responsibility", "owns_record_types", "forbidden_authorities"],
        "properties": {
          "component_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
          "responsibility": { "type": "string", "minLength": 1 },
          "owns_record_types": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "forbidden_authorities": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "decision_authority_matrix": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["decision_type", "final_authority", "proposal_roles", "required_evidence", "llm_vlm_final_authority_allowed"],
        "properties": {
          "decision_type": { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
          "final_authority": { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
          "proposal_roles": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "llm_vlm_final_authority_allowed": { "const": false }
        },
        "additionalProperties": false
      }
    },
    "namespace_reservations": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["package_id", "first_row", "last_row", "item_csv", "tracker_csv", "item_id_field", "tracker_id_field", "item_id_pattern", "tracker_id_pattern"],
        "properties": {
          "package_id": { "type": "string", "minLength": 1 },
          "first_row": { "type": "integer", "minimum": 1 },
          "last_row": { "type": "integer", "minimum": 1 },
          "item_csv": { "type": "string", "minLength": 1 },
          "tracker_csv": { "type": "string", "minLength": 1 },
          "item_id_field": { "type": "string", "minLength": 1 },
          "tracker_id_field": { "type": "string", "minLength": 1 },
          "item_id_pattern": { "type": "string", "minLength": 1 },
          "tracker_id_pattern": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "revision_policy": {
      "type": "object",
      "required": ["append_only", "immutable_revision_ids", "evidence_required", "rollback_required", "in_place_mutation_allowed", "exception_scope_must_be_bounded", "exception_expiry_required"],
      "properties": {
        "append_only": { "const": true },
        "immutable_revision_ids": { "const": true },
        "evidence_required": { "const": true },
        "rollback_required": { "const": true },
        "in_place_mutation_allowed": { "const": false },
        "exception_scope_must_be_bounded": { "const": true },
        "exception_expiry_required": { "const": true }
      },
      "additionalProperties": false
    },
    "revision_history_fixture": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["record_id", "revision_id", "parent_revision_id", "supersedes_revision_id", "status", "payload_sha256", "evidence_refs"],
        "properties": {
          "record_id": { "type": "string", "minLength": 1 },
          "revision_id": { "type": "string", "minLength": 1 },
          "parent_revision_id": { "type": ["string", "null"] },
          "supersedes_revision_id": { "type": ["string", "null"] },
          "status": { "enum": ["active", "superseded", "revoked"] },
          "payload_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "exception_fixture": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["exception_id", "applies_to_revision_id", "bounded_scope", "authority", "evidence_refs", "created_at", "expires_at", "rollback_revision_id", "waives_rules"],
        "properties": {
          "exception_id": { "type": "string", "minLength": 1 },
          "applies_to_revision_id": { "type": "string", "minLength": 1 },
          "bounded_scope": { "type": "string", "minLength": 1 },
          "authority": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "expires_at": { "type": "string", "format": "date-time" },
          "rollback_revision_id": { "type": "string", "minLength": 1 },
          "waives_rules": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "id_namespaces": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["entity_type", "prefix", "pattern", "reusable_definition", "scope"],
        "properties": {
          "entity_type": { "type": "string", "minLength": 1 },
          "prefix": { "type": "string", "minLength": 1 },
          "pattern": { "type": "string", "minLength": 1 },
          "reusable_definition": { "type": "boolean" },
          "scope": { "enum": ["global", "project", "scene", "shot", "take"] }
        },
        "additionalProperties": false
      }
    },
    "relationship_rules": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["source_type", "target_type", "relation", "required"],
        "properties": {
          "source_type": { "type": "string", "minLength": 1 },
          "target_type": { "type": "string", "minLength": 1 },
          "relation": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "synthetic_entity_graph": {
      "type": "object",
      "required": ["entities", "relations"],
      "properties": {
        "entities": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "required": ["entity_type", "entity_id", "revision", "reusable_definition", "scope", "fingerprint_sha256"],
            "properties": {
              "entity_type": { "type": "string", "minLength": 1 },
              "entity_id": { "type": "string", "minLength": 1 },
              "revision": { "type": "string", "minLength": 1 },
              "reusable_definition": { "type": "boolean" },
              "scope": { "enum": ["global", "project", "scene", "shot", "take"] },
              "fingerprint_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            },
            "additionalProperties": false
          }
        },
        "relations": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "required": ["source_id", "target_id", "relation"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "target_id": { "type": "string", "minLength": 1 },
              "relation": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "never_waivable_rules": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "content_based_suppression": { "const": false },
    "runtime_completion_claimed": { "const": false }
  },
  "additionalProperties": false
}
