{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mask Factory Runtime Manifest",
  "type": "object",
  "required": [
    "manifest_id",
    "contract_id",
    "workflow_lane",
    "mask_outputs"
  ],
  "properties": {
    "manifest_id": {
      "type": "string"
    },
    "contract_id": {
      "type": "string"
    },
    "workflow_lane": {
      "type": "string"
    },
    "mask_outputs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
