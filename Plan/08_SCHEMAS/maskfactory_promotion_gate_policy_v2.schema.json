{
  "$id": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/maskfactory_promotion_gate_policy_v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "fixture_only": {
            "const": true
          }
        },
        "required": [
          "fixture_only"
        ]
      },
      "then": {
        "properties": {
          "genuine_runtime_evidence_refs": {
            "maxItems": 0
          },
          "policy_context": {
            "const": "fixture_validation"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "policy_context": {
            "const": "production_runtime"
          }
        },
        "required": [
          "policy_context"
        ]
      },
      "then": {
        "properties": {
          "fixture_only": {
            "const": false
          },
          "genuine_runtime_evidence_refs": {
            "minItems": 1
          },
          "signature_trust": {
            "properties": {
              "trust_result": {
                "const": "trusted"
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "completion_profile": {
      "const": "core_autonomous_runtime"
    },
    "created_at": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/timestamp"
    },
    "criteria": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "analyzer_manifest_ref": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
          },
          "blocking": {
            "const": true
          },
          "comparator": {
            "enum": [
              "gte",
              "lte",
              "eq",
              "boolean_true",
              "no_blockers"
            ]
          },
          "criterion_id": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
          },
          "dimension": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
          },
          "evidence_type": {
            "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
          },
          "threshold": {
            "type": [
              "number",
              "integer",
              "boolean",
              "string"
            ]
          }
        },
        "required": [
          "criterion_id",
          "dimension",
          "comparator",
          "threshold",
          "evidence_type",
          "analyzer_manifest_ref",
          "blocking"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "evidence_manifest_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "minItems": 1,
      "type": "array"
    },
    "fixture_only": {
      "type": "boolean"
    },
    "genuine_runtime_evidence_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "type": "array",
      "uniqueItems": true
    },
    "legacy_string_gate_authoritative": {
      "const": false
    },
    "live_qa_strictness_control_authoritative": {
      "const": false
    },
    "maskfactory_promotion_gate_policy_v2_id": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "optional_independent_accuracy_can_mutate_core_decision": {
      "const": false
    },
    "policy_artifact_ref": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
    },
    "policy_context": {
      "enum": [
        "fixture_validation",
        "production_runtime"
      ]
    },
    "policy_hash_profile": {
      "const": "main_domain_separated_sorted_utf8_json_v2_excluding_policy_hash_signature_signature_trust_and_artifact_ref_hash"
    },
    "policy_sha256": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/sha256"
    },
    "policy_version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "type": "string"
    },
    "record_type": {
      "const": "maskfactory_promotion_gate_policy_v2"
    },
    "revision": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/id"
    },
    "revocation_manifest_refs": {
      "items": {
        "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/immutable_ref"
      },
      "minItems": 1,
      "type": "array"
    },
    "runtime_completion_claimed": {
      "const": false
    },
    "runtime_policy_mutable_from_app": {
      "const": false
    },
    "schema_version": {
      "const": "2.0.0"
    },
    "signature": {
      "minLength": 16,
      "type": "string"
    },
    "signature_domain": {
      "const": "comfy_ui_main.maskfactory_promotion_gate_policy.v2"
    },
    "signature_trust": {
      "$ref": "https://schemas.local/comfy-ui-main/wave64/maskfactory-bridge/v2/wave64_maskfactory_bridge_common_v2.schema.json#/$defs/signing_trust_verification"
    }
  },
  "required": [
    "schema_version",
    "record_type",
    "maskfactory_promotion_gate_policy_v2_id",
    "revision",
    "created_at",
    "fixture_only",
    "runtime_completion_claimed",
    "policy_version",
    "policy_context",
    "completion_profile",
    "policy_artifact_ref",
    "policy_sha256",
    "policy_hash_profile",
    "signature_domain",
    "signature",
    "signature_trust",
    "criteria",
    "evidence_manifest_refs",
    "genuine_runtime_evidence_refs",
    "revocation_manifest_refs",
    "live_qa_strictness_control_authoritative",
    "runtime_policy_mutable_from_app",
    "optional_independent_accuracy_can_mutate_core_decision",
    "legacy_string_gate_authoritative"
  ],
  "title": "maskfactory_promotion_gate_policy_v2",
  "type": "object"
}
