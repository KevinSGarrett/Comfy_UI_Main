{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voice Reference Intake Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "created_at",
    "source",
    "segment",
    "transcript",
    "rights",
    "quality",
    "acceptance",
    "source_bytes_preserved",
    "content_based_suppression"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "record_id": { "type": "string", "minLength": 3 },
    "created_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes", "format", "sample_rate_hz", "channels", "sample_width_bytes", "frame_count", "duration_seconds"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "bytes": { "type": "integer", "minimum": 1 },
        "format": { "const": "pcm_wav" },
        "sample_rate_hz": { "type": "integer", "minimum": 8000 },
        "channels": { "type": "integer", "minimum": 1 },
        "sample_width_bytes": { "type": "integer", "minimum": 1, "maximum": 4 },
        "frame_count": { "type": "integer", "minimum": 1 },
        "duration_seconds": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_frame", "end_frame", "start_seconds", "end_seconds"],
      "properties": {
        "start_frame": { "const": 0 },
        "end_frame": { "type": "integer", "minimum": 1 },
        "start_seconds": { "const": 0 },
        "end_seconds": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "transcript": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "language", "source"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 2 },
        "source": { "enum": ["supplied_authoritative", "verified_transcription"] }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["license", "provenance", "derivative_use_allowed"],
      "properties": {
        "license": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "minLength": 1 },
        "derivative_use_allowed": { "const": true },
        "attribution": { "type": "string" }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rms_dbfs", "peak_dbfs", "clipping_ratio", "silence_ratio", "contamination_flags"],
      "properties": {
        "rms_dbfs": { "type": "number" },
        "peak_dbfs": { "type": "number" },
        "clipping_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "silence_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "contamination_flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duration_pass", "level_pass", "clipping_pass", "silence_pass", "rights_pass", "intake_pass"],
      "properties": {
        "duration_pass": { "type": "boolean" },
        "level_pass": { "type": "boolean" },
        "clipping_pass": { "type": "boolean" },
        "silence_pass": { "type": "boolean" },
        "rights_pass": { "type": "boolean" },
        "intake_pass": { "type": "boolean" }
      }
    },
    "source_bytes_preserved": { "const": true },
    "content_based_suppression": { "const": false }
  }
}
