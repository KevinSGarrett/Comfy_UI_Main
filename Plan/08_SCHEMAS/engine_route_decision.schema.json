  "required": [
    "selected_engine",
    "selected_family",
    "reason",
    "blocked",
    "required_proof"
  ],
  "properties": {
    "selected_engine": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_family": {
      "type": [
        "string",
        "null"
      ]
    },
    "reason": {
      "type": "string"
    },
    "blocked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_proof": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
