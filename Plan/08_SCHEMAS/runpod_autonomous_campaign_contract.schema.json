{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://comfy-ui-main.local/schemas/runpod_autonomous_campaign_contract.schema.json",
  "title": "Wave64 RunPod Autonomous Campaign Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "campaign_id", "campaign_name", "repository", "policy", "jobs", "dag", "model_bindings", "authority"],
  "properties": {
    "schema_version": {"const": "wave64.aqa.campaign.v1"},
    "campaign_id": {"$ref": "#/definitions/sha256"},
    "campaign_name": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,128}$"},
    "repository": {
      "type": "object", "additionalProperties": false,
      "required": ["remote", "commit_sha256", "tree_sha256"],
      "properties": {
        "remote": {"type": "string", "minLength": 1},
        "commit_sha256": {"$ref": "#/definitions/sha256"},
        "tree_sha256": {"$ref": "#/definitions/sha256"}
      }
    },
    "policy": {
      "type": "object", "additionalProperties": false,
      "required": ["policy_id", "policy_sha256", "max_attempts", "repair_attempts", "abstain_on_unqualified_role"],
      "properties": {
        "policy_id": {"const": "W64-AQA-TOOL-POLICY-002"},
        "policy_sha256": {"$ref": "#/definitions/sha256"},
        "max_attempts": {"type": "integer", "minimum": 1, "maximum": 5},
        "repair_attempts": {"type": "integer", "minimum": 0, "maximum": 2},
        "abstain_on_unqualified_role": {"const": true}
      }
    },
    "jobs": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["node_id", "contract_path", "contract_sha256", "contract_id", "input_sha256", "runtime_sha256", "prompt_sha256", "role_id", "phase", "continue_unrelated_branches"],
        "properties": {
          "node_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,96}$"},
          "contract_path": {"type": "string", "pattern": "^(?![A-Za-z]:|/|.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"},
          "contract_sha256": {"$ref": "#/definitions/sha256"},
          "contract_id": {"$ref": "#/definitions/sha256"},
          "input_sha256": {"$ref": "#/definitions/sha256"},
          "runtime_sha256": {"$ref": "#/definitions/sha256"},
          "prompt_sha256": {"$ref": "#/definitions/sha256"},
          "role_id": {"type": "string", "pattern": "^W64-AQA-ROLE-[A-Z0-9-]+$"},
          "phase": {"enum": ["CPU", "GPU"]},
          "continue_unrelated_branches": {"const": true}
        }
      }
    },
    "dag": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["node_id", "depends_on"],
        "properties": {
          "node_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,96}$"},
          "depends_on": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,96}$"}}
        }
      }
    },
    "model_bindings": {
      "type": "array", "minItems": 3,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["role_id", "family_id", "checkpoint_sha256", "qualification_state"],
        "properties": {
          "role_id": {"type": "string", "pattern": "^W64-AQA-ROLE-[A-Z0-9-]+$"},
          "family_id": {"type": "string", "pattern": "^W64-AQA-FAMILY-[A-Z0-9-]+$"},
          "checkpoint_sha256": {"$ref": "#/definitions/sha256"},
          "qualification_state": {"enum": ["QUALIFIED", "UNQUALIFIED", "REVOKED"]}
        }
      }
    },
    "authority": {
      "type": "object", "additionalProperties": false,
      "required": ["runpod_may_execute_isolated_batches", "runpod_may_propose_deltas", "runpod_may_push_git", "runpod_may_promote", "runpod_may_spend", "runpod_may_override_foreign_lease", "final_acceptance_authority"],
      "properties": {
        "runpod_may_execute_isolated_batches": {"const": true},
        "runpod_may_propose_deltas": {"const": true},
        "runpod_may_push_git": {"const": false},
        "runpod_may_promote": {"const": false},
        "runpod_may_spend": {"const": false},
        "runpod_may_override_foreign_lease": {"const": false},
        "final_acceptance_authority": {"const": "CODEX"}
      }
    }
  },
  "definitions": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
