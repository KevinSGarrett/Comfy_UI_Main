{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mask Pass Profile",
  "type": "object",
  "required": [
    "profile_id",
    "mask_scales",
    "default_denoise_max",
    "uses"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "mask_scales": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "default_denoise_max": {
      "type": "number"
    },
    "uses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_if": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
