{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lapa_taxonomy_binding.schema.json",
  "title": "LaPa Taxonomy Binding",
  "type": "object",
  "required": ["schema_version", "dataset_id", "authority_source", "label_to_class", "protected_neighbors"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "dataset_id": {"const": "lapa"},
    "authority_source": {"type": "string", "minLength": 1},
    "label_to_class": {"type": "object", "minProperties": 11, "maxProperties": 11},
    "protected_neighbors": {"type": "object", "minProperties": 11, "maxProperties": 11}
  }
}
