{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/wave64-bridge-specialist-authority/1.0.0",
  "title": "Wave64 Bridge and Specialist Authority Fixture",
  "type": "object",
  "required": [
    "schema_version", "authority_id", "status", "source_route_evidence",
    "intent_classification", "decoded_bridge_contract", "conditioning_translations",
    "qualification_gate", "specialist_catalog", "accepted_parent_artifact_id",
    "runtime_execution_allowed", "production_bridge_certified", "content_based_suppression"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "authority_id": { "type": "string", "minLength": 1 },
    "status": { "const": "blocked_contract_fixture_not_runtime_evidence" },
    "source_route_evidence": { "$ref": "#/$defs/ImmutableFileRef" },
    "intent_classification": {
      "type": "object",
      "required": [
        "classification_id", "objective_dimensions", "candidate_stack_ids",
        "selected_first_pass_stack_id", "downstream_bridge_needs", "quality_tier",
        "resource_class", "decision_status"
      ],
      "properties": {
        "classification_id": { "type": "string", "minLength": 1 },
        "objective_dimensions": { "type": "array", "minItems": 8, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "candidate_stack_ids": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "selected_first_pass_stack_id": { "const": null },
        "downstream_bridge_needs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "quality_tier": { "type": "string", "minLength": 1 },
        "resource_class": { "type": "string", "minLength": 1 },
        "decision_status": { "const": "blocked_no_eligible_stack" }
      },
      "additionalProperties": false
    },
    "decoded_bridge_contract": { "type": "object" },
    "conditioning_translations": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "object",
        "required": ["translation_id", "semantic", "source_contract", "target_engine_family", "translator_revision", "configuration_sha256", "translation_method", "raw_value_copy_allowed", "status"],
        "properties": {
          "translation_id": { "type": "string", "minLength": 1 },
          "semantic": { "enum": ["prompt", "reference", "pose", "depth", "mask", "control", "denoise", "scheduler", "adapter"] },
          "source_contract": { "type": "string", "minLength": 1 },
          "target_engine_family": { "type": "string", "minLength": 1 },
          "translator_revision": { "type": "string", "minLength": 1 },
          "configuration_sha256": { "$ref": "#/$defs/Sha256" },
          "translation_method": { "type": "string", "minLength": 1 },
          "raw_value_copy_allowed": { "const": false },
          "status": { "const": "planned_blocked_no_certified_bridge" }
        },
        "additionalProperties": false
      }
    },
    "qualification_gate": {
      "type": "object",
      "required": ["qualification_id", "required_metrics", "metric_results", "decision", "certificate_id", "execution_allowed", "blocker_codes"],
      "properties": {
        "qualification_id": { "type": "string", "minLength": 1 },
        "required_metrics": { "type": "array", "minItems": 6, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "metric_results": {
          "type": "array",
          "minItems": 6,
          "items": {
            "type": "object",
            "required": ["metric", "status", "evidence_ids"],
            "properties": {
              "metric": { "type": "string", "minLength": 1 },
              "status": { "const": "not_run" },
              "evidence_ids": { "type": "array", "maxItems": 0 }
            },
            "additionalProperties": false
          }
        },
        "decision": { "const": "blocked" },
        "certificate_id": { "const": null },
        "execution_allowed": { "const": false },
        "blocker_codes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "specialist_catalog": {
      "type": "array",
      "minItems": 11,
      "items": {
        "type": "object",
        "required": ["catalog_entry_id", "pass_intent", "capability_tags", "eligible_exact_stack_ids", "inputs", "outputs", "preservation_risks", "qa_gate_ids", "status"],
        "properties": {
          "catalog_entry_id": { "type": "string", "minLength": 1 },
          "pass_intent": { "enum": ["face_eyes", "hands_feet", "anatomy", "skin", "hair", "fabric", "accessories", "materials", "contact", "pressure", "deformation"] },
          "capability_tags": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "eligible_exact_stack_ids": { "type": "array", "maxItems": 0 },
          "inputs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "outputs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "preservation_risks": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "qa_gate_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "status": { "const": "blocked_no_certified_bundle" }
        },
        "additionalProperties": false
      }
    },
    "accepted_parent_artifact_id": { "type": "string", "minLength": 1 },
    "runtime_execution_allowed": { "const": false },
    "production_bridge_certified": { "const": false },
    "content_based_suppression": { "const": false }
  },
  "$defs": {
    "Sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "ImmutableFileRef": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": { "path": { "type": "string", "minLength": 1 }, "sha256": { "$ref": "#/$defs/Sha256" } },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
