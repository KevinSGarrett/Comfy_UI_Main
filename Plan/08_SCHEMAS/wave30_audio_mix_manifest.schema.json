{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/wave30_audio_mix_manifest.schema.json",
  "title": "Wave30 Audio Mix Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_name",
    "mix_manifest_version",
    "run_id",
    "mix_id",
    "scene_id",
    "shot_id",
    "is_synthetic",
    "event_manifest_bindings",
    "mixdown_artifact",
    "mix_technical",
    "mix_event_metadata",
    "mix_loudness",
    "dialogue_ducking",
    "av_sync_evidence",
    "runtime_proof",
    "audio_review",
    "production_state",
    "promotion_decision"
  ],
  "properties": {
    "$schema": { "const": "https://json-schema.org/draft/2020-12/schema" },
    "schema_name": { "const": "wave30_audio_mix_manifest" },
    "mix_manifest_version": { "type": "integer", "minimum": 1, "maximum": 9999 },
    "run_id": { "type": "string", "minLength": 1 },
    "mix_id": { "type": "string", "minLength": 1 },
    "scene_id": { "type": "string", "minLength": 1 },
    "shot_id": { "type": "string", "minLength": 1 },
    "is_synthetic": { "type": "boolean" },
    "event_manifest_bindings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "mixdown_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 2147483647 }
      }
    },
    "mix_technical": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duration_seconds",
        "sample_rate_hz",
        "channels",
        "channel_layout",
        "sample_width_bytes",
        "frame_count"
      ],
      "properties": {
        "duration_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 86400 },
        "sample_rate_hz": { "type": "integer", "minimum": 8000, "maximum": 384000 },
        "channels": { "type": "integer", "minimum": 1, "maximum": 16 },
        "channel_layout": { "type": "string", "minLength": 1 },
        "sample_width_bytes": { "type": "integer", "minimum": 1, "maximum": 8 },
        "frame_count": { "type": "integer", "minimum": 1, "maximum": 2147483647 }
      }
    },
    "mix_event_metadata": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "audio_event_id",
          "gain_db",
          "pan",
          "spatial_position",
          "distance_meters"
        ],
        "properties": {
          "audio_event_id": { "type": "string", "minLength": 1 },
          "gain_db": { "type": "number", "minimum": -60, "maximum": 24 },
          "pan": { "type": "number", "minimum": -1, "maximum": 1 },
          "spatial_position": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y", "z"],
            "properties": {
              "x": { "type": "number", "minimum": -1000, "maximum": 1000 },
              "y": { "type": "number", "minimum": -1000, "maximum": 1000 },
              "z": { "type": "number", "minimum": -1000, "maximum": 1000 }
            }
          },
          "distance_meters": { "type": "number", "minimum": 0, "maximum": 1000 }
        }
      }
    },
    "mix_loudness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["integrated_lufs", "true_peak_dbtp", "clipping_detected"],
      "properties": {
        "integrated_lufs": { "type": "number", "minimum": -70, "maximum": 0 },
        "true_peak_dbtp": { "type": "number", "minimum": -20, "maximum": 6 },
        "clipping_detected": { "type": "boolean" }
      }
    },
    "measurement_methods": {
      "type": "object",
      "additionalProperties": false,
      "required": ["integrated_loudness", "true_peak", "certification_authority"],
      "properties": {
        "integrated_loudness": { "type": "string", "minLength": 1 },
        "true_peak": { "type": "string", "minLength": 1 },
        "certification_authority": { "type": "boolean" }
      }
    },
    "dialogue_ducking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "duck_db", "recovery_ms"],
      "properties": {
        "enabled": { "type": "boolean" },
        "duck_db": { "type": "number", "minimum": -36, "maximum": 0 },
        "recovery_ms": { "type": "integer", "minimum": 0, "maximum": 120000 }
      }
    },
    "av_sync_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame_rate", "start_frame", "end_frame", "frame_offset"],
      "properties": {
        "frame_rate": { "type": "number", "exclusiveMinimum": 0, "maximum": 240 },
        "start_frame": { "type": "integer", "minimum": 0, "maximum": 2000000 },
        "end_frame": { "type": "integer", "minimum": 0, "maximum": 2000000 },
        "frame_offset": { "type": "integer", "minimum": -10000, "maximum": 10000 }
      }
    },
    "runtime_proof": { "$ref": "#/$defs/proofArtifactRuntime" },
    "audio_review": { "$ref": "#/$defs/proofArtifactAudioReview" },
    "production_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_proof_present", "audio_review_present", "certified_for_release"],
      "properties": {
        "runtime_proof_present": { "const": false },
        "audio_review_present": { "const": false },
        "certified_for_release": { "const": false }
      }
    },
    "promotion_decision": {
      "type": "string",
      "enum": ["repair", "rerun", "block"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "is_synthetic": { "const": true } },
        "required": ["is_synthetic"]
      },
      "then": {
        "properties": {
          "promotion_decision": { "enum": ["repair", "rerun", "block"] },
          "production_state": {
            "properties": {
              "runtime_proof_present": { "const": false },
              "audio_review_present": { "const": false },
              "certified_for_release": { "const": false }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "proofArtifactRuntime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_kind", "path", "sha256"],
      "properties": {
        "proof_kind": { "const": "runtime" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "proofArtifactAudioReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_kind", "path", "sha256"],
      "properties": {
        "proof_kind": { "const": "audio_review" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
