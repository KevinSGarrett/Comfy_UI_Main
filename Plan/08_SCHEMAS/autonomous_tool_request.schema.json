{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/autonomous-tool-request/1.0.0",
  "title": "Wave64 Autonomous Tool Request",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "tool_request_id",
    "revision",
    "status",
    "created_at",
    "actor_role_activation_ref",
    "requested_action",
    "requested_target_id",
    "argument_schema_id",
    "arguments_sha256",
    "reason",
    "evidence_ids",
    "credential_access_requested",
    "registry_mutation_requested",
    "promotion_requested",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "autonomous_tool_request"
    },
    "tool_request_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "actor_role_activation_ref": {
      "allOf": [
        {
          "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/ImmutableRecordRef"
        },
        {
          "type": "object",
          "properties": {
            "record_type": {
              "const": "autonomous_role_activation_decision"
            }
          },
          "required": [
            "record_type"
          ]
        }
      ]
    },
    "requested_action": {
      "type": "string",
      "minLength": 1
    },
    "requested_target_id": {
      "type": "string",
      "minLength": 1
    },
    "argument_schema_id": {
      "type": "string",
      "minLength": 1
    },
    "arguments_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "credential_access_requested": {
      "const": false
    },
    "registry_mutation_requested": {
      "const": false
    },
    "promotion_requested": {
      "const": false
    }
  },
  "additionalProperties": false
}
