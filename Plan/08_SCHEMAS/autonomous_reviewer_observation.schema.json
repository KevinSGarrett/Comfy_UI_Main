{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfy-ui-main.local/schemas/autonomous-reviewer-observation/1.0.0",
  "title": "Wave64 Autonomous Reviewer Observation",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "reviewer_observation_id",
    "revision",
    "status",
    "created_at",
    "autonomous_stack_ref",
    "artifact_ids",
    "scope_bindings",
    "observations",
    "metric_observations",
    "uncertainty",
    "promotion_authority",
    "evidence_ids",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "autonomous_reviewer_observation"
    },
    "reviewer_observation_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/Provenance"
    },
    "autonomous_stack_ref": {
      "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/RecordRef"
    },
    "artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "scope_bindings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "metric_observations": {
      "type": "array",
      "items": {
        "$ref": "https://comfy-ui-main.local/schemas/model-intelligence-common/1.0.0#/$defs/MetricObservation"
      }
    },
    "uncertainty": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "disagreement_group_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "promotion_authority": {
      "const": "none"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
