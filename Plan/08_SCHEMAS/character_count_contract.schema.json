{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave12 Character Count Contract",
  "type": "object",
  "required": [
    "expected_character_count",
    "exact_count_required"
  ],
  "properties": {
    "expected_character_count": {
      "type": "integer"
    },
    "exact_count_required": {
      "type": "boolean"
    },
    "allow_background_people": {
      "type": "boolean"
    },
    "character_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
