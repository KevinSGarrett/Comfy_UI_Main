{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Wave16 Base Preservation Report",
  "required": [
    "base_image_hash",
    "refined_image_hash",
    "identity_preserved",
    "frame_preserved",
    "passed"
  ],
  "properties": {
    "base_image_hash": {
      "type": "string"
    },
    "refined_image_hash": {
      "type": "string"
    },
    "identity_preserved": {
      "type": "boolean"
    },
    "frame_preserved": {
      "type": "boolean"
    },
    "passed": {
      "type": "boolean"
    }
  }
}
