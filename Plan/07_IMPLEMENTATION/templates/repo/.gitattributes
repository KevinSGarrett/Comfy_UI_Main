# Text normalization
* text=auto

# Keep JSON/MD readable
*.json text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.py text eol=lf
*.ps1 text eol=crlf

# Do not diff large/binary artifact classes
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.pdf binary

# Model/media files should be ignored by .gitignore.
# If they appear, treat as binary and block with validation.
*.safetensors binary
*.ckpt binary
*.pt binary
*.pth binary
*.mp4 binary
*.wav binary
