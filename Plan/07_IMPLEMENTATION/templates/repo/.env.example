# Ultra Hyperrealism System — Example Environment File
# Copy to .env locally, fill real values, and NEVER commit the real .env file.
# The repository .gitignore must ignore .env and .env.* while allowing this .env.example.

# -----------------------------------------------------------------------------
# Project / repository
# -----------------------------------------------------------------------------
PROJECT_NAME=Ultra_Hyperrealism_ComfyUI_System
LOCAL_REPO_ROOT=C:\Comfy_UI_Main
GITHUB_REPO_URL=https://github.com/KevinSGarrett/Comfy_UI_Main
GITHUB_DEFAULT_BRANCH=main
GITHUB_USERNAME=KevinSGarrett
GITHUB_TOKEN=
GITHUB_TOKEN_SCOPES_NOTE=repo,workflow,read:packages_if_needed
GITHUB_DISABLE_MODEL_UPLOADS=true
GITHUB_MAX_ALLOWED_FILE_MB=95

# -----------------------------------------------------------------------------
# ComfyUI local paths
# -----------------------------------------------------------------------------
COMFYUI_LOCAL_ROOT=C:\Comfy_UI_Main\ComfyUI
COMFYUI_WORKFLOWS_DIR=C:\Comfy_UI_Main\workflows
COMFYUI_API_WORKFLOWS_DIR=C:\Comfy_UI_Main\workflows_api
COMFYUI_OUTPUT_DIR=C:\Comfy_UI_Main\outputs
COMFYUI_INPUT_DIR=C:\Comfy_UI_Main\inputs
COMFYUI_TEMP_DIR=C:\Comfy_UI_Main\temp
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
COMFYUI_API_BASE_URL=http://127.0.0.1:8188

# -----------------------------------------------------------------------------
# Local model cache - outside Git
# -----------------------------------------------------------------------------
LOCAL_MODEL_CACHE_ROOT=C:\Comfy_UI_Model_Cache
LOCAL_MODEL_CACHE_CHECKPOINTS=C:\Comfy_UI_Model_Cache\checkpoints
LOCAL_MODEL_CACHE_LORAS=C:\Comfy_UI_Model_Cache\loras
LOCAL_MODEL_CACHE_VAE=C:\Comfy_UI_Model_Cache\vae
LOCAL_MODEL_CACHE_CONTROLNET=C:\Comfy_UI_Model_Cache\controlnet
LOCAL_MODEL_CACHE_IPADAPTER=C:\Comfy_UI_Model_Cache\ipadapter
LOCAL_MODEL_CACHE_CLIP=C:\Comfy_UI_Model_Cache\clip
LOCAL_MODEL_CACHE_CLIP_VISION=C:\Comfy_UI_Model_Cache\clip_vision
LOCAL_MODEL_CACHE_UPSCALE=C:\Comfy_UI_Model_Cache\upscale_models
LOCAL_MODEL_CACHE_VIDEO=C:\Comfy_UI_Model_Cache\video_models
LOCAL_MODEL_CACHE_AUDIO=C:\Comfy_UI_Model_Cache\audio_models
LOCAL_MODEL_CACHE_METADATA=C:\Comfy_UI_Model_Cache\metadata
LOCAL_MODEL_CACHE_RAW_CIVITAI=C:\Comfy_UI_Model_Cache\metadata\civitai_raw
ALLOW_LOCAL_SYMLINKS=true

# -----------------------------------------------------------------------------
# AWS / S3 canonical model storage
# -----------------------------------------------------------------------------
AWS_PROFILE=default
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
S3_MODEL_BUCKET=
S3_MODEL_PREFIX=models
S3_METADATA_PREFIX=metadata/civitai
S3_MANIFEST_PREFIX=manifests/model_assets
S3_RENDER_OUTPUT_PREFIX=renders
S3_DEFAULT_STORAGE_CLASS=STANDARD
S3_MODEL_SERVER_SIDE_ENCRYPTION=AES256
S3_SYNC_DRY_RUN_BY_DEFAULT=true
S3_HYDRATE_ONLY_MANIFEST_ASSETS=true
S3_ALLOW_FULL_BUCKET_SYNC=false

# -----------------------------------------------------------------------------
# EC2 runtime mirror - EC2 stays off by default
# -----------------------------------------------------------------------------
EC2_INSTANCE_ID=
EC2_INSTANCE_NAME=ComfyUI-GPU-Worker
EC2_REGION=us-east-1
EC2_DEFAULT_STATE=stopped
EC2_START_ALLOWED=false
EC2_REQUIRE_EXPLICIT_RUNTIME_PROOF=true
EC2_USE_SSM=true
EC2_SSM_DOCUMENT=AWS-RunShellScript
EC2_REMOTE_PROJECT_ROOT=/opt/Comfy_UI_Main
EC2_REMOTE_COMFYUI_ROOT=/opt/ComfyUI
EC2_REMOTE_MODEL_ROOT=/opt/ComfyUI/models
EC2_REMOTE_OUTPUT_ROOT=/opt/ComfyUI/output
EC2_REMOTE_WORK_DIR=/opt/Comfy_UI_Main/runtime
EC2_STOP_AFTER_RUN=true
EC2_MAX_RUNTIME_MINUTES=60
EC2_COST_GUARD_ENABLED=true
EC2_ALLOW_MANUAL_SSH=false
EC2_SSH_KEY_PATH=
EC2_SSH_USER=ubuntu
EC2_SECURITY_GROUP_ID=
EC2_SUBNET_ID=

# -----------------------------------------------------------------------------
# Civitai API
# -----------------------------------------------------------------------------
CIVITAI_API_BASE_URL=https://civitai.com/api/v1
CIVITAI_API_KEY=
CIVITAI_AUTH_MODE=bearer_header
CIVITAI_USER_AGENT=Comfy_UI_Main_Model_Metadata_Manager/1.0
CIVITAI_TIMEOUT_SECONDS=60
CIVITAI_MAX_RETRIES=5
CIVITAI_RETRY_BACKOFF_SECONDS=2
CIVITAI_MAX_CONCURRENCY=2
CIVITAI_REQUESTS_PER_MINUTE=30
CIVITAI_USE_CURSOR_PAGINATION=true
CIVITAI_DEFAULT_PAGE_LIMIT=25
CIVITAI_DISCOVERY_USE_TAG_FIRST=true
CIVITAI_DISCOVERY_ALLOW_QUERY_FALLBACK=true
CIVITAI_FETCH_MODELS=true
CIVITAI_FETCH_MODEL_VERSIONS=true
CIVITAI_FETCH_VERSION_BY_HASH=true
CIVITAI_FETCH_IMAGES=true
CIVITAI_FETCH_CREATORS=true
CIVITAI_FETCH_TAGS=true
CIVITAI_FETCH_SAMPLE_IMAGE_METADATA=true
CIVITAI_CACHE_RAW_JSON=true
CIVITAI_CACHE_RAW_JSON_ROOT=C:\Comfy_UI_Model_Cache\metadata\civitai_raw
CIVITAI_NORMALIZED_REGISTRY_PATH=C:\Comfy_UI_Main\registries\civitai_model_registry.csv
CIVITAI_METADATA_TARGET_COLUMNS=70
CIVITAI_METADATA_EXTENDED_COLUMNS=146
CIVITAI_MIN_REQUIRED_COLUMNS=70
CIVITAI_HASH_SCAN_ROOT=C:\Comfy_UI_Model_Cache
CIVITAI_HASH_LOOKUP_FALLBACK_ALLOWED=true
CIVITAI_SKIP_DOWNLOADS_BY_DEFAULT=true
CIVITAI_DOWNLOAD_ALLOWED=false

# -----------------------------------------------------------------------------
# Pass planner / model selection
# -----------------------------------------------------------------------------
MODEL_REGISTRY_PATH=C:\Comfy_UI_Main\registries\model_asset_registry.json
MODEL_COMPATIBILITY_REGISTRY_PATH=C:\Comfy_UI_Main\registries\engine_compatibility_registry.json
MODEL_HYDRATION_MANIFEST_PATH=C:\Comfy_UI_Main\manifests\model_hydration_manifest.json
PASS_PLAN_SCHEMA_PATH=C:\Comfy_UI_Main\schemas\pass_plan.schema.json
STRICT_ENGINE_COMPATIBILITY=true
STRICT_SAME_ENGINE_LORA_STACKS=true
ALLOW_CROSS_ENGINE_IMAGE_BRIDGE=true
ALLOW_CROSS_ENGINE_LATENT_BRIDGE=false
MAX_GLOBAL_LORAS_BASE_PASS=2
MAX_DETAIL_LORAS_MASKED_PASS=3

# -----------------------------------------------------------------------------
# QA / validation
# -----------------------------------------------------------------------------
QA_ROOT=C:\Comfy_UI_Main\qa
QA_EVIDENCE_ROOT=C:\Comfy_UI_Main\qa\evidence
QA_MANIFEST_ROOT=C:\Comfy_UI_Main\manifests
QA_STRICT_MODE=true
QA_REQUIRE_HASH_PROOF=true
QA_REQUIRE_CIVITAI_METADATA=true
QA_REQUIRE_S3_MANIFEST=true
QA_REQUIRE_NO_MODEL_BINARIES_IN_GIT=true
QA_REQUIRE_ENGINE_COMPATIBILITY=true
QA_REQUIRE_LOCAL_VALIDATION_BEFORE_EC2=true
QA_FAIL_ON_MISSING_MODEL_METADATA=true
QA_FAIL_ON_UNKNOWN_ENGINE=true
QA_FAIL_ON_DUPLICATE_HASH_WITHOUT_DEDUPE_RECORD=true
QA_FAIL_ON_REJECTED_OR_SUPERSEDED_ASSET=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=C:\Comfy_UI_Main\logs
MASK_SECRETS_IN_LOGS=true
LOG_CIVITAI_REQUESTS=true
LOG_AWS_DRY_RUNS=true
LOG_COMFYUI_API_CALLS=true

# -----------------------------------------------------------------------------
# Wave03 local validation harness
# -----------------------------------------------------------------------------
WAVE03_VALIDATION_OUT_DIR=C:\Comfy_UI_Main\Implementation\manifests\wave03_local_validation
WAVE03_MAIN_WORKFLOW_PATH=C:\Comfy_UI_Main\workflows\main\WAVE42_MAIN_FLOW_20260702.json
WAVE03_OBJECT_INFO_SNAPSHOT=C:\Comfy_UI_Main\Implementation\manifests\wave03_local_validation\object_info_snapshot.json
WAVE03_VALIDATE_OBJECT_INFO=false
WAVE03_VALIDATE_MODEL_REFS_LOCAL=false
WAVE03_FAIL_ON_MISSING_OBJECT_INFO_FOR_PRODUCTION=true
WAVE03_FAIL_ON_STATIC_GRAPH_ERRORS=true
WAVE03_FAIL_ON_INVALID_JSON_REGISTRY=true
WAVE03_EC2_ALLOWED_FOR_STATIC_VALIDATION=false

# -------------------------------------------------------------------
# Wave 06 Engine Router / Flux2
# -------------------------------------------------------------------
ENGINE_ROUTER_ENABLED=true
ENGINE_REGISTRY_PATH=10_REGISTRIES/wave06_engine_registry.json
ENGINE_ROUTER_RULES_PATH=10_REGISTRIES/wave06_engine_router_rules.json
PASS_TO_ENGINE_MAP_PATH=10_REGISTRIES/wave06_pass_to_engine_map.json
CHECKPOINT_RECOMMENDATION_MATRIX_PATH=10_REGISTRIES/wave06_checkpoint_recommendation_matrix.json

FLUX2_ENABLED=false
FLUX2_LOCAL_ROOT=C:\Comfy_UI_Main\models\flux2
FLUX2_S3_PREFIX=s3://YOUR_MODEL_BUCKET/models/flux2/
FLUX2_EC2_ROOT=/opt/ComfyUI/models/flux2
FLUX2_DEV_MODEL_FILENAME=
FLUX2_KLEIN_MODEL_FILENAME=
FLUX2_TEXT_ENCODER_FILENAME=
FLUX2_VAE_FILENAME=
FLUX2_MIN_COMFYUI_VERSION=
FLUX2_PROMOTION_STATUS=blocked_until_runtime_proof

BFL_API_ENABLED=false
BFL_API_KEY=
BFL_API_MAX_COST_PER_RUN_USD=
BFL_API_ALLOWED_MODELS=flux-2-pro,flux-2-max,flux-2-flex,flux-2-klein

QWEN_IMAGE_ENABLED=false
QWEN_IMAGE_LOCAL_ROOT=C:\Comfy_UI_Main\models\qwen_image
SD35_ENABLED=false
SD35_LOCAL_ROOT=C:\Comfy_UI_Main\models\sd35
WAN22_ENABLED=false
HUNYUANVIDEO15_ENABLED=false
LTX2_ENABLED=false

# Wave17 body-shape correction controls
BODY_SHAPE_CORRECTION_ENABLED=false
BODY_SHAPE_CONTRACT_SCHEMA_PATH=08_SCHEMAS/body_shape_correction_contract.schema.json
BODY_REGION_TAXONOMY_PATH=10_REGISTRIES/wave17_body_region_taxonomy.json
BODY_PROPORTION_TARGET_PROFILES_PATH=10_REGISTRIES/wave17_body_proportion_target_profiles.json
BODY_CORRECTION_PASS_PROFILES_PATH=10_REGISTRIES/wave17_body_correction_pass_profiles.json
BODY_CORRECTION_QA_RULES_PATH=10_REGISTRIES/wave17_body_proportion_qa_scoring_rules.json
BODY_CORRECTION_MAX_TOTAL_RERUNS=4
BODY_CORRECTION_DEFAULT_DENOISE=0.22
BODY_CORRECTION_REQUIRE_PERSON_INSTANCE_MASK=true
BODY_CORRECTION_ALLOW_GLOBAL_REDRAW=false
