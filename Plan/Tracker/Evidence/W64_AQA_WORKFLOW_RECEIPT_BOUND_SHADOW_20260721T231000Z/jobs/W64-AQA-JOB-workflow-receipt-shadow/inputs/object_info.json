{
  "CheckpointLoaderSimple": {
    "input": {
      "required": {
        "ckpt_name": [
          [
            "base.safetensors"
          ]
        ]
      }
    },
    "output": [
      "MODEL"
    ],
    "output_node": false
  },
  "Sampler": {
    "input": {
      "required": {
        "cfg": [
          "FLOAT",
          {
            "max": 100,
            "min": 0
          }
        ],
        "model": [
          "MODEL"
        ],
        "steps": [
          "INT",
          {
            "max": 1000,
            "min": 1
          }
        ],
        "text": [
          "STRING"
        ]
      }
    },
    "output": [
      "IMAGE"
    ],
    "output_node": false
  },
  "SaveImage": {
    "input": {
      "required": {
        "filename_prefix": [
          "STRING"
        ],
        "images": [
          "IMAGE"
        ]
      }
    },
    "output": [],
    "output_node": true
  }
}
