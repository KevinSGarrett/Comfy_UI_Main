{
  "schema_version": "1.0.0",
  "registry_id": "wave64_row082_repetition_diversity_policy_registry",
  "revision": "wave64_row082_repetition_diversity_policy_v0.1.0",
  "tracker_id": "TRK-W64-082",
  "authority": "planning_freeze_not_library_acceptance",
  "notes": [
    "Policy freezes Row082 cooldown, near-duplicate, alternation, continuity, and bounded-variation contracts for synthetic fixture calibration.",
    "It does not accept library completion or substitute for Rows074/080/081 authority."
  ],
  "required_gates": [
    "cooldown",
    "near_duplicate_penalty",
    "alternation",
    "scene_continuity",
    "bounded_variation"
  ],
  "hard_exclusion_order": [
    "MISSING_SELECTION_HISTORY",
    "COOLDOWN_ACTIVE",
    "ALTERNATION_VIOLATION",
    "CONTINUITY_PARTITION_MISMATCH",
    "TRANSFORM_OUT_OF_BOUNDS",
    "SEMANTIC_FLOOR_VIOLATION",
    "DEPENDENCY_EVIDENCE_ABSENT"
  ],
  "cooldown_policy": {
    "default_window_events": 3,
    "event_family_windows": {
      "footstep": 4,
      "fabric_rustle": 2,
      "impact_hard": 3
    },
    "canonical_asset_key": "asset_sha256",
    "near_duplicate_group_key": "near_duplicate_group_id"
  },
  "near_duplicate_policy": {
    "feature_revision": "wave64_row082_near_dup_v0.1.0",
    "similarity_threshold": 0.92,
    "penalty_scale": 0.12,
    "penalty_cap": 0.36,
    "identical_pcm_is_hard_duplicate": true
  },
  "alternation_policy": {
    "enabled_event_families": ["footstep"],
    "state_machine": ["left", "right"],
    "require_expected_side": true,
    "reset_on_scene_change": true,
    "confidence_floor": 0.55
  },
  "continuity_policy": {
    "partition_keys": [
      "actor_id",
      "scene_id",
      "shot_id",
      "gait_id",
      "foot_side"
    ],
    "scene_change_resets": ["shot_id", "foot_side"],
    "scene_change_preserves": ["actor_id", "scene_id", "gait_id"],
    "require_actor_continuity": true
  },
  "bounded_variation_policy": {
    "allowed_transforms": [
      "gain_db",
      "timing_ms",
      "pitch_cents",
      "eq_tilt_db",
      "transient_scale",
      "stereo_width",
      "room_mix"
    ],
    "limits": {
      "gain_db": {"min": -1.5, "max": 1.5},
      "timing_ms": {"min": -12.0, "max": 12.0},
      "pitch_cents": {"min": -25.0, "max": 25.0},
      "eq_tilt_db": {"min": -1.0, "max": 1.0},
      "transient_scale": {"min": 0.92, "max": 1.08},
      "stereo_width": {"min": 0.90, "max": 1.10},
      "room_mix": {"min": 0.0, "max": 0.15}
    },
    "semantic_floors": {
      "event_fit": 0.70,
      "material_fit": 0.70,
      "force_fit": 0.65,
      "continuity_fit": 0.70
    }
  },
  "penalty_policy": {
    "recent_use": {"scale": 0.10, "cap": 0.30},
    "near_duplicate_recent_use": {"scale": 0.12, "cap": 0.36},
    "weak_variation_diversity": {"scale": 0.05, "cap": 0.10}
  },
  "tie_break_order": [
    "total_score_desc",
    "candidate_id_asc",
    "asset_sha256_asc"
  ],
  "decision_thresholds": {
    "min_select_confidence": 0.55,
    "abstain_when_no_eligible": true,
    "require_rank_one_selection": true
  },
  "fail_closed": {
    "missing_history_rejected": true,
    "cooldown_active_hard_excludes": true,
    "alternation_violation_hard_excludes": true,
    "out_of_bound_transform_rejected": true,
    "semantic_floor_violation_rejected": true,
    "duplicate_ranks_rejected": true,
    "library_authority_requires_dependencies": true,
    "product_completion_forbidden_until_runtime_proof": true
  }
}
