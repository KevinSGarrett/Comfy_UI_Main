{
  "schema_version": "1.0.0",
  "registry_id": "wave64_row080_hybrid_audio_retrieval_index_registry",
  "revision": "wave64_row080_hybrid_audio_retrieval_index_v0.1.0",
  "tracker_id": "TRK-W64-080",
  "authority": "planning_freeze_not_library_acceptance",
  "notes": [
    "Frozen retrieval policy for Row080 synthetic fixture calibration and fail-closed generation isolation.",
    "All channels in one query must bind a single immutable index generation.",
    "This registry does not accept library completion or substitute for Rows069/077/079 authority."
  ],
  "required_channels": [
    "structured_metadata_filter",
    "lexical_search",
    "embedding_similarity",
    "canonical_content_hash_deduplication"
  ],
  "required_identity_fields": [
    "query_sha256",
    "index_revision",
    "index_manifest_sha256",
    "record_schema_sha256",
    "taxonomy_revision_sha256",
    "embedding_index_sha256",
    "retrieval_policy_sha256",
    "ordered_candidate_set_sha256"
  ],
  "structured_filter_fields": [
    "event_type",
    "material",
    "sync_class",
    "intensity_band",
    "license_classification"
  ],
  "lexical_policy": {
    "tokenizer": "whitespace_lower_alnum",
    "field_weights": {
      "tags": 1.0,
      "caption": 0.8,
      "relative_path": 0.4
    },
    "min_token_length": 2
  },
  "vector_policy": {
    "metric": "cosine",
    "dimension": 4,
    "min_similarity": 0.0,
    "normalize_query_and_record": true
  },
  "merge_policy": {
    "channel_weights": {
      "structured_metadata_filter": 0.35,
      "lexical_search": 0.30,
      "embedding_similarity": 0.35
    },
    "tie_break_order": [
      "merged_score_desc",
      "canonical_pcm_sha256_asc",
      "asset_id_asc"
    ]
  },
  "dedup_policy": {
    "key": "canonical_pcm_sha256",
    "representative_order": [
      "merged_score_desc",
      "asset_id_asc"
    ],
    "apply_before_limit": true
  },
  "generation_isolation": {
    "require_exact_index_revision": true,
    "reject_stale_or_mixed_generations": true,
    "reject_missing_channel_artifacts": true,
    "reject_corrupt_channel_hashes": true
  },
  "fail_closed": {
    "library_authority_requires_dependencies": true,
    "stale_generation_mix_rejected": true,
    "missing_channel_rejected": true,
    "duplicate_content_must_collapse": true,
    "empty_query_rejected": true
  },
  "dependency_prerequisites": [
    "TRK-W64-069",
    "TRK-W64-077",
    "TRK-W64-079"
  ]
}
