{
  "schema_name": "wave64_av_sync_gate_rules",
  "registry_version": 1,
  "parser_rules": {
    "allowed_pyav_versions": [
      "18.0.0"
    ]
  },
  "sync_rules": {
    "max_start_offset_seconds": 0.04,
    "max_cumulative_endpoint_drift_seconds": 0.05,
    "max_anchor_frame_delta": 1.0
