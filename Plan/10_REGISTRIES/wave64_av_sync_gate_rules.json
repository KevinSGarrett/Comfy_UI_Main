      "matroska",
      "matroska,webm"
    ],
    "required_video_stream_count": 1,
    "required_audio_stream_count": 1,
    "required_video_codec": "ffv1",
    "required_audio_codec": "pcm_s16le",
    "required_audio_sample_rate_hz": 16000,
    "required_audio_channels": 1,
    "required_audio_layouts": [
      "mono"
    ]
  },
  "producer_rules": {
    "measurement_allowlist": [
      {
        "proof_kind": "anchor_measurement",
        "engine": "fixture_anchor_engine",
        "model": "fixture_anchor_model",
