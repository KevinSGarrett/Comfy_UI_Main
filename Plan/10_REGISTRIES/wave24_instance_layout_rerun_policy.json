{
  "rerun_policy": [
    {
      "failure": "wrong_character_edit",
      "action": "rerun_with_stricter_target_instance_mask"
    },
    {
      "failure": "merged_bodies",
      "action": "reroute_to_frame_depth_or_pose_repair"
    },
    {
      "failure": "skeleton_conflict",
      "action": "reroute_to_pose_control_map_wave"
    },
    {
      "failure": "depth_order_conflict",
      "action": "rerun_depth_occlusion_layout"
    },
    {
      "failure": "missing_region_owner",
      "action": "rebuild_region_ownership_map"
    }
  ]
}
