{
  "schema_version": "1.0",
  "registry_id": "end_to_end_architecture_boundary_registry",
  "authority_order": [
    "local_project",
    "github",
    "model_registry",
    "s3",
    "ec2",
    "workflow_lanes",
    "qa_evidence",
    "release_gate",
    "done_certification"
  ],
  "boundaries": {
    "local_project": {
      "authority": "C:\\Comfy_UI_Main",
      "owns": ["execution_ledger", "orchestration_source", "tracker_items", "hydration", "final_decisions"],
      "must_not_delegate_authority_to": ["legacy_root", "ec2_workspace", "s3_objects"]
    },
    "github": {
      "authority": "origin/main",
      "stores": ["code", "workflow_templates", "schemas", "registries", "tests", "lightweight_evidence"],
      "excludes": ["model_binaries", "private_inputs", "runtime_outputs", "secrets"],
      "mutation_owner": "Codex Desktop"
    },
    "model_registry": {
      "authority": "Plan/Registries/Models/model_registry.jsonl",
      "required_before_hydration": ["model_id", "license", "source", "sha256", "target_path", "compatibility", "validation_state"]
    },
    "s3": {
      "authority": "hash_bound_object_manifests",
      "stores": ["selected_model_binaries", "selected_runtime_bundles", "selected_transfer_artifacts"],
      "planning_authority": false,
      "full_library_sync_allowed": false
    },
    "ec2": {
      "authority": "approved_on_demand_gpu_worker",
      "planning_authority": false,
      "required_gates": ["local", "git", "authentication", "budget", "ttl", "emergency_stop", "input", "model", "workflow", "pullback"],
      "required_terminal_state": "stopped"
    },
    "workflow_lanes": {
      "authority": ["Plan/07_IMPLEMENTATION/workflow_templates/base_generation/runtime_lane_queue.json", "Workflows/base_generation/ACTIVE_LANES.json"],
      "selection_scope": "one_bounded_lane",
      "required_bindings": ["workflow", "inputs", "models", "gates", "promotion_rule"]
    },
    "qa_evidence": {
      "authority": ["Plan/Instructions/QA/Evidence", "Plan/Tracker/Evidence"],
      "required_decisions": ["pass", "conditional_pass", "repair", "blocked"],
      "existence_is_pass": false
    },
    "release_gate": {
      "authority": ["Plan/02_TARGET_ARCHITECTURE/WAVE34_RELEASE_GATE_DECISION_ENGINE.md", "Plan/11_RELEASES/WAVE34_RELEASE_GATE_DECISION.json"],
      "fail_closed_on_missing": ["runtime_proof", "qa_proof", "release_manifest", "failure_resolution"]
    },
    "done_certification": {
      "authority": "Plan/Instructions/QA/DONE_CERTIFICATION_EVIDENCE_PROTOCOL.md",
      "required": ["implementation", "tests", "qa", "artifact_inspection", "tracker_update", "item_update", "known_issue_review", "final_record"],
      "scope_inheritance_allowed": false
    }
  },
  "runtime_action_allowed_by_registry": false,
  "promotion_allowed_by_registry": false,
  "full_project_completion_implied": false
}
