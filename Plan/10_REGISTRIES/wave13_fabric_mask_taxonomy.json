{
  "scope": "clothing_fabric_material_and_edge_mask_taxonomy",
  "regions": [
    {
      "id": "full_garment",
      "scale": "major",
      "purpose": "isolate an entire clothing item or fabric surface"
    },
    {
      "id": "garment_panel",
      "scale": "minor",
      "purpose": "separate sleeves, torso panels, pant legs, skirt panels, or large cloth sections"
    },
    {
      "id": "fabric_fold_group",
      "scale": "minor",
      "purpose": "repair or enhance visible fold groups without changing body silhouette"
    },
    {
      "id": "seam_or_hem",
      "scale": "micro",
      "purpose": "edge repair, seam definition, hemline alignment"
    },
    {
      "id": "fabric_texture_patch",
      "scale": "micro",
      "purpose": "weave, grain, fuzz, roughness, sheen"
    },
    {
      "id": "strap_or_thin_detail",
      "scale": "nano",
      "purpose": "thin fabric lines and tiny cleanup masks"
    },
    {
      "id": "fabric_body_contact_edge",
      "scale": "nano",
      "purpose": "where clothing meets body or compresses visually"
    }
  ],
  "qa_rules": [
    "do_not_change_locked_outfit_identity",
    "preserve_body_silhouette_unless_revision_approved",
    "verify_contact_shadow_and_occlusion"
  ]
}
