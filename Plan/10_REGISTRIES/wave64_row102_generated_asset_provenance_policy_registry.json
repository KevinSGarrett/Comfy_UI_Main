    "missing_input_hashes_rejected": true,
    "missing_prompt_hash_rejected": true,
    "missing_engine_hashes_rejected": true,
    "missing_seed_rejected": true,
    "missing_output_hashes_rejected": true,
    "rights_non_pass_rejected": true,
    "selector_visible_staged_candidate_rejected": true,
    "approved_library_path_before_promotion_rejected": true,
    "content_based_suppression_rejected": true,
    "candidate_records_immutable": true
