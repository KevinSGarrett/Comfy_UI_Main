{
  "schema_name": "wave30_reference_speaker_registry",
  "registry_version": 1,
  "required_fields": [
    "reference_id",
    "source",
    "license",
    "transcript",
    "path",
    "sha256",
    "bytes",
    "duration_seconds",
    "permitted_character_ids",
    "production_authorized"
  ],
  "references": [],
  "policy": {
    "minimum_clean_duration_seconds": 10.0,
    "maximum_clean_duration_seconds": 30.0,
    "required_channel_layout": "dry_mono_preferred",
    "music_or_reverb_allowed": false,
    "clipping_allowed": false,
    "license_and_character_use_must_be_explicit": true
  }
}
