{
  "version": "wave12_v1",
  "count_policy": {
    "exact_count_required_by_default": true,
    "visible_primary_character_required": true,
    "extra_unexplained_people_fail": true,
    "body_fragments_count_as_extra_if_unassigned": true,
    "reflection_or_poster_people_allowed_only_if_scene_role_is_background_decor": true
  },
  "evidence_fields": [
    "expected_character_count",
    "detected_person_instances",
    "detected_skeletons",
    "detected_faces",
    "assigned_character_ids",
    "unassigned_body_fragments",
    "extra_person_like_regions"
  ],
  "failure_modes": [
    "missing_primary_character",
    "extra_character",
    "duplicated_character",
    "merged_body",
    "split_body_counted_as_two",
    "unassigned_body_fragment",
    "background_person_false_positive_not_marked"
  ]
}
