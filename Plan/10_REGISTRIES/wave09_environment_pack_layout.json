{
  "pack_root": "Implementation/environment_packs/{environment_id}/{environment_version}",
  "required_files": [
    "manifest.json",
    "room_profile.json",
    "lighting_rig.json",
    "prop_registry.json",
    "material_surface_profiles.json",
    "scale_reference.json"
  ],
  "optional_dirs": [
    "references/room",
    "references/lighting",
    "references/materials",
    "references/props",
    "references/camera",
    "references/masks",
    "video",
    "audio"
  ],
  "large_asset_policy": "Use Wave02 S3/local/EC2 cache rules for large binaries."
}
