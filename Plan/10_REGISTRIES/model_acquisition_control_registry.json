      "download_endpoint": "https://civitai.com/api/download/models/{modelVersionId}",
      "browser_fallback": true
    },
    "huggingface": {
      "credential_keys": ["HF_TOKEN", "HUGGING_FACE_HUB_TOKEN"],
      "exact_revision_required": true,
      "browser_fallback": true
    }
  },
  "placement_map": {
    "Checkpoint": "checkpoints",
    "LORA": "loras",
    "ControlNet": "controlnet",
    "VAE": "vae",
    "TextEncoder": "text_encoders",
    "CLIP": "clip",
    "CLIPVision": "clip_vision",
    "DiffusionModel": "diffusion_models",
    "UNET": "unet",
    "UpscaleModel": "upscale_models",
    "LatentUpscaleModel": "latent_upscale_models",
    "Embedding": "embeddings",
    "Hypernetwork": "hypernetworks",
    "StyleModel": "style_models",
    "IPAdapter": "ipadapter",
    "PhotoMaker": "photomaker",
    "ModelPatch": "model_patches",
    "MotionModel": "animatediff_models",
    "AudioEncoder": "audio_encoders",
    "BackgroundRemoval": "background_removal",
    "MMAudio": "mmaudio",
    "FrameInterpolation": "frame_interpolation",
    "GeometryEstimation": "geometry_estimation",
    "OpticalFlow": "optical_flow",
    "Detection": "detection"
