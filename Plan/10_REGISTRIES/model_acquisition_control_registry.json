  "required_chain": [
    "capability_need_recorded",
    "exact_source_version_and_file_resolved",
    "license_and_access_state_recorded",
    "duplicate_hash_checked",
    "download_staged_and_resumable",
    "sha256_and_size_verified",
    "asset_moved_atomically_to_declared_comfyui_folder",
    "model_registry_upserted_idempotently",
    "runtime_validation_queue_upserted_idempotently",
    "runtime_requirements_and_workflow_bindings_updated",
    "local_object_info_visibility_checked",
    "bounded_runtime_smoke_and_modality_qa_completed"
  ],
  "browser_fallback_contract": {
    "use_signed_in_browser_session": true,
    "browser_cookie_export_prohibited": true,
    "api_token_paste_into_page_prohibited": true,
    "download_must_match_resolved_file": true,
    "browser_file_must_pass_same_hash_install_registry_and_wiring_path": true
  },
  "selection_policy": {
    "download_everything_speculatively": false,
    "download_when_a_concrete_lane_or_capability_need_exists": true,
    "prefer_exact_revisions_and_safetensors_when_available": true,
    "unknown_engine_compatibility_blocks_runtime_use": true,
    "content_based_suppression": false,
    "adult_or_nsfw_labels_are_metadata_not_filters": true,
    "paid_early_access_private_or_gated_access_must_not_be_bypassed": true
  },
  "done_gate": {
    "download_only_is_complete": false,
    "registry_only_is_complete": false,
    "workflow_reference_only_is_complete": false,
    "runtime_and_modality_qa_required": true,
    "production_promotion_requires_separate_evidence": true
  }
