{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Done Certification",
  "type": "object",
  "required": ["certification_id", "task_id", "title", "final_decision"],
  "properties": {
    "certification_id": {"type": "string"},
    "task_id": {"type": "string"},
    "title": {"type": "string"},
    "artifact_scope": {"type": "string"},
    "implementation_summary": {"type": "string"},
    "tests_performed": {"type": "array"},
    "qa_summary": {"type": "string"},
    "evidence_paths": {"type": "array", "items": {"type": "string"}},
    "known_issues": {"type": "array"},
    "final_decision": {"type": "string"},
    "certifier": {"type": "string"},
    "timestamp": {"type": "string"}
  }
}
