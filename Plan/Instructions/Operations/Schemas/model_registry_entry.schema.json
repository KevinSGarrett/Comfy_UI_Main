{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Comfy UI Main Model Registry Entry",
  "type": "object",
  "required": [
    "registry_schema_version",
    "record_id",
    "model_name",
    "model_type",
    "base_model",
    "local_path",
    "workflow_lane",
    "compatibility_status",
    "qa_status",
    "runtime_validation_status"
  ],
  "properties": {
    "registry_schema_version": {
      "type": "string"
    },
    "record_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "source_model_id": {
      "type": "string"
    },
    "source_model_version_id": {
      "type": "string"
    },
    "model_name": {
      "type": "string"
    },
    "model_type": {
      "type": "string"
    },
    "base_model": {
      "type": "string"
    },
    "version_name": {
      "type": "string"
    },
    "file_name": {
      "type": "string"
    },
    "file_extension": {
      "type": "string"
    },
    "file_size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "sha256": {
      "type": "string"
    },
    "source_hashes": {
      "type": "object"
    },
    "local_path": {
      "type": "string"
    },
    "storage_location": {
      "type": "string"
    },
    "workflow_lane": {
      "type": "string"
    },
    "compatibility_status": {
      "type": "string"
    },
    "compatible_engines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trigger_words": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "intended_use": {
      "type": "string"
    },
    "prompt_notes": {
      "type": "string"
    },
    "negative_prompt_notes": {
      "type": "string"
    },
    "qa_status": {
      "type": "string"
    },
    "runtime_validation_status": {
      "type": "string"
    },
    "visual_impact": {
      "type": "string"
    },
    "video_impact": {
      "type": "string"
    },
    "audio_impact": {
      "type": "string"
    },
    "known_issues": {
      "type": "array"
    },
    "last_tested_at": {
      "type": "string"
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
