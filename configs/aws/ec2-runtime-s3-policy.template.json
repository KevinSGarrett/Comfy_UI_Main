{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowRuntimeBucketPrefixList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::<bucket-name>",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "<deploy-bundle-prefix>/*",
            "<model-cache-prefix>/*",
            "<artifact-prefix>/*"
          ]
        }
      }
    },
    {
      "Sid": "AllowRuntimeBundleAndModelRead",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::<bucket-name>/<deploy-bundle-prefix>/*",
        "arn:aws:s3:::<bucket-name>/<model-cache-prefix>/*"
      ]
    },
    {
      "Sid": "AllowRuntimeArtifactWrite",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectTagging"
      ],
      "Resource": "arn:aws:s3:::<bucket-name>/<artifact-prefix>/*"
    }
  ]
}
