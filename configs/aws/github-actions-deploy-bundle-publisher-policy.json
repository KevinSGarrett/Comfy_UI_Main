{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeployPrefixBucketMetadata",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::comfy-ui-main-runtime-029530099913-us-east-1",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "deploy-bundles/github",
            "deploy-bundles/github/*"
          ]
        }
      }
    },
    {
      "Sid": "PublishAndVerifyDeployBundlesOnly",
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:GetObject",
        "s3:ListMultipartUploadParts",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::comfy-ui-main-runtime-029530099913-us-east-1/deploy-bundles/github/*"
    }
  ]
}
