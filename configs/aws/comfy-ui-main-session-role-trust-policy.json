{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "OnlyMainSessionBootstrapUser",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::029530099913:root"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalArn": "arn:aws:iam::029530099913:user/ComfyUIMainSessionBootstrap"
        }
      }
    }
  ]
}
